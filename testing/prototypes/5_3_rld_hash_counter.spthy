/* 
 * Protocol:    Clone detection with hash chain (with double update)
 * Modeler:     Alessio Yang
 * Date:        May 2026
 * 
 * Status:      Complete
 *
 * Notes:
 * - P = Prover, V = Verifier, A = Adversary
 * - Every message sent by an agent is signed with its secret key
 * - Change in semantics: State of V represents the previous state of P
 * 
 * Registration:
 * - P generates its own key pair (ltkPV, pkPV)
 * - V generates its own key pair (ltkVP, pkVP)
 * - The public keys (pkPV, pkVP) are shared across the network
 * - P and V initialise their states (prev_hP=~init, prev_nP='null')
 * 
 * Protocol:
 * - V generates a challenge ch and sends (prev_hP, prev_nP, ch) to P
 * - P receives the challenge (prev_hP, prev_nP, ch), generates a new nonce nP,
 *   updates its hash chain to next_hP, and sends (hP, nP, ch) to V
 *   (hP = h(<prev_hP, ch>), next_hP = h(<hP, nP>))
 * - V receives the response (hP, nP, ch) and checks that h(<prev_hP, ch>) = hP:
 *   - If true, V authenticates P and updates its state to (next_hP, nP)
 *   - Otherwise, V rejects P and detects a cloning
 * 
 * Desired security properties:
 * - Prover injective agreement
 * - Clone detection soundness: If V has detected, then either P or V has been
 *   cloned
 * - Clone detection weak completeness: If A clones P and authenticates, and then P
 *   tries to authenticate, then V detects the cloning
 */


theory 5_2_rld_hash_counter
begin

builtins: signing, hashing, natural-numbers

heuristic: I

restriction Equality:
  "All x y #i. Eq(x, y) @i ==> x = y"

restriction Inequality:
  "All x #i. Neq(x, x) @i ==> F"

restriction LessThan:
  "All %x %y #i. LessThan(%x, %y) @i ==> %x << %y"

restriction GreaterThan:
  "All %x %y #i. GreaterThan(%x, %y) @i ==> %y << %x"

// A prover may register with the same verifier no more than once.
restriction RegisterOnce:
  "All p v #i #j. Register(p, v) @i & Register(p, v) @j ==> #i = #j"


// Registration:
// - Both P and V generate their own key pairs
// - Both P and V initialise their internal states with the same values
// The idP, idV and inj_n nonces are never used in our protocol.
// They serve solely to optimise Tamarin's performance.
rule Register:
    [ Fr(~ltkPV), Fr(~ltkVP), Fr(~init),
      Fr(~idP), Fr(~idV), Fr(~inj_n) ]
  --[ Register($P, $V) ]->
    [ !Binding_PV($P, $V, ~idP, ~idV, pk(~ltkPV), pk(~ltkVP), ~ltkPV),
      !Binding_VP($V, $P, ~idV, ~idP, pk(~ltkVP), pk(~ltkPV), ~ltkVP),
      St_PV(~idP, %1, ~init, 'null'),
      St_VP(~idV, %1, ~init, 'null', ~inj_n, 'challenge_state'),
      // The optimization parameters have been made public to ensure that their
      // secrecy is not relevant to our protocol.
      Out(<pk(~ltkPV), pk(~ltkVP), ~init, ~idP, ~idV, ~inj_n>) ]

// V sends a challenge to P.
rule V_challenge:
  let m = <'challenge', $V, $P, %prev_cP, prev_hP, prev_nP, ~ch>
      sig = sign(m, ~ltkVP)
  in
    [ St_VP(~idV, %prev_cP, prev_hP, prev_nP, ~inj_n, 'challenge_state'),
      !Binding_VP($V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP),
      Fr(~ch) ]
  --[ Challenge($V, $P, %prev_cP, prev_hP, prev_nP, ~ch),
      Injectivity(~idV, ~inj_n, ~ch) ]->
    [ St_VP(~idV, %prev_cP, prev_hP, prev_nP, ~ch, 'verify_state'),
      Out(<m, sig>) ]

// P receives the challenge and sends the response to V.
rule P_response:
  let v_m =  <'challenge', $V, $P, %prev_cP, prev_hP, prev_nP, ch>
      %cP = %prev_cP %+ %1
      %next_cP = %cP %+ %1
      hP = h(<prev_hP, ch, %cP>)
      p_m = <'response', $P, $V, %cP, hP, ~nP, ch>
      p_sig = sign(p_m, ~ltkPV)
      next_hP = h(<hP, ~nP, %next_cP>)
  in
    [ In(<v_m, v_sig>),
      St_PV(~idP, %prev_cP, prev_hP, prev_nP),
      !Binding_PV($P, $V, ~idP, ~idV, pkPV, pkVP, ~ltkPV),
      Fr(~nP) ]
  --[ Eq(verify(v_sig, v_m, pkVP), true),
      Response($P, $V, %cP, hP, ~nP, ch) ]->
    [ St_PV(~idP, %next_cP, next_hP, ~nP),
      Out(<p_m, p_sig>) ]

// V receives P's response and successfully authenticates it.
rule V_accept:
  let m = <'response', $P, $V, %cP, hP, nP, ch>
      %expected_cP = %prev_cP %+ %1
      %next_cP = %expected_cP %+ %1
      expected_hP = h(<prev_hP, ch, %expected_cP>)
      next_hP = h(<expected_hP, nP, %next_cP>)
  in
    [ In(<m, sig>),
      St_VP(~idV, %prev_cP, prev_hP, prev_nP, ch, 'verify_state'),
      !Binding_VP($V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP),
      Fr(~inj_n) ]
  --[ Verify($V, $P, %cP, hP, nP, ch),
      Eq(verify(sig, m, pkPV), true),
      Eq(%expected_cP, %cP),
      Eq(expected_hP, hP),
      Accept($V, $P),
      Injectivity(~idV, ch, ~inj_n) ]->
    [ St_VP(~idV, %next_cP, next_hP, nP, ~inj_n, 'challenge_state') ]

restriction HashLessThan:
  "All h0 ch h1 h2 %c1 %c2 #i. HashLessThan(h0, ch, %c1, %c2, h1, h2) @i
    ==> %c1 << %c2 & h1 = h(<h0, ch, %c1>) & h2 = h(<h0, ch, %c2>)"

// V receives P's response and detects a loss of response.
rule V_detect_response_loss:
  let m = <'response', $P, $V, %cP, hP, nP, ch>
      %expected_cP = %prev_cP %+ %1
      expected_hP = h(<prev_hP, ch, %expected_cP>)
  in
    [ In(<m, sig>),
      St_VP(~idV, %prev_cP, prev_hP, prev_nP, ch, 'verify_state'),
      !Binding_VP($V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP) ]
  --[ Verify($V, $P, %cP, hP, nP, ch),
      Eq(verify(sig, m, pkPV), true),
      LessThan(%expected_cP, %cP),
      HashLessThan(prev_hP, ch, %expected_cP, %cP, expected_hP, hP),
      DetectResponseLoss($V, $P) ]->
    [ /* Perform recovery */ ]

restriction HashGreaterThan:
  "All h0 ch h1 h2 %c1 %c2 #i. HashGreaterThan(h0, ch, %c1, %c2, h1, h2) @i
    ==> %c2 << %c1 & h1 = h(<h0, ch, %c1>) & h2 = h(<h0, ch, %c2>)"

// V receives P's response and detects a clone.
rule V_detect_cloning:
  let m = <'response', $P, $V, %cP, hP, nP, ch>
      %expected_cP = %prev_cP %+ %1
      expected_hP = h(<prev_hP, ch, %expected_cP>)
  in
    [ In(<m, sig>),
      St_VP(~idV, %prev_cP, prev_hP, prev_nP, ch, 'verify_state'),
      !Binding_VP($V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP) ]
  --[ Verify($V, $P, %cP, hP, nP, ch),
      Eq(verify(sig, m, pkPV), true),
      GreaterThan(%expected_cP, %cP),
      HashGreaterThan(prev_hP, ch, %expected_cP, %cP, expected_hP, hP),
      DetectCloning($V, $P) ]->
    [ /* Perform mitigation */ ]

// Cloning P's key.
rule Reveal_ltk_PV:
    [ !Binding_PV($P, $V, ~idP, ~idV, pkPV, pkVP, ~ltkPV) ]
  --[ Reveal_ltk_PV($P, $V) ]->
    [ Out(~ltkPV) ]

// Cloning V's key.
rule Reveal_ltk_VP:
    [ !Binding_VP($V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP) ]
  --[ Reveal_ltk_VP($V, $P) ]->
    [ Out(~ltkVP) ]


// Between sending a challenge and verifying the response to that specific 
// challenge, the verifier cannot change its state.
lemma verifier_injectivity[reuse]:
  "All idV inj_n1 ch inj_n2 n1 n2 #i #i1 #i3.
    Injectivity(idV, inj_n1, ch) @i1 &
    Injectivity(idV, ch, inj_n2) @i3 &
    Injectivity(idV, n1, n2) @i &
    #i < #i3 ==> not(#i1 < #i)"

// Verify the correctness of the protocol for a single authentication session.
lemma executability_honest_single_session:
  exists-trace
  "Ex p v #i. Accept(v, p) @i &
    not(Ex #j. Reveal_ltk_PV(p, v) @j) &
    not(Ex #j. Reveal_ltk_VP(v, p) @j)"

// Verify the correctness of the protocol for two consecutive authentication
// sessions.
lemma executability_honest_consecutive_sessions:
  exists-trace
   "Ex p v #i1 #i2. Accept(v, p) @i1 & Accept(v, p) @i2 & #i1 < #i2 &
    not(Ex #i. Reveal_ltk_PV(p, v) @i) &
    not(Ex #i. Reveal_ltk_VP(v, p) @i)"

lemma executability_honest_response_loss:
  exists-trace
  "Ex v p #i. DetectResponseLoss(v, p) @i &
    not(Ex #i. Reveal_ltk_PV(p, v) @i) &
    not(Ex #i. Reveal_ltk_VP(v, p) @i)"

lemma executability_cloning:
  exists-trace
  "Ex v p #i. DetectCloning(v, p) @i"

// If V has authenticated P, then P must have sent a response previously, and their 
// state must never have been used in other authentication sessions.
lemma prover_injective_agreement:
  "All p v %cP hP nP ch #i2.
    Verify(v, p, %cP, hP, nP, ch) @i2 & Accept(v, p) @i2 &
    not(Ex #i. Reveal_ltk_PV(p, v) @i) &
    not(Ex #i. Reveal_ltk_VP(v, p) @i)
    ==>
    (Ex #i1. Response(p, v, %cP, hP, nP, ch) @i1 & #i1 < #i2) &
    not(Ex p_i v_i #i.
      Verify(v_i, p_i, %cP, hP, nP, ch) @i & Accept(v_i, p_i) @i & not(#i = #i2))"

// If V has detected, then either P's key or V's key has been cloned (or both have 
// been cloned).
lemma clone_detection_soundness:
  "All p v #i2. DetectCloning(v, p) @i2
    ==>
    (Ex #i1. Reveal_ltk_PV(p, v) @i1 & #i1 < #i2) |
    (Ex #i1. Reveal_ltk_VP(v, p) @i1 & #i1 < #i2)"

// If V has detected a response loss, then P must have responded at least twice
// previously.
lemma response_loss_detection_soundness:
  "All p v #i3. DetectResponseLoss(v, p) @i3 &
    not(Ex #i. Reveal_ltk_PV(p, v) @i & #i < #i3) &
    not(Ex #i. Reveal_ltk_VP(v, p) @i & #i < #i3)
    ==>
    (Ex %cP1 hP1 nP1 ch1 %cP2 hP2 nP2 ch2 #i1 #i2.
      Response(p, v, %cP1, hP1, nP1, ch1) @i1 &
      Response(p ,v, %cP2, hP2, nP2, ch2) @i2 &
      #i1 < #i2 & #i2 < #i3)"

// If V has verified a response and subsequently completed a successful
// authentication session, then either the previous response came from P or it was
// forged by A, triggering a detection.
// Lemma relaxation: P's key is not clonable.
lemma clone_detection_in_compromised_previous_session_verifier_key[use_induction]:
  "All p v %cP1 hP1 nP1 ch1 %cP2 hP2 nP2 ch2 #i2 #i3 #i4.
    Verify(v, p, %cP1, hP1, nP1, ch1) @i2 &
    Response(p, v, %cP2, hP2, nP2, ch2) @i3 &
    Verify(v, p, %cP2, hP2, nP2, ch2) @i4 &
    #i2 < #i3 & #i3 < #i4
    ==>
    (Ex #i1. Response(p, v, %cP1, hP1, nP1, ch1) @i1 & #i1 < #i2) |
    (Ex #i. DetectCloning(v, p) @i) |
    (Ex #i. Reveal_ltk_PV(p, v) @i)"

// If V has verified a response and subsequently completed a successful
// authentication session, then either the previous response came from P or it was
// forged by A, triggering a detection.
// Lemma relaxation: V's key is not clonable.
lemma clone_detection_in_compromised_previous_session_prover_key[use_induction]:
  "All p v %cP1 hP1 nP1 ch1 %cP2 hP2 nP2 ch2 #i2 #i3 #i4.
    Verify(v, p, %cP1, hP1, nP1, ch1) @i2 &
    Response(p, v, %cP2, hP2, nP2, ch2) @i3 &
    Verify(v, p, %cP2, hP2, nP2, ch2) @i4 &
    #i2 < #i3 & #i3 < #i4
    ==>
    (Ex #i1. Response(p, v, %cP1, hP1, nP1, ch1) @i1 & #i1 < #i2) |
    (Ex #i. DetectCloning(v, p) @i) |
    (Ex #i. Reveal_ltk_VP(v, p) @i)"

// If V has verified a response and subsequently completed a successful
// authentication session, then either the previous response came from P or it was
// forged by A, triggering a detection.
lemma clone_detection_in_compromised_previous_session_both_keys[use_induction]:
  "All p v %cP1 hP1 nP1 ch1 %cP2 hP2 nP2 ch2 #i2 #i3 #i4.
    Verify(v, p, %cP1, hP1, nP1, ch1) @i2 &
    Response(p, v, %cP2, hP2, nP2, ch2) @i3 &
    Verify(v, p, %cP2, hP2, nP2, ch2) @i4 &
    #i2 < #i3 & #i3 < #i4
    ==>
    (Ex #i1. Response(p, v, %cP1, hP1, nP1, ch1) @i1 & #i1 < #i2) |
    (Ex #i. DetectCloning(v, p) @i)"


end