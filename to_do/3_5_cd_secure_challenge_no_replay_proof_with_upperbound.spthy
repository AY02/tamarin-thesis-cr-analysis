                          qed
                        qed
                      qed
                    qed
                  next
                    case Register
                    by contradiction /* contradictory subterm store */
                  qed
                next
                  case secure_channel_receive_case_2
                  solve( (¬(#i2 < #vr.3))  ∥ (%n_p1 ⊏ %n_v.2) )
                    case case_1
