                                    by contradiction /* non-injective facts (#i1,#vr.8,#vr.9) */
                                  next
                                    case V_challenge_case_2
                                    solve( !KU( ~ch ) @ #vk.15 )
                                      case P_response
                                      by contradiction /* from formulas */
                                    qed
