                                  solve( !KU( ~ch ) @ #vk.15 )
                                    case P_response
                                    by contradiction /* from formulas */
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      next
                        case Register
                        by contradiction /* contradictory subterm store */
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma clone_detection_in_compromised_previous_session_prover_counter_forgery:
  all-traces
  "∀ p v %n_p1 ch1 %n_p2 ch2 #i2 #i3 #i4.
    (((((Verify( v, p, <%n_p1, ch1> ) @ #i2) ∧
        (Response( p, v, <%n_p2, ch2> ) @ #i3)) ∧
       (Verify( v, p, <%n_p2, ch2> ) @ #i4)) ∧
      (#i2 < #i3)) ∧
     (#i3 < #i4)) ⇒
    ((∃ #i1. (Response( p, v, <%n_p1, ch1> ) @ #i1) ∧ (#i1 < #i2)) ∨
     (∃ #i. Detect( v, p ) @ #i))"
/*
guarded formula characterizing all counter-examples:
"∃ p v %n_p1 ch1 %n_p2 ch2 #i2 #i3 #i4.
  (Verify( v, p, <%n_p1, ch1> ) @ #i2) ∧
  (Response( p, v, <%n_p2, ch2> ) @ #i3) ∧
  (Verify( v, p, <%n_p2, ch2> ) @ #i4)
 ∧
  (#i2 < #i3) ∧
  (#i3 < #i4) ∧
  (∀ #i1. (Response( p, v, <%n_p1, ch1> ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i. (Detect( v, p ) @ #i) ⇒ ⊥)"
*/
simplify
solve( !Binding( ~idP, ~idV, ltkPV, pkPV, $P, $V )[+] ▶₂ #i3 )
  case Register
  solve( !Ltk( $P, $V, ~ltkPV )[+] ▶₃ #i3 )
    case Register
    solve( Verify( $V, $P, <%n_p1, ch1> ) @ #i2 )
      case V_detect
      by contradiction /* from formulas */
    next
      case V_verify
      solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x), $P, $V )[+] ▶₂ #i2 )
        case Register
        solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i2 )
          case Register
          solve( Verify( $V, $P, <(%n_p%+%1), ch2> ) @ #i4 )
            case V_detect
            by contradiction /* from formulas */
          next
            case V_verify
            solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x), $P, $V )[+] ▶₂ #i4 )
              case Register
              solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i4 )
                case Register
                solve( SecRecv( $V, $P, ch2 ) ▶₀ #i3 )
                  case secure_channel_receive_case_1
                  solve( St_P( ~idP, $P, $V, %n_p ) ▶₁ #i3 )
                    case P_response
                    solve( (¬(#i2 < #vr.7))  ∥ (%n_p1 ⊏ %n_v.2) )
                      case case_1
                      solve( (¬(#vr.7 < #i2))  ∥ (%n_v.2 ⊏ %n_p1) )
                        case case_1
                        solve( (#i2 = #vr.7)  ∥ (#vr.7 < #i2) )
                          case case_1
                          solve( St_V( ~idV, $V, $P, %n_v, 'verify_state', ch1 ) ▶₁ #i2 )
                            case V_challenge_case_1
                            solve( !KU( ~ch ) @ #vk.9 )
                              case P_response
                              by contradiction /* cyclic */
                            qed
                          next
                            case V_challenge_case_2
                            solve( !KU( ~ch ) @ #vk.11 )
                              case P_response
                              solve( !KU( sign(<%n_p1, ~ch>, ~ltkPV) ) @ #vk.12 )
                                case P_response
                                by contradiction /* from formulas */
                              next
                                case c_sign
                                solve( !KU( ~ltkPV ) @ #vk.23 )
                                  case Reveal_ltk
                                  solve( St_V( ~idV, $V, $P, %n_v.1, 'verify_state', ~ch.1
                                         ) ▶₁ #i4 )
                                    case V_challenge
                                    by contradiction /* non-injective facts (#i1,#i2,#vr.2) */
                                  qed
                                qed
                              qed
                            qed
                          qed
                        next
                          case case_2
                          by contradiction /* from formulas */
                        qed
                      next
                        case case_2
                        solve( (#i2 = #vr.7)  ∥ (#vr.7 < #i2) )
                          case case_1
                          by contradiction /* contradictory subterm store */
                        next
                          case case_2
                          solve( St_V( ~idV, $V, $P, %n_v, 'verify_state', ch1 ) ▶₁ #i2 )
                            case V_challenge_case_1
                            by contradiction /* non-injective facts (#i1,#vr.7,#vr.2) */
                          next
                            case V_challenge_case_2
                            solve( !KU( ~ch ) @ #vk.13 )
                              case P_response
                              solve( (¬(#vr.7 < #vr.9))  ∥ (%n_v.2 ⊏ %n_v) )
                                case case_1
                                solve( (¬(#vr.9 < #vr.7))  ∥ (%n_v ⊏ %n_v.2) )
                                  case case_1
