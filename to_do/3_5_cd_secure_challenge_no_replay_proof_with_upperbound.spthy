theory 3_5_cd_secure_challenge_no_replay

begin

// Function signature and definition of the equational theory E

builtins: natural-numbers
functions: fst/1, pair/2, pk/1, sign/2, snd/1, true/0, verify/3
equations:
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    verify(sign(x.1, x.2), x.1, pk(x.2)) = true

heuristic: I

/* looping facts with injective instances: St_P/4, St_V/6 */

restriction Equality:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

  /*
  expanded formula:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  */

restriction LessThan:
  "∀ %x %y #i. (LessThan( %x, %y ) @ #i) ⇒ (%x ⊏ %y)"
  // safety formula

  /*
  expanded formula:
  "∀ %x %y #i. (LessThan( %x, %y ) @ #i) ⇒ (%x ⊏ %y)"
  */

restriction GreaterEqualThan:
  "∀ %x %y #i.
    (GreaterEqualThan( %x, %y ) @ #i) ⇒ ((%y ⊏ %x) ∨ (%x = %y))"
  // safety formula

  /*
  expanded formula:
  "∀ %x %y #i.
    (GreaterEqualThan( %x, %y ) @ #i) ⇒ ((%y ⊏ %x) ∨ (%x = %y))"
  */

restriction RegisterOnce:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( p, v ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( p, v ) @ #j)) ⇒ (#i = #j)"
  */

restriction NoReversedRoles:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( v, p ) @ #j)) ⇒ (⊥)"
  // safety formula

  /*
  expanded formula:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( v, p ) @ #j)) ⇒ (⊥)"
  */

restriction RevealOnce:
  "∀ p v #i #j.
    ((Reveal( p, v ) @ #i) ∧ (Reveal( p, v ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ p v #i #j.
    ((Reveal( p, v ) @ #i) ∧ (Reveal( p, v ) @ #j)) ⇒ (#i = #j)"
  */

restriction UpperboundResponse3:
  "∀ p v n1 ch1 #i1 n2 ch2 #i2 n3 ch3 #i3 n4 ch4 #i4.
    ((((Response( p, v, <n1, ch1> ) @ #i1) ∧
       (Response( p, v, <n2, ch2> ) @ #i2)) ∧
      (Response( p, v, <n3, ch3> ) @ #i3)) ∧
     (Response( p, v, <n4, ch4> ) @ #i4)) ⇒
    ((((((#i1 = #i2) ∨ (#i1 = #i3)) ∨ (#i1 = #i4)) ∨ (#i2 = #i3)) ∨
      (#i2 = #i4)) ∨
     (#i3 = #i4))"
  // safety formula

  /*
  expanded formula:
  "∀ p v n1 ch1 #i1 n2 ch2 #i2 n3 ch3 #i3 n4 ch4 #i4.
    ((((Response( p, v, <n1, ch1> ) @ #i1) ∧
       (Response( p, v, <n2, ch2> ) @ #i2)) ∧
      (Response( p, v, <n3, ch3> ) @ #i3)) ∧
     (Response( p, v, <n4, ch4> ) @ #i4)) ⇒
    ((((((#i1 = #i2) ∨ (#i1 = #i3)) ∨ (#i1 = #i4)) ∨ (#i2 = #i3)) ∨
      (#i2 = #i4)) ∨
     (#i3 = #i4))"
  */

rule (modulo E) secure_channel_send:
   [ SecSend( A, B, m ) ]
  --[ SecChan_Out( A, B, m ) ]->
   [ Sec( A, B, m ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) secure_channel_receive:
   [ Sec( A, B, m ) ]
  --[ SecChan_In( A, B, m ) ]->
   [ SecRecv( A, B, m ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Register:
   [ Fr( ~ltkPV ), Fr( ~idP ), Fr( ~idV ) ]
  --[
  Register( $P, $V ), InitCounterP( ~idP, $P, $V ),
  InitCounterV( ~idV, $V, $P )
  ]->
   [
   !Ltk( $P, $V, ~ltkPV ), !Pk( $V, $P, pk(~ltkPV) ),
   !Binding( ~idP, ~idV, ~ltkPV, pk(~ltkPV), $P, $V ),
   St_P( ~idP, $P, $V, %1 ),
   St_V( ~idV, $V, $P, %1, 'challenge_state', 'null' ),
   Out( pk(~ltkPV) )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) V_challenge:
   [
   St_V( ~idV, $V, $P, %n_v, 'challenge_state', 'null' ),
   !Binding( ~idP, ~idV, ltkPV, pkPV, $P, $V )[+],
   !Pk( $V, $P, pkPV )[+], Fr( ~ch )
   ]
  --[ Challenge( $V, $P, %n_v, ~ch ) ]->
   [
   St_V( ~idV, $V, $P, %n_v, 'verify_state', ~ch ),
   SecSend( $V, $P, ~ch )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) P_response:
   [
   SecRecv( $V, $P, ch ), St_P( ~idP, $P, $V, %n_p ),
   !Binding( ~idP, ~idV, ltkPV, pkPV, $P, $V )[+],
   !Ltk( $P, $V, ltkPV )[+]
   ]
  --[
  Response( $P, $V, <(%n_p%+%1), ch> ),
  CounterP( ~idP, (%n_p%+%1), $P, $V )
  ]->
   [
   St_P( ~idP, $P, $V, (%n_p%+%1) ),
   Out( <$P, $V, <(%n_p%+%1), ch>, sign(<(%n_p%+%1), ch>, ltkPV)> )
   ]

  // loop breaker: [1]
  /* has exactly the trivial AC variant */

rule (modulo E) V_verify:
   [
   In( <$P, $V, <%n_p, ch>, sig> ),
   St_V( ~idV, $V, $P, %n_v, 'verify_state', ch ),
   !Binding( ~idP, ~idV, ltkPV, pkPV, $P, $V )[+],
   !Pk( $V, $P, pkPV )[+]
   ]
  --[
  Verify( $V, $P, <%n_p, ch> ),
  Eq( verify(sig, <%n_p, ch>, pkPV), true ), LessThan( %n_v, %n_p ),
  Accept( $V, $P ), CounterV( ~idV, %n_p, $V, $P )
  ]->
   [ St_V( ~idV, $V, $P, %n_p, 'challenge_state', 'null' ) ]

  // loop breaker: [1]
  /*
  rule (modulo AC) V_verify:
     [
     In( <$P, $V, <%n_p, ch>, sig> ),
     St_V( ~idV, $V, $P, %n_v, 'verify_state', ch ),
     !Binding( ~idP, ~idV, ltkPV, pkPV, $P, $V )[+],
     !Pk( $V, $P, pkPV )[+]
     ]
    --[
    Verify( $V, $P, <%n_p, ch> ), Eq( z, true ),
    LessThan( %n_v, %n_p ), Accept( $V, $P ),
    CounterV( ~idV, %n_p, $V, $P )
    ]->
     [ St_V( ~idV, $V, $P, %n_p, 'challenge_state', 'null' ) ]
    variants (modulo AC)
    1. ch    = ch.20
       pkPV  = pkPV.22
       sig   = sig.23
       z     = verify(sig.23, <%n_p.24, ch.20>, pkPV.22)
       %n_p  = %n_p.24
    
    2. ch    = ch.38
       pkPV  = pk(x.70)
       sig   = sign(<%n_p.42, ch.38>, x.70)
       z     = true
       %n_p  = %n_p.42
    // loop breaker: [1]
  */

rule (modulo E) V_detect:
   [
   In( <$P, $V, <%n_p, ch>, sig> ),
   St_V( ~idV, $V, $P, %n_v, 'verify_state', ch ),
   !Binding( ~idP, ~idV, ltkPV, pkPV, $P, $V )[+],
   !Pk( $V, $P, pkPV )[+]
   ]
  --[
  Verify( $V, $P, <%n_p, ch> ),
  Eq( verify(sig, <%n_p, ch>, pkPV), true ),
  GreaterEqualThan( %n_v, %n_p ), Detect( $V, $P )
  ]->
   [ ]

  /*
  rule (modulo AC) V_detect:
     [
     In( <$P, $V, <%n_p, ch>, sig> ),
     St_V( ~idV, $V, $P, %n_v, 'verify_state', ch ),
     !Binding( ~idP, ~idV, ltkPV, pkPV, $P, $V )[+],
     !Pk( $V, $P, pkPV )[+]
     ]
    --[
    Verify( $V, $P, <%n_p, ch> ), Eq( z, true ),
    GreaterEqualThan( %n_v, %n_p ), Detect( $V, $P )
    ]->
     [ ]
    variants (modulo AC)
    1. ch    = ch.14
       pkPV  = pkPV.16
       sig   = sig.17
       z     = verify(sig.17, <%n_p.18, ch.14>, pkPV.16)
       %n_p  = %n_p.18
    
    2. ch    = ch.17
       pkPV  = pk(x.27)
       sig   = sign(<%n_p.21, ch.17>, x.27)
       z     = true
       %n_p  = %n_p.21
  */

rule (modulo E) Reveal_ltk:
   [ !Ltk( $P, $V, ltkPV )[+] ]
  --[ Reveal( $P, $V ) ]->
   [ Out( ltkPV ) ]

  /* has exactly the trivial AC variant */

lemma counter_init [reuse, use_induction]:
  all-traces
  "(∀ p v idP %n_p #i2.
     (CounterP( idP, %n_p, p, v ) @ #i2) ⇒
     (∃ #i1. (InitCounterP( idP, p, v ) @ #i1) ∧ (#i1 < #i2))) ∧
   (∀ p v idV %n_v #i2.
     (CounterV( idV, %n_v, v, p ) @ #i2) ⇒
     (∃ #i1. (InitCounterV( idV, v, p ) @ #i1) ∧ (#i1 < #i2)))"
/*
guarded formula characterizing all counter-examples:
"((∃ p v idP %n_p #i2.
    (CounterP( idP, %n_p, p, v ) @ #i2)
   ∧
    ∀ #i1. (InitCounterP( idP, p, v ) @ #i1) ⇒ ¬(#i1 < #i2)) ∨
  (∃ p v idV %n_v #i2.
    (CounterV( idV, %n_v, v, p ) @ #i2)
   ∧
    ∀ #i1. (InitCounterV( idV, v, p ) @ #i1) ⇒ ¬(#i1 < #i2)))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (∃ p v idP %n_p #i2.
           (CounterP( idP, %n_p, p, v ) @ #i2)
          ∧
           ∀ #i1. (InitCounterP( idP, p, v ) @ #i1) ⇒ ¬(#i1 < #i2))  ∥
         (∃ p v idV %n_v #i2.
           (CounterV( idV, %n_v, v, p ) @ #i2)
          ∧
           ∀ #i1. (InitCounterV( idV, v, p ) @ #i1) ⇒ ¬(#i1 < #i2)) )
    case case_1
    solve( !Binding( ~idP, ~idV, ltkPV, pkPV, $P, $V )[+] ▶₂ #i2 )
      case Register
      by contradiction /* from formulas */
    qed
  next
    case case_2
    solve( !Binding( ~idP, ~idV, ltkPV, pk(x), $P, $V )[+] ▶₂ #i2 )
      case Register
      by contradiction /* from formulas */
    qed
  qed
qed

lemma counter_init_unique [reuse, use_induction]:
  all-traces
  "(∀ p v idP #i #j.
     ((InitCounterP( idP, p, v ) @ #i) ∧
      (InitCounterP( idP, p, v ) @ #j)) ⇒
     (#i = #j)) ∧
   (∀ p v idV #i #j.
     ((InitCounterV( idV, v, p ) @ #i) ∧
      (InitCounterV( idV, v, p ) @ #j)) ⇒
     (#i = #j))"
/*
guarded formula characterizing all counter-examples:
"((∃ p v idP #i #j.
    (InitCounterP( idP, p, v ) @ #i) ∧ (InitCounterP( idP, p, v ) @ #j)
   ∧
    ¬(#i = #j)) ∨
  (∃ p v idV #i #j.
    (InitCounterV( idV, v, p ) @ #i) ∧ (InitCounterV( idV, v, p ) @ #j)
   ∧
    ¬(#i = #j)))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (∃ p v idP #i #j.
           (InitCounterP( idP, p, v ) @ #i) ∧ (InitCounterP( idP, p, v ) @ #j)
          ∧
           ¬(#i = #j))  ∥
         (∃ p v idV #i #j.
           (InitCounterV( idV, v, p ) @ #i) ∧ (InitCounterV( idV, v, p ) @ #j)
          ∧
           ¬(#i = #j)) )
    case case_1
    by contradiction /* from formulas */
  next
    case case_2
    by contradiction /* from formulas */
  qed
qed

lemma counter_monotony [reuse, use_induction]:
  all-traces
  "(∀ p v idP %n_p1 %n_p2 #i1 #i2.
     (((CounterP( idP, %n_p1, p, v ) @ #i1) ∧
       (CounterP( idP, %n_p2, p, v ) @ #i2)) ∧
      (#i1 < #i2)) ⇒
     (%n_p1 ⊏ %n_p2)) ∧
   (∀ p v idV %n_v1 %n_v2 #i1 #i2.
     (((CounterV( idV, %n_v1, v, p ) @ #i1) ∧
       (CounterV( idV, %n_v2, v, p ) @ #i2)) ∧
      (#i1 < #i2)) ⇒
     (%n_v1 ⊏ %n_v2))"
/*
guarded formula characterizing all counter-examples:
"((∃ p v idP %n_p1 %n_p2 #i1 #i2.
    (CounterP( idP, %n_p1, p, v ) @ #i1) ∧
    (CounterP( idP, %n_p2, p, v ) @ #i2)
   ∧
    (#i1 < #i2) ∧ (¬(%n_p1 ⊏ %n_p2))) ∨
  (∃ p v idV %n_v1 %n_v2 #i1 #i2.
    (CounterV( idV, %n_v1, v, p ) @ #i1) ∧
    (CounterV( idV, %n_v2, v, p ) @ #i2)
   ∧
    (#i1 < #i2) ∧ (¬(%n_v1 ⊏ %n_v2))))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (∃ p v idP %n_p1 %n_p2 #i1 #i2.
           (CounterP( idP, %n_p1, p, v ) @ #i1) ∧
           (CounterP( idP, %n_p2, p, v ) @ #i2)
          ∧
           (#i1 < #i2) ∧ (¬(%n_p1 ⊏ %n_p2)))  ∥
         (∃ p v idV %n_v1 %n_v2 #i1 #i2.
           (CounterV( idV, %n_v1, v, p ) @ #i1) ∧
           (CounterV( idV, %n_v2, v, p ) @ #i2)
          ∧
           (#i1 < #i2) ∧ (¬(%n_v1 ⊏ %n_v2))) )
    case case_1
    by contradiction /* cyclic */
  next
    case case_2
    simplify
    solve( !Binding( ~idP, ~idV, ltkPV, pk(x), $P, $V )[+] ▶₂ #i1 )
      case Register
      solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i1 )
        case Register
        solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x), $P, $V )[+] ▶₂ #i2 )
          case Register
          solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i2 )
            case Register
            solve( St_V( ~idV, $V, $P, %n_v, 'verify_state', ch ) ▶₁ #i1 )
              case V_challenge_case_1
              simplify
              solve( !KU( ~ch ) @ #vk.9 )
                case P_response
                solve( St_V( ~idV, $V, $P, %n_v, 'verify_state', ch.1 ) ▶₁ #i2 )
                  case V_challenge_case_1
                  by contradiction /* cyclic */
                next
                  case V_challenge_case_2
                  simplify
                  solve( !KU( ~ch.1 ) @ #vk.16 )
                    case P_response
                    solve( (#vr.9 = #i1)  ∥ (#i1 < #vr.9)  ∥ (%n_v ⊏ %n_v1) )
                      case case_1
                      by contradiction /* cyclic */
                    next
                      case case_2
                      by contradiction /* from formulas */
                    next
                      case case_3
                      solve( (#i1 = #vr.9)  ∥ (#vr.9 < #i1) )
                        case case_1
                        by contradiction /* cyclic */
                      next
                        case case_2
                        by contradiction /* cyclic */
                      qed
                    qed
                  qed
                qed
              qed
            next
              case V_challenge_case_2
              solve( !KU( ~ch ) @ #vk.11 )
                case P_response
                solve( St_V( ~idV, $V, $P, %n_v.1, 'verify_state', ch.1 ) ▶₁ #i2 )
                  case V_challenge_case_1
                  by contradiction /* non-injective facts (#i1.1,#i1,#vr.9) */
                next
                  case V_challenge_case_2
                  simplify
                  simplify
                  solve( !KU( ~ch.1 ) @ #vk.18 )
                    case P_response
                    solve( (#vr.10 = #i1)  ∥ (#i1 < #vr.10)  ∥ (%n_v.1 ⊏ %n_v1) )
                      case case_1
                      by contradiction /* cyclic */
                    next
                      case case_2
                      by contradiction /* from formulas */
                    next
                      case case_3
                      solve( (#i1 = #vr.10)  ∥ (#vr.10 < #i1) )
                        case case_1
                        by contradiction /* cyclic */
                      next
                        case case_2
                        by contradiction /* cyclic */
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma counter_unique [reuse, use_induction]:
  all-traces
  "(∀ p v idP %n_p #i #j.
     ((CounterP( idP, %n_p, p, v ) @ #i) ∧
      (CounterP( idP, %n_p, p, v ) @ #j)) ⇒
     (#i = #j)) ∧
   (∀ p v idV %n_v #i #j.
     ((CounterV( idV, %n_v, v, p ) @ #i) ∧
      (CounterV( idV, %n_v, v, p ) @ #j)) ⇒
     (#i = #j))"
/*
guarded formula characterizing all counter-examples:
"((∃ p v idP %n_p #i #j.
    (CounterP( idP, %n_p, p, v ) @ #i) ∧
    (CounterP( idP, %n_p, p, v ) @ #j)
   ∧
    ¬(#i = #j)) ∨
  (∃ p v idV %n_v #i #j.
    (CounterV( idV, %n_v, v, p ) @ #i) ∧
    (CounterV( idV, %n_v, v, p ) @ #j)
   ∧
    ¬(#i = #j)))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (∃ p v idP %n_p #i #j.
           (CounterP( idP, %n_p, p, v ) @ #i) ∧
           (CounterP( idP, %n_p, p, v ) @ #j)
          ∧
           ¬(#i = #j))  ∥
         (∃ p v idV %n_v #i #j.
           (CounterV( idV, %n_v, v, p ) @ #i) ∧
           (CounterV( idV, %n_v, v, p ) @ #j)
          ∧
           ¬(#i = #j)) )
    case case_1
    by contradiction /* from formulas */
  next
    case case_2
    solve( !Binding( ~idP, ~idV, ltkPV, pk(x), $P, $V )[+] ▶₂ #i )
      case Register
      solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i )
        case Register
        solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x), $P, $V )[+] ▶₂ #j )
          case Register
          solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #j )
            case Register
            solve( (#i < #j)  ∥ (#j < #i) )
              case case_1
              by contradiction /* from formulas */
            next
              case case_2
              by contradiction /* from formulas */
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma prover_injective_agreement:
  all-traces
  "∀ p v %n_p ch #i2.
    (((Verify( v, p, <%n_p, ch> ) @ #i2) ∧ (Accept( v, p ) @ #i2)) ∧
     (¬(∃ #i. Reveal( p, v ) @ #i))) ⇒
    ((∃ #i1. (Response( p, v, <%n_p, ch> ) @ #i1) ∧ (#i1 < #i2)) ∧
     (¬(∃ p_j v_j #j.
         ((Verify( v_j, p_j, <%n_p, ch> ) @ #j) ∧
          (Accept( v_j, p_j ) @ #j)) ∧
         (¬(#j = #i2)))))"
/*
guarded formula characterizing all counter-examples:
"∃ p v %n_p ch #i2.
  (Verify( v, p, <%n_p, ch> ) @ #i2) ∧ (Accept( v, p ) @ #i2)
 ∧
  (∀ #i. (Reveal( p, v ) @ #i) ⇒ ⊥) ∧
  (((∀ #i1. (Response( p, v, <%n_p, ch> ) @ #i1) ⇒ ¬(#i1 < #i2)) ∨
    (∃ p_j v_j #j.
      (Verify( v_j, p_j, <%n_p, ch> ) @ #j) ∧ (Accept( v_j, p_j ) @ #j)
     ∧
      ¬(#j = #i2))))"
*/
simplify
solve( !Binding( ~idP, ~idV, ltkPV, pk(x), $P, $V )[+] ▶₂ #i2 )
  case Register
  solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i2 )
    case Register
    solve( Verify( $V, $P, <%n_p.1, ch.1> ) @ #i2 )
      case V_verify
      solve( (∀ #i1.
               (Response( $P, $V, <%n_p, ch> ) @ #i1) ⇒ ¬(#i1 < #i2))  ∥
             (∃ p_j v_j #j.
               (Verify( v_j, p_j, <%n_p, ch> ) @ #j) ∧ (Accept( v_j, p_j ) @ #j)
              ∧
               ¬(#j = #i2)) )
        case case_1
        solve( St_V( ~idV, $V, $P, %n_v, 'verify_state', ch ) ▶₁ #i2 )
          case V_challenge_case_1
          solve( !KU( ~ch ) @ #vk.7 )
            case P_response
            solve( !KU( sign(<%n_p, ~ch>, ~ltkPV) ) @ #vk.8 )
              case P_response
              by contradiction /* from formulas */
            next
              case c_sign
              solve( !KU( ~ltkPV ) @ #vk.9 )
                case Reveal_ltk
                by contradiction /* from formulas */
              qed
            qed
          qed
        next
          case V_challenge_case_2
          solve( !KU( ~ch ) @ #vk.9 )
            case P_response
            solve( !KU( sign(<%n_p, ~ch>, ~ltkPV) ) @ #vk.10 )
              case P_response
              by contradiction /* from formulas */
            next
              case c_sign
              solve( !KU( ~ltkPV ) @ #vk.16 )
                case Reveal_ltk
