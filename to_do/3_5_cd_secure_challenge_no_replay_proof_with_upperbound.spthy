                                        case case_1
                                        by contradiction /* cyclic */
                                      next
                                        case case_2
                                        by contradiction /* cyclic */
                                      qed
                                    qed
                                  qed
                                qed
                              next
                                case case_2
                                solve( (¬(#vr.10 < #vr.3))  ∥ ((%n_p.1%+%1) ⊏ (%n_p%+%1)) )
                                  case case_1
                                  solve( (#vr.3 = #vr.10)  ∥ (#vr.10 < #vr.3) )
                                    case case_1
                                    by contradiction /* contradictory subterm store */
                                  next
                                    case case_2
                                    by contradiction /* from formulas */
                                  qed
                                next
                                  case case_2
                                  solve( (#vr.3 = #vr.10)  ∥ (#vr.10 < #vr.3) )
                                    case case_1
                                    by contradiction /* contradictory subterm store */
                                  next
                                    case case_2
                                    solve( (#vr.9 = #vr.7)  ∥ (#vr.7 < #vr.9) )
                                      case case_1
                                      by contradiction /* cyclic */
                                    next
                                      case case_2
                                      solve( !KU( sign(<%n_p1, ~ch>, ~ltkPV) ) @ #vk.14 )
                                        case P_response
                                        by contradiction /* from formulas */
                                      next
                                        case c_sign
                                        solve( !KU( ~ltkPV ) @ #vk.30 )
                                          case Reveal_ltk
                                          solve( St_V( ~idV, $V, $P, %n_v.1, 'verify_state', ~ch.1
                                                 ) ▶₁ #i4 )
                                            case V_challenge
                                            by contradiction
                                               /* non-injective facts (#i1,#i2,#vr.2) */
                                          qed
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    next
                      case case_2
                      solve( (#vr.7 = #i2)  ∥ (#i2 < #vr.7) )
                        case case_1
                        by contradiction /* contradictory subterm store */
                      next
                        case case_2
                        solve( St_V( ~idV, $V, $P, %n_v, 'verify_state', ch1 ) ▶₁ #i2 )
                          case V_challenge_case_1
                          solve( !KU( ~ch ) @ #vk.11 )
                            case P_response
                            by contradiction /* cyclic */
                          qed
                        next
                          case V_challenge_case_2
                          solve( !KU( ~ch ) @ #vk.13 )
                            case P_response
                            solve( !KU( sign(<%n_p1, ~ch>, ~ltkPV) ) @ #vk.14 )
                              case P_response
