                                               /* non-injective facts (#i1,#i2,#vr.2) */
                                          qed
                                        qed
                                      qed
                                    next
                                      case case_2
                                      by contradiction /* from formulas */
                                    qed
                                  next
                                    case case_2
                                    solve( (#vr.3 = #vr.10)  ∥ (#vr.10 < #vr.3) )
                                      case case_1
                                      by contradiction /* contradictory subterm store */
                                    next
                                      case case_2
                                      solve( (#vr.7 = #vr.9)  ∥ (#vr.9 < #vr.7) )
                                        case case_1
                                        by contradiction /* cyclic */
                                      next
                                        case case_2
                                        by contradiction /* cyclic */
                                      qed
                                    qed
                                  qed
                                next
                                  case case_2
                                  solve( (¬(#vr.10 < #vr.3))  ∥ ((%n_p.1%+%1) ⊏ (%n_p%+%1)) )
                                    case case_1
                                    solve( (#vr.3 = #vr.10)  ∥ (#vr.10 < #vr.3) )
                                      case case_1
                                      by contradiction /* contradictory subterm store */
                                    next
                                      case case_2
                                      by contradiction /* from formulas */
                                    qed
                                  next
                                    case case_2
                                    solve( (#vr.3 = #vr.10)  ∥ (#vr.10 < #vr.3) )
                                      case case_1
