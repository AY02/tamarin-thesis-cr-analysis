                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma clone_detection_soundness:
  all-traces
  "∀ p v #i2.
    (Detect( v, p ) @ #i2) ⇒
    (∃ #i1. (Reveal( p, v ) @ #i1) ∧ (#i1 < #i2))"
/*
guarded formula characterizing all counter-examples:
"∃ p v #i2.
  (Detect( v, p ) @ #i2)
 ∧
  ∀ #i1. (Reveal( p, v ) @ #i1) ⇒ ¬(#i1 < #i2)"
*/
simplify
solve( !Binding( ~idP, ~idV, ltkPV, pk(x), $P, $V )[+] ▶₂ #i2 )
  case Register
  solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i2 )
    case Register
    solve( St_V( ~idV, $V, $P, %n_v, 'verify_state', ch ) ▶₁ #i2 )
      case V_challenge_case_1
      solve( !KU( ~ch ) @ #vk.7 )
        case P_response
        solve( !KU( sign(<%1, ~ch>, ~ltkPV) ) @ #vk.8 )
          case c_sign
          solve( !KU( ~ltkPV ) @ #vk.9 )
            case Reveal_ltk
            by contradiction /* from formulas */
          qed
        qed
      qed
    next
      case V_challenge_case_2
      solve( !KU( ~ch ) @ #vk.9 )
        case P_response
        solve( (%n_p ⊏ %n_v)  ∥ (%n_v = %n_p) )
          case case_1
          solve( !KU( sign(<%n_p, ~ch>, ~ltkPV) ) @ #vk.10 )
            case P_response
            solve( !KU( sign(<%n_v, ch.1>, ~ltkPV) ) @ #vk.15 )
              case P_response_case_1
              by contradiction /* cyclic */
            next
              case P_response_case_2
              by contradiction /* cyclic */
            next
              case c_sign
              solve( !KU( ~ltkPV ) @ #vk.16 )
                case Reveal_ltk
                by contradiction /* from formulas */
              qed
            qed
          next
            case c_sign
            solve( !KU( ~ltkPV ) @ #vk.16 )
              case Reveal_ltk
              by contradiction /* from formulas */
            qed
          qed
        next
          case case_2
          solve( !KU( sign(<%n_p, ~ch>, ~ltkPV) ) @ #vk.11 )
            case P_response
            solve( !KU( sign(<(%n_p%+%1), ch.1>, ~ltkPV) ) @ #vk.14 )
              case P_response
              by contradiction /* cyclic */
            next
              case c_sign
              solve( !KU( ~ltkPV ) @ #vk.15 )
                case Reveal_ltk
                by contradiction /* from formulas */
              qed
            qed
          next
            case c_sign
            solve( !KU( ~ltkPV ) @ #vk.15 )
              case Reveal_ltk
              by contradiction /* from formulas */
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma clone_detection_completeness:
  all-traces
  "∀ p v #i1.
    (Reveal( p, v ) @ #i1) ⇒
    (∃ #i2. (Detect( v, p ) @ #i2) ∧ (#i1 < #i2))"
/*
guarded formula characterizing all counter-examples:
"∃ p v #i1.
  (Reveal( p, v ) @ #i1)
 ∧
  ∀ #i2. (Detect( v, p ) @ #i2) ⇒ ¬(#i1 < #i2)"
*/
simplify
solve( !Ltk( $P, $V, ltkPV )[+] ▶₀ #i1 )
  case Register
  SOLVED // trace found
qed

lemma clone_detection_in_compromised_previous_session_weak:
  all-traces
  "∀ p v %n_p1 ch1 %n_p2 ch2 #i2 #i3 #i4.
    (((((Verify( v, p, <%n_p1, ch1> ) @ #i2) ∧
        (Response( p, v, <%n_p2, ch2> ) @ #i3)) ∧
       (Verify( v, p, <%n_p2, ch2> ) @ #i4)) ∧
      (#i2 < #i3)) ∧
     (#i3 < #i4)) ⇒
    ((∃ %n_p #i1.
       (Response( p, v, <%n_p, ch1> ) @ #i1) ∧ (#i1 < #i2)) ∨
     (∃ #i. Detect( v, p ) @ #i))"
/*
guarded formula characterizing all counter-examples:
"∃ p v %n_p1 ch1 %n_p2 ch2 #i2 #i3 #i4.
  (Verify( v, p, <%n_p1, ch1> ) @ #i2) ∧
  (Response( p, v, <%n_p2, ch2> ) @ #i3) ∧
  (Verify( v, p, <%n_p2, ch2> ) @ #i4)
 ∧
  (#i2 < #i3) ∧
  (#i3 < #i4) ∧
  (∀ %n_p #i1.
    (Response( p, v, <%n_p, ch1> ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i. (Detect( v, p ) @ #i) ⇒ ⊥)"
*/
simplify
solve( !Binding( ~idP, ~idV, ltkPV, pkPV, $P, $V )[+] ▶₂ #i3 )
  case Register
  solve( !Ltk( $P, $V, ~ltkPV )[+] ▶₃ #i3 )
    case Register
    solve( Verify( $V, $P, <%n_p1, ch1> ) @ #i2 )
      case V_detect
      by contradiction /* from formulas */
    next
      case V_verify
      solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x), $P, $V )[+] ▶₂ #i2 )
        case Register
        solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i2 )
          case Register
          solve( Verify( $V, $P, <(%n_p%+%1), ch2> ) @ #i4 )
            case V_detect
            by contradiction /* from formulas */
          next
            case V_verify
            solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x), $P, $V )[+] ▶₂ #i4 )
              case Register
              solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i4 )
                case Register
                solve( SecRecv( $V, $P, ch2 ) ▶₀ #i3 )
                  case secure_channel_receive_case_1
                  solve( St_P( ~idP, $P, $V, %n_p ) ▶₁ #i3 )
                    case P_response
                    solve( (¬(#i2 < #vr.7))  ∥ (%n_p1 ⊏ %n_v.2) )
                      case case_1
                      solve( (¬(#vr.7 < #i2))  ∥ (%n_v.2 ⊏ %n_p1) )
                        case case_1
                        solve( (#i2 = #vr.7)  ∥ (#vr.7 < #i2) )
