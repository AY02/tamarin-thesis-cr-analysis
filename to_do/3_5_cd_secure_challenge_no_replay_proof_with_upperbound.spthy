                  case V_challenge_case_1
                  solve( !KU( ~ch ) @ #vk.10 )
                    case P_response
                    solve( !KU( sign(<%n_p, ~ch>, ~ltkPV) ) @ #vk.11 )
                      case P_response
                      solve( St_V( ~idV.1, $V.1, $P.1, %n_v, 'verify_state', ~ch
                             ) ▶₁ #j )
