                              case V_detect
                              solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                case Register
                                solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                  case Register
                                  simplify
