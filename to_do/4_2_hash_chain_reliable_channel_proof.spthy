                                qed
                              qed
                            next
                              case V_verify
                              solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                case Register
                                solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                  case Register
                                  simplify
                                  solve( Verify( $V, $P, ~ch.2, h_v1 ) @ #i2.3 )
                                    case V_detect
                                    solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.3 )
                                      case Register
                                      solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.3 )
                                        case Register
                                        by contradiction
                                           /* non-injective facts (#vr.11,#i2.3,#i2.1) */
                                      qed
                                    qed
                                  next
                                    case V_verify
                                    solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.3 )
                                      case Register
                                      solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.3 )
                                        case Register
                                        solve( (¬(#i2.1 < #i2.2))  ∥ ((%1%+%1) ⊏ (%n_v%+%1)) )
                                          case case_1
                                          solve( (#i2.2 = #i2.1)  ∥ (#i2.1 < #i2.2) )
                                            case case_1
                                            by contradiction /* cyclic */
                                          next
                                            case case_2
                                            by contradiction /* cyclic */
                                          qed
                                        next
                                          case case_2
                                          solve( (#i2.2 = #i2.1)  ∥ (#i2.1 < #i2.2) )
                                            case case_1
                                            by contradiction /* cyclic */
                                          next
                                            case case_2
                                            by contradiction /* cyclic */
                                          qed
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      next
                        case V_challenge_case_2
                        solve( St_P( ~idP, $P, $V, h_p, %n_p ) ▶₁ #vr.1 )
                          case P_response
                          solve( (¬(#vr.6 < #vr.13))  ∥
                                 (∃ h_v1 #i2.
                                   (Verify( $V, $P, ~ch.2, h_v1 ) @ #i2)
                                  ∧
                                   (#vr.6 < #i2) ∧ (#i2 < #vr.13)) )
                            case case_1
                            solve( (¬(#vr.13 < #vr.6))  ∥
                                   (∃ h_v1 #i2.
                                     (Verify( $V, $P, ch.1, h_v1 ) @ #i2)
                                    ∧
                                     (#vr.13 < #i2) ∧ (#i2 < #vr.6)) )
                              case case_1
                              solve( (¬(#vr.6 < #vr.13))  ∥ ((%n_p.1%+%1) ⊏ (%n_p%+%1)) )
                                case case_1
                                solve( Verify( $V, $P, ch.1, h_v1 ) @ #i2.2 )
                                  case V_detect
                                  solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                    case Register
                                    solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                      case Register
                                      simplify
                                      simplify
                                      by contradiction
                                         /* non-injective facts (#vr.13,#vr.6,#vr.1) */
                                    qed
                                  qed
                                next
                                  case V_verify
                                  solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                    case Register
                                    solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                      case Register
                                      simplify
                                      solve( (#vr.13 = #vr.6)  ∥ (#vr.6 < #vr.13) )
                                        case case_1
