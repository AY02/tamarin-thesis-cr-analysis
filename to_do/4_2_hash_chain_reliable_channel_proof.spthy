theory 4_2_hash_chain_reliable_channel

begin

// Function signature and definition of the equational theory E

builtins: natural-numbers
functions: fst/1, h/1, pair/2, pk/1, sign/2, snd/1, true/0,
           verify/3
equations:
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    verify(sign(x.1, x.2), x.1, pk(x.2)) = true

heuristic: I

/* looping facts with injective instances: St_P/5, St_V/7 */

restriction Equality:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

  /*
  expanded formula:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  */

restriction Inequality:
  "∀ x #i. (Neq( x, x ) @ #i) ⇒ (⊥)"
  // safety formula

  /*
  expanded formula:
  "∀ x #i. (Neq( x, x ) @ #i) ⇒ (⊥)"
  */

restriction LessThan:
  "∀ %x %y #i. (LessThan( %x, %y ) @ #i) ⇒ (%x ⊏ %y)"
  // safety formula

  /*
  expanded formula:
  "∀ %x %y #i. (LessThan( %x, %y ) @ #i) ⇒ (%x ⊏ %y)"
  */

restriction RegisterOnce:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( p, v ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( p, v ) @ #j)) ⇒ (#i = #j)"
  */

restriction NoReversedRoles:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( v, p ) @ #j)) ⇒ (⊥)"
  // safety formula

  /*
  expanded formula:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( v, p ) @ #j)) ⇒ (⊥)"
  */

restriction RevealOnce:
  "∀ p v #i #j.
    ((Reveal( p, v ) @ #i) ∧ (Reveal( p, v ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ p v #i #j.
    ((Reveal( p, v ) @ #i) ∧ (Reveal( p, v ) @ #j)) ⇒ (#i = #j)"
  */

restriction ResponseVerify:
  "∀ p v h_p1 h_p2 ch1 ch2 #i1 #i3.
    (((Response( p, v, ch1, h_p1 ) @ #i1) ∧
      (Response( p, v, ch2, h_p2 ) @ #i3)) ∧
     (#i1 < #i3)) ⇒
    (∃ h_v1 #i2.
      ((Verify( v, p, ch1, h_v1 ) @ #i2) ∧ (#i1 < #i2)) ∧ (#i2 < #i3))"

  /*
  expanded formula:
  "∀ p v h_p1 h_p2 ch1 ch2 #i1 #i3.
    (((Response( p, v, ch1, h_p1 ) @ #i1) ∧
      (Response( p, v, ch2, h_p2 ) @ #i3)) ∧
     (#i1 < #i3)) ⇒
    (∃ h_v1 #i2.
      ((Verify( v, p, ch1, h_v1 ) @ #i2) ∧ (#i1 < #i2)) ∧ (#i2 < #i3))"
  */

restriction UpperboundResponse4:
  "∀ p v ch1 h1 #i1 ch2 h2 #i2 ch3 h3 #i3 ch4 h4 #i4 ch5 h5 #i5.
    (((((Response( p, v, ch1, h1 ) @ #i1) ∧
        (Response( p, v, ch2, h2 ) @ #i2)) ∧
       (Response( p, v, ch3, h3 ) @ #i3)) ∧
      (Response( p, v, ch4, h4 ) @ #i4)) ∧
     (Response( p, v, ch5, h5 ) @ #i5)) ⇒
    ((((((((((#i1 = #i2) ∨ (#i1 = #i3)) ∨ (#i1 = #i4)) ∨ (#i1 = #i5)) ∨
          (#i2 = #i3)) ∨
         (#i2 = #i4)) ∨
        (#i2 = #i5)) ∨
       (#i3 = #i4)) ∨
      (#i3 = #i5)) ∨
     (#i4 = #i5))"
  // safety formula

  /*
  expanded formula:
  "∀ p v ch1 h1 #i1 ch2 h2 #i2 ch3 h3 #i3 ch4 h4 #i4 ch5 h5 #i5.
    (((((Response( p, v, ch1, h1 ) @ #i1) ∧
        (Response( p, v, ch2, h2 ) @ #i2)) ∧
       (Response( p, v, ch3, h3 ) @ #i3)) ∧
      (Response( p, v, ch4, h4 ) @ #i4)) ∧
     (Response( p, v, ch5, h5 ) @ #i5)) ⇒
    ((((((((((#i1 = #i2) ∨ (#i1 = #i3)) ∨ (#i1 = #i4)) ∨ (#i1 = #i5)) ∨
          (#i2 = #i3)) ∨
         (#i2 = #i4)) ∨
        (#i2 = #i5)) ∨
       (#i3 = #i4)) ∨
      (#i3 = #i5)) ∨
     (#i4 = #i5))"
  */

restriction UpperboundVerify4:
  "∀ v p ch1 h1 #i1 ch2 h2 #i2 ch3 h3 #i3 ch4 h4 #i4 ch5 h5 #i5.
    (((((Verify( v, p, ch1, h1 ) @ #i1) ∧
        (Verify( v, p, ch2, h2 ) @ #i2)) ∧
       (Verify( v, p, ch3, h3 ) @ #i3)) ∧
      (Verify( v, p, ch4, h4 ) @ #i4)) ∧
     (Verify( v, p, ch5, h5 ) @ #i5)) ⇒
    ((((((((((#i1 = #i2) ∨ (#i1 = #i3)) ∨ (#i1 = #i4)) ∨ (#i1 = #i5)) ∨
          (#i2 = #i3)) ∨
         (#i2 = #i4)) ∨
        (#i2 = #i5)) ∨
       (#i3 = #i4)) ∨
      (#i3 = #i5)) ∨
     (#i4 = #i5))"
  // safety formula

  /*
  expanded formula:
  "∀ v p ch1 h1 #i1 ch2 h2 #i2 ch3 h3 #i3 ch4 h4 #i4 ch5 h5 #i5.
    (((((Verify( v, p, ch1, h1 ) @ #i1) ∧
        (Verify( v, p, ch2, h2 ) @ #i2)) ∧
       (Verify( v, p, ch3, h3 ) @ #i3)) ∧
      (Verify( v, p, ch4, h4 ) @ #i4)) ∧
     (Verify( v, p, ch5, h5 ) @ #i5)) ⇒
    ((((((((((#i1 = #i2) ∨ (#i1 = #i3)) ∨ (#i1 = #i4)) ∨ (#i1 = #i5)) ∨
          (#i2 = #i3)) ∨
         (#i2 = #i4)) ∨
        (#i2 = #i5)) ∨
       (#i3 = #i4)) ∨
      (#i3 = #i5)) ∨
     (#i4 = #i5))"
  */

rule (modulo E) Register:
   [ Fr( ~ltkPV ), Fr( ~idP ), Fr( ~idV ), Fr( ~inj_n ) ]
  --[ Register( $P, $V ), InitHashP( ~idP ), InitHashV( ~idV ) ]->
   [
   !Ltk( $P, $V, ~ltkPV ), !Pk( $V, $P, pk(~ltkPV) ),
   !Binding( ~idP, ~idV, ~ltkPV, pk(~ltkPV) ),
   St_P( ~idP, $P, $V, h('seed'), %1 ),
   St_V( ~idV, $V, $P, h('seed'), %1, ~inj_n, 'challenge_state' ),
   Out( pk(~ltkPV) )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) V_challenge:
   [
   St_V( ~idV, $V, $P, h_v, %n_v, ~inj_n, 'challenge_state' ),
   !Binding( ~idP, ~idV, ltkPV, pkPV )[+], !Pk( $V, $P, pkPV )[+],
   Fr( ~ch )
   ]
  --[ Challenge( $V, $P, ~ch, h_v ), Injectivity( ~idV, ~inj_n, ~ch )
  ]->
   [
   St_V( ~idV, $V, $P, h_v, %n_v, ~ch, 'verify_state' ),
   Out( <$V, $P, ~ch> )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) P_response:
   [
   In( <$V, $P, ch> ), St_P( ~idP, $P, $V, h_p, %n_p ),
   !Binding( ~idP, ~idV, ltkPV, pkPV )[+], !Ltk( $P, $V, ltkPV )[+]
   ]
  --[
  Response( $P, $V, ch, h(<ch, h_p>) ),
  HashP( ~idP, h(<ch, h_p>), (%n_p%+%1) )
  ]->
   [
   St_P( ~idP, $P, $V, h(<ch, h_p>), (%n_p%+%1) ),
   Out( <$P, $V, ch, h(<ch, h_p>), sign(<ch, h(<ch, h_p>)>, ltkPV)> )
   ]

  // loop breaker: [1]
  /* has exactly the trivial AC variant */

rule (modulo E) V_verify:
   [
   In( <$P, $V, ch, h_p, sig> ),
   St_V( ~idV, $V, $P, h_v, %n_v, ch, 'verify_state' ),
   !Binding( ~idP, ~idV, ltkPV, pkPV )[+], !Pk( $V, $P, pkPV )[+],
   Fr( ~inj_n )
   ]
  --[
  Verify( $V, $P, ch, h_p ),
  Eq( verify(sig, <ch, h_p>, pkPV), true ), Eq( h(<ch, h_v>), h_p ),
  Accept( $V, $P ), HashV( ~idV, h_p, (%n_v%+%1) ),
  Injectivity( ~idV, ch, ~inj_n )
  ]->
   [ St_V( ~idV, $V, $P, h_p, (%n_v%+%1), ~inj_n, 'challenge_state' )
   ]

  // loop breaker: [1]
  /*
  rule (modulo AC) V_verify:
     [
     In( <$P, $V, ch, h_p, sig> ),
     St_V( ~idV, $V, $P, h_v, %n_v, ch, 'verify_state' ),
     !Binding( ~idP, ~idV, ltkPV, pkPV )[+], !Pk( $V, $P, pkPV )[+],
     Fr( ~inj_n )
     ]
    --[
    Verify( $V, $P, ch, h_p ), Eq( z, true ), Eq( h(<ch, h_v>), h_p ),
    Accept( $V, $P ), HashV( ~idV, h_p, (%n_v%+%1) ),
    Injectivity( ~idV, ch, ~inj_n )
    ]->
     [ St_V( ~idV, $V, $P, h_p, (%n_v%+%1), ~inj_n, 'challenge_state' )
     ]
    variants (modulo AC)
    1. ch    = ch.22
       h_p   = h_p.23
       pkPV  = pkPV.26
       sig   = sig.27
       z     = verify(sig.27, <ch.22, h_p.23>, pkPV.26)
    
    2. ch    = ch.31
       h_p   = h_p.32
       pkPV  = pk(x.55)
       sig   = sign(<ch.31, h_p.32>, x.55)
       z     = true
    // loop breaker: [1]
  */

rule (modulo E) V_detect:
   [
   In( <$P, $V, ch, h_p, sig> ),
   St_V( ~idV, $V, $P, h_v, %n_v, ch, 'verify_state' ),
   !Binding( ~idP, ~idV, ltkPV, pkPV )[+], !Pk( $V, $P, pkPV )[+]
   ]
  --[
  Verify( $V, $P, ch, h_p ),
  Eq( verify(sig, <ch, h_p>, pkPV), true ), Neq( h(<ch, h_v>), h_p ),
  Detect( $V, $P )
  ]->
   [ ]

  /*
  rule (modulo AC) V_detect:
     [
     In( <$P, $V, ch, h_p, sig> ),
     St_V( ~idV, $V, $P, h_v, %n_v, ch, 'verify_state' ),
     !Binding( ~idP, ~idV, ltkPV, pkPV )[+], !Pk( $V, $P, pkPV )[+]
     ]
    --[
    Verify( $V, $P, ch, h_p ), Eq( z, true ), Neq( h(<ch, h_v>), h_p ),
    Detect( $V, $P )
    ]->
     [ ]
    variants (modulo AC)
    1. ch    = ch.15
       h_p   = h_p.16
       pkPV  = pkPV.19
       sig   = sig.20
       z     = verify(sig.20, <ch.15, h_p.16>, pkPV.19)
    
    2. ch    = ch.19
       h_p   = h_p.20
       pkPV  = pk(x.32)
       sig   = sign(<ch.19, h_p.20>, x.32)
       z     = true
  */

rule (modulo E) Reveal_ltk:
   [ !Ltk( $P, $V, ltkPV )[+] ]
  --[ Reveal( $P, $V ) ]->
   [ Out( ltkPV ) ]

  /* has exactly the trivial AC variant */

lemma hash_init [reuse, use_induction]:
  all-traces
  "(∀ idP h_p %n_p #i2.
     (HashP( idP, h_p, %n_p ) @ #i2) ⇒
     (∃ #i1. (InitHashP( idP ) @ #i1) ∧ (#i1 < #i2))) ∧
   (∀ idV h_v %n_v #i2.
     (HashV( idV, h_v, %n_v ) @ #i2) ⇒
     (∃ #i1. (InitHashV( idV ) @ #i1) ∧ (#i1 < #i2)))"
/*
guarded formula characterizing all counter-examples:
"((∃ idP h_p %n_p #i2.
    (HashP( idP, h_p, %n_p ) @ #i2)
   ∧
    ∀ #i1. (InitHashP( idP ) @ #i1) ⇒ ¬(#i1 < #i2)) ∨
  (∃ idV h_v %n_v #i2.
    (HashV( idV, h_v, %n_v ) @ #i2)
   ∧
    ∀ #i1. (InitHashV( idV ) @ #i1) ⇒ ¬(#i1 < #i2)))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (∃ idP h_p %n_p #i2.
           (HashP( idP, h_p, %n_p ) @ #i2)
          ∧
           ∀ #i1. (InitHashP( idP ) @ #i1) ⇒ ¬(#i1 < #i2))  ∥
         (∃ idV h_v %n_v #i2.
           (HashV( idV, h_v, %n_v ) @ #i2)
          ∧
           ∀ #i1. (InitHashV( idV ) @ #i1) ⇒ ¬(#i1 < #i2)) )
    case case_1
    solve( !Binding( ~idP, ~idV, ltkPV, pkPV )[+] ▶₂ #i2 )
      case Register
      by contradiction /* from formulas */
    qed
  next
    case case_2
    solve( !Binding( ~idP, ~idV, ltkPV, pk(x) )[+] ▶₂ #i2 )
      case Register
      by contradiction /* from formulas */
    qed
  qed
qed

lemma hash_init_unique [reuse, use_induction]:
  all-traces
  "(∀ idP #i #j.
     ((InitHashP( idP ) @ #i) ∧ (InitHashP( idP ) @ #j)) ⇒ (#i = #j)) ∧
   (∀ idV #i #j.
     ((InitHashV( idV ) @ #i) ∧ (InitHashV( idV ) @ #j)) ⇒ (#i = #j))"
/*
guarded formula characterizing all counter-examples:
"((∃ idP #i #j.
    (InitHashP( idP ) @ #i) ∧ (InitHashP( idP ) @ #j) ∧ ¬(#i = #j)) ∨
  (∃ idV #i #j.
    (InitHashV( idV ) @ #i) ∧ (InitHashV( idV ) @ #j) ∧ ¬(#i = #j)))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (∃ idP #i #j.
           (InitHashP( idP ) @ #i) ∧ (InitHashP( idP ) @ #j) ∧ ¬(#i = #j))  ∥
         (∃ idV #i #j.
           (InitHashV( idV ) @ #i) ∧ (InitHashV( idV ) @ #j) ∧ ¬(#i = #j)) )
    case case_1
    by contradiction /* from formulas */
  next
    case case_2
    by contradiction /* from formulas */
  qed
qed

lemma hash_monotony [reuse, use_induction]:
  all-traces
  "(∀ idP h_p1 h_p2 %n_p1 %n_p2 #i1 #i2.
     (((HashP( idP, h_p1, %n_p1 ) @ #i1) ∧
       (HashP( idP, h_p2, %n_p2 ) @ #i2)) ∧
      (#i1 < #i2)) ⇒
     (%n_p1 ⊏ %n_p2)) ∧
   (∀ idV h_v1 h_v2 %n_v1 %n_v2 #i1 #i2.
     (((HashV( idV, h_v1, %n_v1 ) @ #i1) ∧
       (HashV( idV, h_v2, %n_v2 ) @ #i2)) ∧
      (#i1 < #i2)) ⇒
     (%n_v1 ⊏ %n_v2))"
/*
guarded formula characterizing all counter-examples:
"((∃ idP h_p1 h_p2 %n_p1 %n_p2 #i1 #i2.
    (HashP( idP, h_p1, %n_p1 ) @ #i1) ∧
    (HashP( idP, h_p2, %n_p2 ) @ #i2)
   ∧
    (#i1 < #i2) ∧ (¬(%n_p1 ⊏ %n_p2))) ∨
  (∃ idV h_v1 h_v2 %n_v1 %n_v2 #i1 #i2.
    (HashV( idV, h_v1, %n_v1 ) @ #i1) ∧
    (HashV( idV, h_v2, %n_v2 ) @ #i2)
   ∧
    (#i1 < #i2) ∧ (¬(%n_v1 ⊏ %n_v2))))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (∃ idP h_p1 h_p2 %n_p1 %n_p2 #i1 #i2.
           (HashP( idP, h_p1, %n_p1 ) @ #i1) ∧
           (HashP( idP, h_p2, %n_p2 ) @ #i2)
          ∧
           (#i1 < #i2) ∧ (¬(%n_p1 ⊏ %n_p2)))  ∥
         (∃ idV h_v1 h_v2 %n_v1 %n_v2 #i1 #i2.
           (HashV( idV, h_v1, %n_v1 ) @ #i1) ∧
           (HashV( idV, h_v2, %n_v2 ) @ #i2)
          ∧
           (#i1 < #i2) ∧ (¬(%n_v1 ⊏ %n_v2))) )
    case case_1
    by contradiction /* cyclic */
  next
    case case_2
    simplify
    solve( !Binding( ~idP, ~idV, ltkPV, pk(x) )[+] ▶₂ #i1 )
      case Register
      solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i1 )
        case Register
        solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x) )[+] ▶₂ #i2 )
          case Register
          solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i2 )
            case Register
            solve( ((∀ idP h_p1 h_p2 %n_p1 %n_p2 #i1 #i2.
                      (HashP( idP, h_p1, %n_p1 ) @ #i1) ∧
                      (HashP( idP, h_p2, %n_p2 ) @ #i2)
                     ⇒
                      ((last(#i2)) ∨
                       (last(#i1)) ∨
                       (#i1 = #i2) ∨
                       (#i2 < #i1) ∨
                       (%n_p1 ⊏ %n_p2))) ∧
                    (∀ idV h_v1 h_v2 %n_v1 %n_v2 #i1 #i2.
                      (HashV( idV, h_v1, %n_v1 ) @ #i1) ∧
                      (HashV( idV, h_v2, %n_v2 ) @ #i2)
                     ⇒
                      ((last(#i2)) ∨
                       (last(#i1)) ∨
                       (#i1 = #i2) ∨
                       (#i2 < #i1) ∨
                       (%n_v1 ⊏ %n_v2))))  ∥
                   (∃ p v h_p1 h_p2 ch1 ch2 #i1 #i3.
                     (Response( p, v, ch1, h_p1 ) @ #i1) ∧
                     (Response( p, v, ch2, h_p2 ) @ #i3)
                    ∧
                     (¬(last(#i3))) ∧
                     (¬(last(#i1))) ∧
                     (#i1 < #i3) ∧
                     (∀ h_v1 #i2.
                       (Verify( v, p, ch1, h_v1 ) @ #i2)
                      ⇒
                       ((last(#i2)) ∨
                        (#i1 = #i2) ∨
                        (#i2 < #i1) ∨
                        (#i2 = #i3) ∨
                        (#i3 < #i2)))) )
              case case_1
              solve( St_V( ~idV, $V, $P, h_v, %n_v, ch, 'verify_state' ) ▶₁ #i1 )
                case V_challenge_case_1
                solve( St_V( ~idV, $V, $P, h_v, %1, ch.1, 'verify_state' ) ▶₁ #i2 )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case V_challenge_case_2
                simplify
                solve( St_V( ~idV, $V, $P, h_v.1, %n_v.1, ch.2, 'verify_state'
                       ) ▶₁ #i2 )
                  case V_challenge_case_1
                  by contradiction /* cyclic */
                next
                  case V_challenge_case_2
                  by contradiction /* non-injective facts (#vr.3,#i1,#vr.2) */
                qed
              qed
            next
              case case_2
              by contradiction /* from formulas */
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma hash_chain_unique [reuse, use_induction]:
  all-traces
  "(∀ idP h_p %n_p #i #j.
     ((HashP( idP, h_p, %n_p ) @ #i) ∧ (HashP( idP, h_p, %n_p ) @ #j)) ⇒
     (#i = #j)) ∧
   (∀ idV h_v %n_v #i #j.
     ((HashV( idV, h_v, %n_v ) @ #i) ∧ (HashV( idV, h_v, %n_v ) @ #j)) ⇒
     (#i = #j))"
/*
guarded formula characterizing all counter-examples:
"((∃ idP h_p %n_p #i #j.
    (HashP( idP, h_p, %n_p ) @ #i) ∧ (HashP( idP, h_p, %n_p ) @ #j)
   ∧
    ¬(#i = #j)) ∨
  (∃ idV h_v %n_v #i #j.
    (HashV( idV, h_v, %n_v ) @ #i) ∧ (HashV( idV, h_v, %n_v ) @ #j)
   ∧
    ¬(#i = #j)))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (∃ idP h_p %n_p #i #j.
           (HashP( idP, h_p, %n_p ) @ #i) ∧ (HashP( idP, h_p, %n_p ) @ #j)
          ∧
           ¬(#i = #j))  ∥
         (∃ idV h_v %n_v #i #j.
           (HashV( idV, h_v, %n_v ) @ #i) ∧ (HashV( idV, h_v, %n_v ) @ #j)
          ∧
           ¬(#i = #j)) )
    case case_1
    by contradiction /* from formulas */
  next
    case case_2
    solve( !Binding( ~idP, ~idV, ltkPV, pk(x) )[+] ▶₂ #i )
      case Register
      solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i )
        case Register
        solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x) )[+] ▶₂ #j )
          case Register
          solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #j )
            case Register
            solve( ((∀ idP h_p %n_p #i #j.
                      (HashP( idP, h_p, %n_p ) @ #i) ∧ (HashP( idP, h_p, %n_p ) @ #j)
                     ⇒
                      ((last(#j)) ∨ (last(#i)) ∨ (#i = #j))) ∧
                    (∀ idV h_v %n_v #i #j.
                      (HashV( idV, h_v, %n_v ) @ #i) ∧ (HashV( idV, h_v, %n_v ) @ #j)
                     ⇒
                      ((last(#j)) ∨ (last(#i)) ∨ (#i = #j))))  ∥
                   (∃ p v h_p1 h_p2 ch1 ch2 #i1 #i3.
                     (Response( p, v, ch1, h_p1 ) @ #i1) ∧
                     (Response( p, v, ch2, h_p2 ) @ #i3)
                    ∧
                     (¬(last(#i3))) ∧
                     (¬(last(#i1))) ∧
                     (#i1 < #i3) ∧
                     (∀ h_v1 #i2.
                       (Verify( v, p, ch1, h_v1 ) @ #i2)
                      ⇒
                       ((last(#i2)) ∨
                        (#i1 = #i2) ∨
                        (#i2 < #i1) ∨
                        (#i2 = #i3) ∨
                        (#i3 < #i2)))) )
              case case_1
              solve( (#i < #j)  ∥ (#j < #i) )
                case case_1
                by contradiction /* from formulas */
              next
                case case_2
                by contradiction /* from formulas */
              qed
            next
              case case_2
              by contradiction /* from formulas */
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma verifier_injectivity [reuse]:
  all-traces
  "∀ idV inj_n1 ch inj_n2 n1 n2 #i1 #i2 #i3.
    ((((Injectivity( idV, inj_n1, ch ) @ #i1) ∧
       (Injectivity( idV, ch, inj_n2 ) @ #i3)) ∧
      (Injectivity( idV, n1, n2 ) @ #i2)) ∧
     (#i2 < #i3)) ⇒
    (¬(#i1 < #i2))"
/*
guarded formula characterizing all counter-examples:
"∃ idV inj_n1 ch inj_n2 n1 n2 #i1 #i2 #i3.
  (Injectivity( idV, inj_n1, ch ) @ #i1) ∧
  (Injectivity( idV, ch, inj_n2 ) @ #i3) ∧
  (Injectivity( idV, n1, n2 ) @ #i2)
 ∧
  (#i2 < #i3) ∧ (#i1 < #i2)"
*/
simplify
solve( Injectivity( idV, inj_n1, ch ) @ #i1 )
  case V_challenge
  solve( !Binding( ~idP, ~idV, ltkPV, pkPV )[+] ▶₁ #i1 )
    case Register
    solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₂ #i1 )
      case Register
      solve( Injectivity( ~idV, ~ch, inj_n2 ) @ #i3 )
        case V_challenge
        solve( !Binding( ~idP.1, ~idV, ltkPV.1, pkPV )[+] ▶₁ #i3 )
          case Register
          solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₂ #i3 )
            case Register
            solve( Injectivity( ~idV, n1, n2 ) @ #i2 )
              case V_challenge
              solve( !Binding( ~idP.1, ~idV, ltkPV.1, pkPV )[+] ▶₁ #i2 )
                case Register
                solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₂ #i2 )
                  case Register
                  solve( St_V( ~idV, $V, $P, h_v, %n_v, ~inj_n, 'challenge_state'
                         ) ▶₀ #i1 )
                    case Register
                    by solve( St_V( ~idV, $V, $P, h_v.1, %n_v.1, ~ch, 'challenge_state'
                              ) ▶₀ #i3 )
                  next
                    case V_verify
                    by solve( St_V( ~idV, $V, $P, h_v.2, %n_v.2, ~ch.1,
                                    'challenge_state'
                              ) ▶₀ #i3 )
                  qed
                qed
              qed
            next
              case V_verify
              solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x) )[+] ▶₂ #i2 )
                case Register
                solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i2 )
                  case Register
                  solve( St_V( ~idV, $V, $P, h_v, %n_v, ~inj_n, 'challenge_state'
                         ) ▶₀ #i1 )
                    case Register
                    by solve( St_V( ~idV, $V, $P, h_v.1, %n_v.1, ~ch, 'challenge_state'
                              ) ▶₀ #i3 )
                  next
                    case V_verify
                    by solve( St_V( ~idV, $V, $P, h_v.2, %n_v.2, ~ch.1,
                                    'challenge_state'
                              ) ▶₀ #i3 )
                  qed
                qed
              qed
            qed
          qed
        qed
      next
        case V_verify
        solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x) )[+] ▶₂ #i3 )
          case Register
          solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i3 )
            case Register
            solve( Injectivity( ~idV, n1, n2 ) @ #i2 )
              case V_challenge
              solve( !Binding( ~idP.1, ~idV, ltkPV.1, pkPV )[+] ▶₁ #i2 )
                case Register
                solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₂ #i2 )
                  case Register
                  solve( St_V( ~idV, $V, $P, h_v, %n_v, ~inj_n, 'challenge_state'
                         ) ▶₀ #i1 )
                    case Register
                    solve( St_V( ~idV, $V, $P, h_v, %n_v, ~inj_n.1, 'challenge_state'
                           ) ▶₀ #i2 )
                      case Register
                      by contradiction /* cyclic */
                    next
                      case V_verify
                      solve( St_V( ~idV, $V, $P, h_v.1, %n_v.1, ~ch, 'verify_state'
                             ) ▶₁ #i3 )
                        case V_challenge
                        by contradiction /* cyclic */
                      qed
                    qed
                  next
                    case V_verify
                    solve( St_V( ~idV, $V, $P, h_v.1, %n_v.1, ~inj_n.1,
                                 'challenge_state'
                           ) ▶₀ #i2 )
                      case Register
                      by contradiction /* cyclic */
                    next
                      case V_verify
                      simplify
                      solve( St_V( ~idV, $V, $P, h_v.2, %n_v.2, ~ch.1, 'verify_state'
                             ) ▶₁ #i3 )
                        case V_challenge
                        by contradiction /* cyclic */
                      qed
                    qed
                  qed
                qed
              qed
            next
              case V_verify
              solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x) )[+] ▶₂ #i2 )
                case Register
                solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i2 )
                  case Register
                  solve( St_V( ~idV, $V, $P, h_v, %n_v, ~inj_n, 'challenge_state'
                         ) ▶₀ #i1 )
                    case Register
                    solve( St_V( ~idV, $V, $P, h_v.1, %n_v.1, ~ch, 'verify_state'
                           ) ▶₁ #i3 )
                      case V_challenge
                      by contradiction /* cyclic */
                    qed
                  next
                    case V_verify
                    solve( St_V( ~idV, $V, $P, h_v.2, %n_v.2, ~ch.1, 'verify_state'
                           ) ▶₁ #i3 )
                      case V_challenge
                      by contradiction /* cyclic */
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
next
  case V_verify
  solve( !Binding( ~idP, ~idV, ltkPV, pk(x) )[+] ▶₂ #i1 )
    case Register
    solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i1 )
      case Register
      solve( Injectivity( ~idV, ~inj_n, inj_n2 ) @ #i3 )
        case V_challenge
        solve( !Binding( ~idP.1, ~idV, ltkPV.1, pkPV )[+] ▶₁ #i3 )
          case Register
          solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₂ #i3 )
            case Register
            solve( Injectivity( ~idV, n1, n2 ) @ #i2 )
              case V_challenge
              solve( !Binding( ~idP.1, ~idV, ltkPV.1, pkPV )[+] ▶₁ #i2 )
                case Register
                solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₂ #i2 )
                  case Register
                  solve( St_V( ~idV, $V, $P, h_v.2, %n_v.2, ~inj_n, 'challenge_state'
                         ) ▶₀ #i3 )
                    case V_verify
                    by contradiction /* cyclic */
                  qed
                qed
              qed
            next
              case V_verify
              solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x) )[+] ▶₂ #i2 )
                case Register
                solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i2 )
                  case Register
                  solve( St_V( ~idV, $V, $P, h_v.2, %n_v.2, ~inj_n, 'challenge_state'
                         ) ▶₀ #i3 )
                    case V_verify
                    by contradiction /* cyclic */
                  qed
                qed
              qed
            qed
          qed
        qed
      next
        case V_verify
        solve( !Binding( ~idP.1, ~idV, ltkPV.1, pk(x) )[+] ▶₂ #i3 )
          case Register
          solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i3 )
            case Register
            by solve( !KU( ~inj_n ) @ #vk.12 )
          qed
        qed
      qed
    qed
  qed
qed

lemma prover_injective_agreement:
  all-traces
  "∀ p v ch h_p #i2.
    (((Verify( v, p, ch, h_p ) @ #i2) ∧ (Accept( v, p ) @ #i2)) ∧
     (¬(∃ #i. Reveal( p, v ) @ #i))) ⇒
    ((∃ #i1. (Response( p, v, ch, h_p ) @ #i1) ∧ (#i1 < #i2)) ∧
     (¬(∃ p_j v_j #j.
         ((Verify( v_j, p_j, ch, h_p ) @ #j) ∧ (Accept( v_j, p_j ) @ #j)) ∧
         (¬(#j = #i2)))))"
/*
guarded formula characterizing all counter-examples:
"∃ p v ch h_p #i2.
  (Verify( v, p, ch, h_p ) @ #i2) ∧ (Accept( v, p ) @ #i2)
 ∧
  (∀ #i. (Reveal( p, v ) @ #i) ⇒ ⊥) ∧
  (((∀ #i1. (Response( p, v, ch, h_p ) @ #i1) ⇒ ¬(#i1 < #i2)) ∨
    (∃ p_j v_j #j.
      (Verify( v_j, p_j, ch, h_p ) @ #j) ∧ (Accept( v_j, p_j ) @ #j)
     ∧
      ¬(#j = #i2))))"
*/
simplify
solve( !Binding( ~idP, ~idV, ltkPV, pk(x) )[+] ▶₂ #i2 )
  case Register
  solve( !Pk( $V.1, $P.1, pk(~ltkPV) )[+] ▶₃ #i2 )
    case Register
    solve( Verify( $V, $P, ch.1, h_p ) @ #i2 )
      case V_verify
      solve( (∀ #i1.
               (Response( $P, $V, ch, h(<ch, h_v>) ) @ #i1) ⇒ ¬(#i1 < #i2))  ∥
             (∃ p_j v_j #j.
               (Verify( v_j, p_j, ch, h(<ch, h_v>) ) @ #j) ∧
               (Accept( v_j, p_j ) @ #j)
              ∧
               ¬(#j = #i2)) )
        case case_1
        solve( St_V( ~idV, $V, $P, h_v, %n_v, ch, 'verify_state' ) ▶₁ #i2 )
          case V_challenge_case_1
          solve( !KU( sign(<~ch, h(<~ch, h('seed')>)>, ~ltkPV) ) @ #vk.8 )
            case P_response
            by contradiction /* from formulas */
          next
            case c_sign
            solve( !KU( ~ltkPV ) @ #vk.10 )
              case Reveal_ltk
              by contradiction /* from formulas */
            qed
          qed
        next
          case V_challenge_case_2
          solve( !KU( sign(<~ch, h(<~ch, h(<ch.1, h_v>)>)>, ~ltkPV)
                 ) @ #vk.10 )
            case P_response
            by contradiction /* from formulas */
          next
            case c_sign
            solve( !KU( ~ltkPV ) @ #vk.17 )
              case Reveal_ltk
              by contradiction /* from formulas */
            qed
          qed
        qed
      next
        case case_2
        solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #j )
          case Register
          solve( !Pk( $V.1, $P.1, pk(~ltkPV.1) )[+] ▶₃ #j )
            case Register
            solve( Verify( $V.1, $P.1, ch, h(<ch, h_v>) ) @ #j )
              case V_verify
              solve( (#j < #i2)  ∥ (#i2 < #j) )
                case case_1
                solve( St_V( ~idV, $V, $P, h_v, %n_v, ch, 'verify_state' ) ▶₁ #i2 )
                  case V_challenge_case_1
                  solve( !KU( sign(<~ch, h(<~ch, h('seed')>)>, ~ltkPV) ) @ #vk.12 )
                    case P_response
                    solve( St_V( ~idV.1, $V.1, $P.1, h('seed'), %n_v, ~ch,
                                 'verify_state'
                           ) ▶₁ #j )
                      case V_challenge
                      by contradiction /* cyclic */
                    qed
                  next
                    case c_sign
                    solve( !KU( ~ltkPV ) @ #vk.17 )
                      case Reveal_ltk
                      by contradiction /* from formulas */
                    qed
                  qed
                next
                  case V_challenge_case_2
                  solve( !KU( sign(<~ch, h(<~ch, h(<ch.1, h_v>)>)>, ~ltkPV)
                         ) @ #vk.14 )
                    case P_response
                    solve( St_V( ~idV.1, $V.1, $P.1, h(<ch.1, h_v>), %n_v.1, ~ch,
                                 'verify_state'
                           ) ▶₁ #j )
                      case V_challenge
                      by contradiction /* cyclic */
                    qed
                  next
                    case c_sign
                    solve( !KU( ~ltkPV ) @ #vk.24 )
                      case Reveal_ltk
                      by contradiction /* from formulas */
                    qed
                  qed
                qed
              next
                case case_2
                solve( St_V( ~idV, $V, $P, h_v, %n_v, ch, 'verify_state' ) ▶₁ #i2 )
                  case V_challenge_case_1
                  solve( !KU( sign(<~ch, h(<~ch, h('seed')>)>, ~ltkPV) ) @ #vk.12 )
                    case P_response
                    solve( St_V( ~idV.1, $V.1, $P.1, h('seed'), %n_v, ~ch,
                                 'verify_state'
                           ) ▶₁ #j )
                      case V_challenge
                      by contradiction /* cyclic */
                    qed
                  next
                    case c_sign
                    solve( !KU( ~ltkPV ) @ #vk.17 )
                      case Reveal_ltk
                      by contradiction /* from formulas */
                    qed
                  qed
                next
                  case V_challenge_case_2
                  solve( !KU( sign(<~ch, h(<~ch, h(<ch.1, h_v>)>)>, ~ltkPV)
                         ) @ #vk.14 )
                    case P_response
                    solve( St_V( ~idV.1, $V.1, $P.1, h(<ch.1, h_v>), %n_v.1, ~ch,
                                 'verify_state'
                           ) ▶₁ #j )
                      case V_challenge
                      by contradiction /* cyclic */
                    qed
                  next
                    case c_sign
                    solve( !KU( ~ltkPV ) @ #vk.24 )
                      case Reveal_ltk
                      by contradiction /* from formulas */
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma clone_detection_soundness:
  all-traces
  "∀ p v #i2.
    (Detect( v, p ) @ #i2) ⇒
    (∃ #i1. (Reveal( p, v ) @ #i1) ∧ (#i1 < #i2))"
/*
guarded formula characterizing all counter-examples:
"∃ p v #i2.
  (Detect( v, p ) @ #i2)
 ∧
  ∀ #i1. (Reveal( p, v ) @ #i1) ⇒ ¬(#i1 < #i2)"
*/
simplify
solve( !Binding( ~idP, ~idV, ltkPV, pk(x) )[+] ▶₂ #i2 )
  case Register
  solve( !Pk( $V, $P, pk(~ltkPV) )[+] ▶₃ #i2 )
    case Register
    solve( St_V( ~idV, $V, $P, h_v, %n_v, ch, 'verify_state' ) ▶₁ #i2 )
      case V_challenge_case_1
      solve( !KU( sign(<~ch, h_p>, ~ltkPV) ) @ #vk.8 )
        case P_response
        solve( St_P( ~idP, $P, $V, h_p, %n_p ) ▶₁ #vr.2 )
          case P_response
          solve( Verify( $V, $P, ch.1, h_v1 ) @ #i2.1 )
            case V_detect
            solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.1 )
              case Register
              solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.1 )
                case Register
                by contradiction /* non-injective facts (#vr,#i2.1,#vr.1) */
              qed
            qed
          next
            case V_verify
            solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.1 )
              case Register
              solve( !Pk( $V.1, $P.1, pk(~ltkPV) )[+] ▶₃ #i2.1 )
                case Register
                by contradiction /* non-injective facts (#i1,#i2.1,#vr) */
              qed
            qed
          qed
        next
          case Register
          by contradiction /* from formulas */
        qed
      next
        case c_sign
        solve( !KU( ~ltkPV ) @ #vk.10 )
          case Reveal_ltk
          by contradiction /* from formulas */
        qed
      qed
    next
      case V_challenge_case_2
      solve( !KU( sign(<~ch, h_p>, ~ltkPV) ) @ #vk.10 )
        case P_response
        solve( !KU( sign(<ch.1, h(<ch.1, h_v>)>, ~ltkPV) ) @ #vk.17 )
          case P_response
          solve( Verify( $V, $P, ch.1, h_v1 ) @ #i2.1 )
            case V_detect
            solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.1 )
              case Register
              solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.1 )
                case Register
                simplify
                solve( St_V( ~idV, $V, $P, h_v.1, %n_v.1, ch.1, 'verify_state'
                       ) ▶₁ #i2.1 )
                  case V_challenge_case_1
                  by solve( St_V( ~idV, $V, $P, h_v, %n_v, ~ch.1, 'verify_state'
                            ) ▶₁ #vr.2 )
                next
                  case V_challenge_case_2
                  by solve( St_V( ~idV, $V, $P, h_v, %n_v, ~ch.1, 'verify_state'
                            ) ▶₁ #vr.2 )
                qed
              qed
            qed
          next
            case V_verify
            solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.1 )
              case Register
              solve( !Pk( $V.1, $P.1, pk(~ltkPV) )[+] ▶₃ #i2.1 )
                case Register
                simplify
                solve( (¬(#i2.1 < #vr.1))  ∥ ((%n_v.1%+%1) ⊏ (%n_v%+%1)) )
                  case case_1
                  solve( (¬(#vr.1 < #i2.1))  ∥ ((%n_v%+%1) ⊏ (%n_v.1%+%1)) )
                    case case_1
                    solve( (#vr.1 = #i2.1)  ∥ (#i2.1 < #vr.1) )
                      case case_1
                      solve( St_V( ~idV, $V, $P, h_v, %n_v, ch.1, 'verify_state'
                             ) ▶₁ #i2.1 )
                        case V_challenge_case_1
                        solve( St_P( ~idP, $P, $V, h_p, %n_p ) ▶₁ #vr.1 )
                          case P_response
                          solve( (¬(#vr.6 < #vr.12))  ∥
                                 (∃ h_v1 #i2.
                                   (Verify( $V, $P, ~ch.2, h_v1 ) @ #i2)
                                  ∧
                                   (#vr.6 < #i2) ∧ (#i2 < #vr.12)) )
                            case case_1
                            solve( (¬(#vr.12 < #vr.6))  ∥
                                   (∃ h_v1 #i2.
                                     (Verify( $V, $P, ch.1, h_v1 ) @ #i2)
                                    ∧
                                     (#vr.12 < #i2) ∧ (#i2 < #vr.6)) )
                              case case_1
                              solve( (¬(#vr.6 < #vr.12))  ∥ ((%n_p.1%+%1) ⊏ (%n_p%+%1)) )
                                case case_1
                                solve( Verify( $V, $P, ch.1, h_v1 ) @ #i2.2 )
                                  case V_detect
                                  solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                    case Register
                                    solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                      case Register
                                      simplify
                                      simplify
                                      by contradiction /* non-injective facts (#i1,#i2.2,#vr.11) */
                                    qed
                                  qed
                                next
                                  case V_verify
                                  solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                    case Register
                                    solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                      case Register
                                      simplify
                                      solve( (#vr.12 = #vr.6)  ∥ (#vr.6 < #vr.12) )
                                        case case_1
                                        by contradiction /* from formulas */
                                      next
                                        case case_2
                                        by contradiction /* from formulas */
                                      qed
                                    qed
                                  qed
                                qed
                              next
                                case case_2
                                solve( Verify( $V, $P, ch.1, h_v1 ) @ #i2.2 )
                                  case V_detect
                                  solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                    case Register
                                    solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                      case Register
                                      simplify
                                      simplify
                                      by contradiction /* non-injective facts (#i1,#i2.2,#vr.11) */
                                    qed
                                  qed
                                next
                                  case V_verify
                                  solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
