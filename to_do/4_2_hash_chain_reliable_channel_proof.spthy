                qed
              qed
            qed
          qed
        next
          case c_sign
          solve( !KU( ~ltkPV ) @ #vk.19 )
            case Reveal_ltk
            by contradiction /* from formulas */
          qed
        qed
      next
        case c_sign
        solve( !KU( ~ltkPV ) @ #vk.17 )
          case Reveal_ltk
          by contradiction /* from formulas */
        qed
      qed
    qed
  qed
qed

lemma clone_detection_in_compromised_previous_session_weak:
  all-traces
  "∀ p v ch1 h_p1 ch2 h_p2 #i2 #i3 #i4.
    (((((Verify( v, p, ch1, h_p1 ) @ #i2) ∧
        (Response( p, v, ch2, h_p2 ) @ #i3)) ∧
       (Verify( v, p, ch2, h_p2 ) @ #i4)) ∧
      (#i2 < #i3)) ∧
     (#i3 < #i4)) ⇒
    ((∃ h_p #i1. (Response( p, v, ch1, h_p ) @ #i1) ∧ (#i1 < #i2)) ∨
     (∃ #i. Detect( v, p ) @ #i))"
/*
guarded formula characterizing all counter-examples:
"∃ p v ch1 h_p1 ch2 h_p2 #i2 #i3 #i4.
  (Verify( v, p, ch1, h_p1 ) @ #i2) ∧
  (Response( p, v, ch2, h_p2 ) @ #i3) ∧
  (Verify( v, p, ch2, h_p2 ) @ #i4)
 ∧
  (#i2 < #i3) ∧
  (#i3 < #i4) ∧
  (∀ h_p #i1. (Response( p, v, ch1, h_p ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i. (Detect( v, p ) @ #i) ⇒ ⊥)"
*/
simplify
solve( !Binding( ~idP, ~idV, ltkPV, pkPV )[+] ▶₂ #i3 )
  case Register
  solve( !Ltk( $P.1, $V.1, ~ltkPV )[+] ▶₃ #i3 )
    case Register
    solve( Verify( $V, $P, ch1, h_p1 ) @ #i2 )
      case V_detect
      by contradiction /* from formulas */
    next
      case V_verify
      solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2 )
        case Register
        solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2 )
          case Register
          solve( Verify( $V, $P, ch2, h(<ch2, h_p>) ) @ #i4 )
            case V_detect
            by contradiction /* from formulas */
          next
            case V_verify
            solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i4 )
              case Register
              solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i4 )
                case Register
                solve( St_P( ~idP, $P, $V, h_v.1, %n_p ) ▶₁ #i3 )
                  case P_response
                  solve( Verify( $V, $P, ch, h_v1 ) @ #i2.1 )
                    case V_detect
                    by contradiction /* from formulas */
                  next
                    case V_verify
                    solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.1 )
                      case Register
                      solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.1 )
                        case Register
                        solve( (¬(#i2 < #i2.1))  ∥ ((%n_v%+%1) ⊏ (%n_v.2%+%1)) )
                          case case_1
                          solve( (¬(#i2.1 < #i2))  ∥ ((%n_v.2%+%1) ⊏ (%n_v%+%1)) )
                            case case_1
                            solve( (#i2 = #i2.1)  ∥ (#i2.1 < #i2) )
                              case case_1
                              by contradiction /* from formulas */
                            next
                              case case_2
                              by contradiction /* from formulas */
                            qed
                          next
                            case case_2
                            solve( (#i2 = #i2.1)  ∥ (#i2.1 < #i2) )
                              case case_1
                              by contradiction /* contradictory subterm store */
                            next
                              case case_2
                              solve( St_V( ~idV, $V, $P, h_v, %n_v, ch1, 'verify_state'
                                     ) ▶₁ #i2 )
                                case V_challenge_case_1
                                by contradiction /* cyclic */
                              next
                                case V_challenge_case_2
                                solve( (¬(#i2.1 < #vr.2))  ∥ ((%n_v.2%+%1) ⊏ (%n_v%+%1)) )
                                  case case_1
                                  solve( (#vr.2 = #i2.1)  ∥ (#i2.1 < #vr.2) )
                                    case case_1
                                    solve( !KU( sign(<~ch, h(<~ch, h(<ch.1, h_v>)>)>, ~ltkPV)
                                           ) @ #vk.18 )
                                      case P_response
                                      by contradiction /* cyclic */
                                    next
                                      case c_sign
                                      solve( !KU( ~ltkPV ) @ #vk.28 )
                                        case Reveal_ltk
                                        solve( St_V( ~idV, $V, $P, h(<ch.1, h_p>), %n_v.1, ch2,
                                                     'verify_state'
                                               ) ▶₁ #i4 )
                                          case V_challenge
                                          solve( (¬(#i2 < #vr.4))  ∥
                                                 ((%n_v%+%1%+%1) ⊏ (%n_v.1%+%1)) )
                                            case case_1
                                            solve( (#vr.4 = #i2)  ∥ (#i2 < #vr.4) )
                                              case case_1
                                              by contradiction /* cyclic */
                                            next
                                              case case_2
                                              by contradiction /* from formulas */
                                            qed
                                          next
                                            case case_2
                                            solve( (#vr.4 = #i2)  ∥ (#i2 < #vr.4) )
                                              case case_1
                                              by contradiction /* cyclic */
                                            next
                                              case case_2
                                              solve( St_P( ~idP, $P, $V, h_p, %n_p ) ▶₁ #vr )
                                                case P_response
                                                by contradiction /* from formulas */
                                              next
                                                case Register
                                                solve( St_V( ~idV, $V, $P, h_v, %n_v, ch.1,
                                                             'verify_state'
                                                       ) ▶₁ #i2.1 )
                                                  case V_challenge_case_1
                                                  by contradiction /* from formulas */
                                                next
                                                  case V_challenge_case_2
                                                  by contradiction /* from formulas */
                                                qed
                                              qed
                                            qed
                                          qed
                                        qed
                                      qed
                                    qed
                                  next
                                    case case_2
                                    by contradiction /* from formulas */
                                  qed
                                next
                                  case case_2
                                  solve( (#vr.2 = #i2.1)  ∥ (#i2.1 < #vr.2) )
                                    case case_1
                                    by contradiction /* contradictory subterm store */
                                  next
                                    case case_2
                                    solve( !KU( sign(<~ch, h(<~ch, h(<ch.1, h_v>)>)>, ~ltkPV)
                                           ) @ #vk.20 )
                                      case P_response
                                      by contradiction /* cyclic */
                                    next
                                      case c_sign
                                      solve( !KU( ~ltkPV ) @ #vk.35 )
                                        case Reveal_ltk
                                        solve( St_V( ~idV, $V, $P, h(<ch.2, h_p>), %n_v.1, ch2,
                                                     'verify_state'
                                               ) ▶₁ #i4 )
                                          case V_challenge
                                          by contradiction /* cyclic */
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          qed
                        next
                          case case_2
                          solve( (#i2.1 = #i2)  ∥ (#i2 < #i2.1) )
                            case case_1
                            by contradiction /* contradictory subterm store */
                          next
                            case case_2
                            solve( St_V( ~idV, $V, $P, h_v, %n_v, ch1, 'verify_state'
                                   ) ▶₁ #i2 )
                              case V_challenge_case_1
                              solve( !KU( sign(<~ch, h(<~ch, h('seed')>)>, ~ltkPV) ) @ #vk.18 )
                                case P_response
                                by contradiction /* from formulas */
                              next
                                case c_sign
                                solve( !KU( ~ltkPV ) @ #vk.28 )
                                  case Reveal_ltk
                                  solve( St_V( ~idV, $V, $P, h(<ch.1, h_p>), %n_v, ch2,
                                               'verify_state'
                                         ) ▶₁ #i4 )
                                    case V_challenge
                                    solve( (¬(#i2 < #vr.4))  ∥ ((%1%+%1) ⊏ (%n_v%+%1)) )
                                      case case_1
                                      solve( (¬(#i2.1 < #vr.4))  ∥ ((%n_v.1%+%1) ⊏ (%n_v%+%1)) )
                                        case case_1
                                        solve( (#vr.4 = #i2)  ∥ (#i2 < #vr.4) )
                                          case case_1
                                          by contradiction /* cyclic */
                                        next
                                          case case_2
                                          by contradiction /* from formulas */
                                        qed
                                      next
                                        case case_2
                                        solve( (#vr.4 = #i2)  ∥ (#i2 < #vr.4) )
                                          case case_1
                                          by contradiction /* cyclic */
                                        next
                                          case case_2
                                          by contradiction /* from formulas */
                                        qed
                                      qed
                                    next
                                      case case_2
                                      solve( (¬(#i2.1 < #vr.4))  ∥ ((%n_v.1%+%1) ⊏ (%n_v%+%1)) )
                                        case case_1
                                        solve( (#vr.4 = #i2)  ∥ (#i2 < #vr.4) )
                                          case case_1
                                          by contradiction /* cyclic */
                                        next
                                          case case_2
                                          solve( (#vr.4 = #i2.1)  ∥ (#i2.1 < #vr.4) )
                                            case case_1
                                            solve( St_P( ~idP, $P, $V, h_p, %n_p ) ▶₁ #vr )
                                              case P_response
                                              solve( Verify( $V, $P, ch.3, h_v1 ) @ #i2.2 )
                                                case V_detect
                                                by contradiction /* from formulas */
                                              next
                                                case V_verify
                                                solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x)
                                                       )[+] ▶₂ #i2.2 )
                                                  case Register
                                                  solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                                    case Register
                                                    solve( Verify( $V, $P, ch.3, h_v1 ) @ #i2.3 )
                                                      case V_detect
                                                      by contradiction /* from formulas */
                                                    next
                                                      case V_verify
                                                      solve( !Binding( ~idP.1, ~idV.1, ltkPV.1,
                                                                       pk(x)
                                                             )[+] ▶₂ #i2.3 )
                                                        case Register
                                                        solve( !Pk( $V, $P, pk(~ltkPV.1)
                                                               )[+] ▶₃ #i2.3 )
                                                          case Register
                                                          solve( (#i2 = #i2.2)  ∥ (#i2 = #i2.3)  ∥
                                                                 (#i2.1 = #i2.2)  ∥
                                                                 (#i2.2 = #i2.3) )
                                                            case case_1
                                                            by contradiction /* from formulas */
                                                          next
                                                            case case_2
                                                            by contradiction /* from formulas */
                                                          next
                                                            case case_3
                                                            solve( (¬(#i2 < #i2.2))  ∥
                                                                   ((%1%+%1) ⊏ (%n_v.1%+%1)) )
                                                              case case_1
                                                              solve( (¬(#i2.2 < #i2))  ∥
                                                                     (¬(#vr.1 < #i2.2)) )
                                                                case case_1
                                                                solve( (#i2.2 = #i2)  ∥
                                                                       (#i2 < #i2.2) )
                                                                  case case_1
                                                                  by contradiction
                                                                     /* from formulas */
                                                                next
                                                                  case case_2
                                                                  by contradiction
                                                                     /* from formulas */
                                                                qed
                                                              next
                                                                case case_2
                                                                by contradiction /* cyclic */
                                                              qed
                                                            next
                                                              case case_2
                                                              solve( (¬(#i2.2 < #i2))  ∥
                                                                     (¬(#vr.1 < #i2.2)) )
                                                                case case_1
                                                                solve( (#i2.2 = #i2)  ∥
                                                                       (#i2 < #i2.2) )
                                                                  case case_1
                                                                  by contradiction
                                                                     /* contradictory subterm store
                                                                     */
                                                                next
                                                                  case case_2
                                                                  solve( St_V( ~idV, $V, $P,
                                                                               h(<ch.2, h_p>), %n_v,
                                                                               ch.2, 'verify_state'
                                                                         ) ▶₁ #i2.1 )
                                                                    case V_challenge
                                                                    by contradiction /* cyclic */
                                                                  qed
                                                                qed
                                                              next
                                                                case case_2
                                                                by contradiction /* cyclic */
                                                              qed
                                                            qed
                                                          next
                                                            case case_4
                                                            solve( (¬(#i2 < #i2.2))  ∥
                                                                   ((%1%+%1) ⊏ (%n_v.1%+%1)) )
                                                              case case_1
                                                              solve( (¬(#i2.2 < #i2))  ∥
                                                                     (¬(#vr.1 < #i2.2)) )
                                                                case case_1
                                                                solve( (#i2.2 = #i2)  ∥
                                                                       (#i2 < #i2.2) )
                                                                  case case_1
                                                                  by contradiction
                                                                     /* from formulas */
                                                                next
                                                                  case case_2
                                                                  by contradiction
                                                                     /* from formulas */
                                                                qed
                                                              next
                                                                case case_2
                                                                by contradiction /* cyclic */
                                                              qed
                                                            next
                                                              case case_2
                                                              solve( (¬(#i2.2 < #i2))  ∥
                                                                     (¬(#vr.1 < #i2.2)) )
                                                                case case_1
                                                                solve( (#i2.2 = #i2)  ∥
                                                                       (#i2 < #i2.2) )
                                                                  case case_1
                                                                  by contradiction
                                                                     /* contradictory subterm store
                                                                     */
                                                                next
                                                                  case case_2
                                                                  solve( St_V( ~idV, $V, $P,
                                                                               h(<ch.3, h_p>), %n_v,
                                                                               ch.2, 'verify_state'
                                                                         ) ▶₁ #i2.1 )
                                                                    case V_challenge
                                                                    solve( (¬(#i2 < #vr.6))  ∥
                                                                           ((%1%+%1) ⊏ (%n_v%+%1)) )
                                                                      case case_1
                                                                      solve( (¬(#i2.2 < #vr.6))  ∥
                                                                             ((%n_v.1%+%1) ⊏
                                                                              (%n_v%+%1)) )
                                                                        case case_1
                                                                        solve( (#i2 = #vr.6)  ∥
                                                                               (#i2.2 = #vr.6) )
                                                                          case case_1
                                                                          by contradiction
                                                                             /* cyclic */
                                                                        next
                                                                          case case_2
                                                                          by contradiction
                                                                             /* from formulas */
                                                                        qed
                                                                      next
                                                                        case case_2
                                                                        solve( (#i2 = #vr.6)  ∥
                                                                               (#i2.2 = #vr.6) )
                                                                          case case_1
                                                                          by contradiction
                                                                             /* cyclic */
                                                                        next
                                                                          case case_2
                                                                          by contradiction
                                                                             /*
                                                                             contradictory subterm store
                                                                             */
                                                                        qed
                                                                      qed
                                                                    next
                                                                      case case_2
                                                                      solve( (¬(#i2.2 < #vr.6))  ∥
                                                                             ((%n_v.1%+%1) ⊏
                                                                              (%n_v%+%1)) )
                                                                        case case_1
                                                                        solve( (#i2 = #vr.6)  ∥
                                                                               (#i2.2 = #vr.6) )
                                                                          case case_1
                                                                          by contradiction
                                                                             /* cyclic */
                                                                        next
                                                                          case case_2
                                                                          solve( St_P( ~idP, $P, $V,
                                                                                       h_p, %n_p
                                                                                 ) ▶₁ #vr.4 )
                                                                            case P_response
                                                                            solve( Verify( $V, $P,
                                                                                           ch.4,
                                                                                           h_v1.1
                                                                                   ) @ #i2.3 )
                                                                              case V_detect
                                                                              by contradiction
                                                                                 /* from formulas */
                                                                            next
                                                                              case V_verify
                                                                              solve( !Binding( ~idP.1,
                                                                                               ~idV.1,
                                                                                               ltkPV.1,
                                                                                               pk(x)
                                                                                     )[+] ▶₂ #i2.3 )
                                                                                case Register
                                                                                solve( !Pk( $V, $P,
                                                                                            pk(~ltkPV.1)
                                                                                       )[+] ▶₃ #i2.3 )
                                                                                  case Register
                                                                                  solve( Verify( $V,
                                                                                                 $P,
                                                                                                 ch.4,
                                                                                                 h_v1.1
                                                                                         ) @ #i2.4 )
                                                                                    case V_detect
                                                                                    by contradiction
                                                                                       /*
                                                                                       from formulas
                                                                                       */
                                                                                  next
                                                                                    case V_verify
                                                                                    solve( !Binding( ~idP.1,
                                                                                                     ~idV.1,
                                                                                                     ltkPV.1,
                                                                                                     pk(x)
                                                                                           )[+] ▶₂ #i2.4 )
                                                                                      case Register
                                                                                      solve( !Pk( $V,
                                                                                                  $P,
                                                                                                  pk(~ltkPV.1)
                                                                                             )[+] ▶₃ #i2.4 )
                                                                                        case Register
                                                                                        solve( Verify( $V,
                                                                                                       $P,
                                                                                                       ch.4,
                                                                                                       h_v1
                                                                                               ) @ #i2 )
                                                                                          case V_verify
                                                                                          by contradiction
                                                                                             /*
                                                                                             from formulas
                                                                                             */
                                                                                        qed
                                                                                      qed
                                                                                    qed
                                                                                  qed
                                                                                qed
                                                                              qed
                                                                            qed
                                                                          next
                                                                            case Register
                                                                            solve( St_V( ~idV, $V,
                                                                                         $P,
                                                                                         h('seed'),
                                                                                         %n_v, ch.3,
                                                                                         'verify_state'
                                                                                   ) ▶₁ #i2.2 )
                                                                              case V_challenge
                                                                              by contradiction
                                                                                 /* cyclic */
                                                                            qed
                                                                          qed
                                                                        qed
                                                                      next
                                                                        case case_2
                                                                        solve( (#i2 = #vr.6)  ∥
                                                                               (#i2.2 = #vr.6) )
                                                                          case case_1
                                                                          by contradiction
                                                                             /* cyclic */
                                                                        next
                                                                          case case_2
                                                                          by contradiction
                                                                             /*
                                                                             contradictory subterm store
                                                                             */
                                                                        qed
                                                                      qed
                                                                    qed
                                                                  qed
                                                                qed
                                                              next
                                                                case case_2
                                                                by contradiction /* cyclic */
                                                              qed
                                                            qed
                                                          qed
                                                        qed
                                                      qed
                                                    qed
                                                  qed
                                                qed
                                              qed
                                            next
                                              case Register
                                              solve( St_V( ~idV, $V, $P, h('seed'), %n_v, ch.2,
                                                           'verify_state'
                                                     ) ▶₁ #i2.1 )
                                                case V_challenge
                                                by contradiction /* cyclic */
                                              qed
                                            qed
                                          next
                                            case case_2
                                            by contradiction /* from formulas */
                                          qed
                                        qed
                                      next
                                        case case_2
                                        solve( (#vr.4 = #i2)  ∥ (#i2 < #vr.4) )
                                          case case_1
                                          by contradiction /* cyclic */
                                        next
                                          case case_2
                                          solve( (#vr.4 = #i2.1)  ∥ (#i2.1 < #vr.4) )
                                            case case_1
                                            by contradiction /* contradictory subterm store */
                                          next
                                            case case_2
                                            solve( St_P( ~idP, $P, $V, h_p, %n_p ) ▶₁ #vr )
                                              case P_response
                                              solve( Verify( $V, $P, ch.3, h_v1.1 ) @ #i2.2 )
                                                case V_detect
                                                by contradiction /* from formulas */
                                              next
                                                case V_verify
                                                solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x)
                                                       )[+] ▶₂ #i2.2 )
                                                  case Register
                                                  solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                                    case Register
                                                    solve( Verify( $V, $P, ch.3, h_v1 ) @ #i2 )
                                                      case V_verify
                                                      by contradiction /* from formulas */
                                                    qed
                                                  qed
                                                qed
                                              qed
                                            next
                                              case Register
                                              solve( St_V( ~idV, $V, $P, h_v, %n_v.1, ch.2,
                                                           'verify_state'
                                                     ) ▶₁ #i2.1 )
                                                case V_challenge_case_1
                                                by contradiction /* cyclic */
                                              next
                                                case V_challenge_case_2
                                                by contradiction /* from formulas */
                                              qed
                                            qed
                                          qed
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            next
                              case V_challenge_case_2
                              solve( !KU( sign(<~ch, h(<~ch, h(<ch.1, h_v>)>)>, ~ltkPV)
                                     ) @ #vk.20 )
                                case P_response
                                by contradiction /* from formulas */
                              next
                                case c_sign
                                solve( !KU( ~ltkPV ) @ #vk.35 )
                                  case Reveal_ltk
                                  solve( St_V( ~idV, $V, $P, h(<ch.2, h_p>), %n_v.1, ch2,
                                               'verify_state'
                                         ) ▶₁ #i4 )
                                    case V_challenge
                                    solve( (¬(#i2 < #vr.5))  ∥ ((%n_v%+%1%+%1) ⊏ (%n_v.1%+%1)) )
                                      case case_1
                                      solve( (¬(#i2.1 < #vr.5))  ∥ ((%n_v.2%+%1) ⊏ (%n_v.1%+%1)) )
                                        case case_1
                                        solve( (#vr.5 = #i2)  ∥ (#i2 < #vr.5) )
                                          case case_1
                                          by contradiction /* cyclic */
                                        next
                                          case case_2
                                          by contradiction /* from formulas */
                                        qed
                                      next
                                        case case_2
                                        solve( (#vr.5 = #i2)  ∥ (#i2 < #vr.5) )
                                          case case_1
                                          by contradiction /* cyclic */
                                        next
                                          case case_2
                                          by contradiction /* contradictory subterm store */
                                        qed
                                      qed
                                    next
                                      case case_2
                                      solve( (¬(#i2.1 < #vr.5))  ∥ ((%n_v.2%+%1) ⊏ (%n_v.1%+%1)) )
                                        case case_1
                                        solve( (#vr.5 = #i2)  ∥ (#i2 < #vr.5) )
                                          case case_1
                                          by contradiction /* cyclic */
                                        next
                                          case case_2
                                          solve( St_P( ~idP, $P, $V, h_p, %n_p ) ▶₁ #vr )
                                            case P_response
                                            solve( Verify( $V, $P, ch.4, h_v1 ) @ #i2.2 )
                                              case V_detect
                                              by contradiction /* from formulas */
                                            next
                                              case V_verify
                                              solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x)
                                                     )[+] ▶₂ #i2.2 )
                                                case Register
                                                solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                                  case Register
                                                  solve( Verify( $V, $P, ch.4, h_v1 ) @ #i2.3 )
                                                    case V_detect
                                                    by contradiction /* from formulas */
                                                  next
                                                    case V_verify
                                                    solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x)
                                                           )[+] ▶₂ #i2.3 )
                                                      case Register
                                                      solve( !Pk( $V, $P, pk(~ltkPV.1)
                                                             )[+] ▶₃ #i2.3 )
                                                        case Register
                                                        solve( (#i2 = #i2.2)  ∥ (#i2.1 = #i2.2)  ∥
                                                               (#vr.2 = #i2.2) )
                                                          case case_1
                                                          by contradiction /* from formulas */
                                                        next
                                                          case case_2
                                                          solve( (#i2 = #i2.2)  ∥ (#vr.2 = #i2.2) )
                                                            case case_1
                                                            by contradiction /* from formulas */
                                                          next
                                                            case case_2
                                                            solve( St_V( ~idV, $V, $P,
                                                                         h(<ch.1, h_p>), %n_v.1,
                                                                         ch.1, 'verify_state'
                                                                   ) ▶₁ #i2.1 )
                                                              case V_challenge
                                                              by contradiction /* cyclic */
                                                            qed
                                                          qed
                                                        next
                                                          case case_3
                                                          solve( (#i2 = #i2.3)  ∥ (#i2.2 = #i2.3) )
                                                            case case_1
                                                            by contradiction /* cyclic */
                                                          next
                                                            case case_2
                                                            solve( St_V( ~idV, $V, $P,
                                                                         h(<ch.1, h_p>), %n_v.1,
                                                                         ch.3, 'verify_state'
                                                                   ) ▶₁ #i2.1 )
                                                              case V_challenge
                                                              by contradiction /* cyclic */
                                                            qed
                                                          qed
                                                        qed
                                                      qed
                                                    qed
                                                  qed
                                                qed
                                              qed
                                            qed
                                          next
                                            case Register
                                            solve( St_V( ~idV, $V, $P, h('seed'), %n_v.1, ch.3,
                                                         'verify_state'
                                                   ) ▶₁ #i2.1 )
                                              case V_challenge
                                              by contradiction /* cyclic */
                                            qed
                                          qed
                                        qed
                                      next
                                        case case_2
                                        solve( (#vr.5 = #i2)  ∥ (#i2 < #vr.5) )
                                          case case_1
                                          by contradiction /* cyclic */
                                        next
                                          case case_2
                                          by contradiction /* contradictory subterm store */
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                next
                  case Register
                  solve( St_V( ~idV, $V, $P, h_v, %n_v, ch1, 'verify_state'
                         ) ▶₁ #i2 )
                    case V_challenge_case_1
                    solve( !KU( sign(<~ch, h(<~ch, h('seed')>)>, ~ltkPV) ) @ #vk.14 )
                      case P_response
                      by contradiction /* cyclic */
                    next
                      case c_sign
                      solve( !KU( ~ltkPV ) @ #vk.19 )
                        case Reveal_ltk
                        solve( St_V( ~idV, $V, $P, h('seed'), %n_v, ch2, 'verify_state'
                               ) ▶₁ #i4 )
                          case V_challenge
                          by contradiction /* cyclic */
                        qed
                      qed
                    qed
                  next
                    case V_challenge_case_2
                    solve( !KU( sign(<~ch, h(<~ch, h(<ch.1, h_v>)>)>, ~ltkPV)
                           ) @ #vk.16 )
                      case P_response
                      by contradiction /* cyclic */
                    next
                      case c_sign
                      solve( !KU( ~ltkPV ) @ #vk.26 )
                        case Reveal_ltk
                        solve( St_V( ~idV, $V, $P, h('seed'), %n_v.1, ch2, 'verify_state'
                               ) ▶₁ #i4 )
                          case V_challenge
                          by contradiction /* cyclic */
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma clone_detection_in_compromised_previous_session_prover_counter_forgery:
  all-traces
  "∀ p v ch1 h_p1 ch2 h_p2 #i2 #i3 #i4.
    (((((Verify( v, p, ch1, h_p1 ) @ #i2) ∧
        (Response( p, v, ch2, h_p2 ) @ #i3)) ∧
       (Verify( v, p, ch2, h_p2 ) @ #i4)) ∧
      (#i2 < #i3)) ∧
     (#i3 < #i4)) ⇒
    ((∃ #i1. (Response( p, v, ch1, h_p1 ) @ #i1) ∧ (#i1 < #i2)) ∨
     (∃ #i. Detect( v, p ) @ #i))"
/*
guarded formula characterizing all counter-examples:
"∃ p v ch1 h_p1 ch2 h_p2 #i2 #i3 #i4.
  (Verify( v, p, ch1, h_p1 ) @ #i2) ∧
  (Response( p, v, ch2, h_p2 ) @ #i3) ∧
  (Verify( v, p, ch2, h_p2 ) @ #i4)
 ∧
  (#i2 < #i3) ∧
  (#i3 < #i4) ∧
  (∀ #i1. (Response( p, v, ch1, h_p1 ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i. (Detect( v, p ) @ #i) ⇒ ⊥)"
*/
simplify
solve( !Binding( ~idP, ~idV, ltkPV, pkPV )[+] ▶₂ #i3 )
  case Register
  solve( !Ltk( $P.1, $V.1, ~ltkPV )[+] ▶₃ #i3 )
    case Register
    solve( Verify( $V, $P, ch1, h_p1 ) @ #i2 )
      case V_detect
      by contradiction /* from formulas */
    next
      case V_verify
      solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2 )
        case Register
        solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2 )
          case Register
          solve( Verify( $V, $P, ch2, h(<ch2, h_p>) ) @ #i4 )
            case V_detect
            by contradiction /* from formulas */
          next
            case V_verify
            solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i4 )
              case Register
              solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i4 )
                case Register
                solve( St_P( ~idP, $P, $V, h_v.1, %n_p ) ▶₁ #i3 )
                  case P_response
                  solve( Verify( $V, $P, ch, h_v1 ) @ #i2.1 )
                    case V_detect
                    by contradiction /* from formulas */
                  next
                    case V_verify
                    solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.1 )
                      case Register
                      solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.1 )
                        case Register
                        solve( (¬(#i2 < #i2.1))  ∥ ((%n_v%+%1) ⊏ (%n_v.2%+%1)) )
                          case case_1
                          solve( (¬(#i2.1 < #i2))  ∥ ((%n_v.2%+%1) ⊏ (%n_v%+%1)) )
                            case case_1
                            solve( (#i2 = #i2.1)  ∥ (#i2.1 < #i2) )
                              case case_1
                              solve( St_V( ~idV, $V, $P, h_v, %n_v, ch, 'verify_state' ) ▶₁ #i2 )
                                case V_challenge_case_1
                                solve( !KU( sign(<~ch, h(<~ch, h('seed')>)>, ~ltkPV) ) @ #vk.16 )
                                  case P_response
                                  by contradiction /* from formulas */
                                next
                                  case c_sign
                                  solve( !KU( ~ltkPV ) @ #vk.21 )
                                    case Reveal_ltk
                                    solve( St_V( ~idV, $V, $P, h(<~ch, h_p>), %n_v, ch2,
                                                 'verify_state'
                                           ) ▶₁ #i4 )
                                      case V_challenge
                                      solve( (¬(#i2 < #vr.4))  ∥ ((%1%+%1) ⊏ (%n_v%+%1)) )
                                        case case_1
                                        solve( (#vr.4 = #i2)  ∥ (#i2 < #vr.4) )
                                          case case_1
                                          by contradiction /* from formulas */
                                        next
                                          case case_2
                                          by contradiction /* from formulas */
                                        qed
                                      next
                                        case case_2
                                        solve( (#vr.4 = #i2)  ∥ (#i2 < #vr.4) )
                                          case case_1
                                          by contradiction /* contradictory subterm store */
                                        next
                                          case case_2
                                          by contradiction /* from formulas */
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              next
                                case V_challenge_case_2
                                solve( !KU( sign(<~ch, h(<~ch, h(<ch.1, h_v>)>)>, ~ltkPV)
                                       ) @ #vk.18 )
                                  case P_response
                                  by contradiction /* from formulas */
                                next
                                  case c_sign
                                  solve( !KU( ~ltkPV ) @ #vk.28 )
                                    case Reveal_ltk
                                    solve( St_V( ~idV, $V, $P, h(<~ch, h_p>), %n_v.1, ch2,
                                                 'verify_state'
                                           ) ▶₁ #i4 )
                                      case V_challenge
                                      solve( (¬(#i2 < #vr.5))  ∥ ((%n_v%+%1%+%1) ⊏ (%n_v.1%+%1)) )
                                        case case_1
                                        solve( (#i2 = #vr.5)  ∥ (#vr.5 < #i2) )
                                          case case_1
                                          by contradiction /* from formulas */
                                        next
                                          case case_2
                                          by contradiction /* cyclic */
                                        qed
                                      next
                                        case case_2
                                        solve( (#i2 = #vr.5)  ∥ (#vr.5 < #i2) )
                                          case case_1
                                          by contradiction /* contradictory subterm store */
                                        next
                                          case case_2
                                          by contradiction /* cyclic */
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            next
                              case case_2
                              by contradiction /* from formulas */
                            qed
                          next
                            case case_2
                            solve( (#i2 = #i2.1)  ∥ (#i2.1 < #i2) )
                              case case_1
                              by contradiction /* contradictory subterm store */
                            next
                              case case_2
                              solve( St_V( ~idV, $V, $P, h_v, %n_v, ch1, 'verify_state'
                                     ) ▶₁ #i2 )
                                case V_challenge_case_1
                                by contradiction /* cyclic */
                              next
                                case V_challenge_case_2
                                solve( (¬(#i2.1 < #vr.2))  ∥ ((%n_v.2%+%1) ⊏ (%n_v%+%1)) )
                                  case case_1
                                  solve( (#vr.2 = #i2.1)  ∥ (#i2.1 < #vr.2) )
                                    case case_1
                                    solve( !KU( sign(<~ch, h(<~ch, h(<ch.1, h_v>)>)>, ~ltkPV)
                                           ) @ #vk.18 )
                                      case P_response
                                      by contradiction /* cyclic */
                                    next
                                      case c_sign
                                      solve( !KU( ~ltkPV ) @ #vk.28 )
                                        case Reveal_ltk
                                        solve( St_V( ~idV, $V, $P, h(<ch.1, h_p>), %n_v.1, ch2,
                                                     'verify_state'
                                               ) ▶₁ #i4 )
                                          case V_challenge
                                          solve( (¬(#i2 < #vr.4))  ∥
                                                 ((%n_v%+%1%+%1) ⊏ (%n_v.1%+%1)) )
                                            case case_1
                                            solve( (#vr.4 = #i2)  ∥ (#i2 < #vr.4) )
                                              case case_1
                                              by contradiction /* cyclic */
                                            next
                                              case case_2
                                              by contradiction /* from formulas */
                                            qed
                                          next
                                            case case_2
                                            solve( (#vr.4 = #i2)  ∥ (#i2 < #vr.4) )
                                              case case_1
                                              by contradiction /* cyclic */
                                            next
                                              case case_2
                                              solve( St_P( ~idP, $P, $V, h_p, %n_p ) ▶₁ #vr )
                                                case P_response
                                                by contradiction /* from formulas */
                                              next
                                                case Register
                                                solve( St_V( ~idV, $V, $P, h_v, %n_v, ch.1,
                                                             'verify_state'
                                                       ) ▶₁ #i2.1 )
                                                  case V_challenge_case_1
                                                  by contradiction /* from formulas */
                                                next
                                                  case V_challenge_case_2
                                                  by contradiction /* from formulas */
                                                qed
                                              qed
                                            qed
                                          qed
                                        qed
                                      qed
                                    qed
                                  next
                                    case case_2
                                    by contradiction /* from formulas */
                                  qed
                                next
                                  case case_2
                                  solve( (#vr.2 = #i2.1)  ∥ (#i2.1 < #vr.2) )
                                    case case_1
                                    by contradiction /* contradictory subterm store */
                                  next
                                    case case_2
                                    solve( !KU( sign(<~ch, h(<~ch, h(<ch.1, h_v>)>)>, ~ltkPV)
                                           ) @ #vk.20 )
                                      case P_response
                                      by contradiction /* cyclic */
                                    next
                                      case c_sign
                                      solve( !KU( ~ltkPV ) @ #vk.35 )
                                        case Reveal_ltk
                                        solve( St_V( ~idV, $V, $P, h(<ch.2, h_p>), %n_v.1, ch2,
