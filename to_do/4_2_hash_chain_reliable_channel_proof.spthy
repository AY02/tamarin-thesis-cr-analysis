                                        by contradiction /* from formulas */
                                      qed
                                    qed
                                  qed
                                qed
                              next
                                case case_2
                                solve( Verify( $V, $P, ch.1, h_v1 ) @ #i2.2 )
                                  case V_detect
                                  solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                    case Register
                                    solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                      case Register
                                      simplify
                                      simplify
                                      by contradiction
                                         /* non-injective facts (#vr.13,#vr.6,#vr.1) */
                                    qed
                                  qed
                                next
                                  case V_verify
                                  solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                    case Register
                                    solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                      case Register
                                      simplify
                                      solve( (#vr.13 = #vr.6)  ∥ (#vr.6 < #vr.13) )
                                        case case_1
                                        by contradiction /* contradictory subterm store */
                                      next
                                        case case_2
                                        by contradiction /* from formulas */
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            next
                              case case_2
                              by contradiction /* cyclic */
                            qed
                          next
                            case case_2
                            solve( Verify( $V, $P, ch.1, h_v1 ) @ #i2.2 )
                              case V_detect
                              solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                case Register
                                solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                  case Register
                                  by contradiction /* non-injective facts (#i2.1,#i2.2,#vr) */
                                qed
                              qed
                            next
                              case V_verify
                              solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                case Register
                                solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                  case Register
                                  simplify
                                  solve( Verify( $V, $P, ~ch.2, h_v1 ) @ #i2.3 )
                                    case V_detect
                                    solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.2 )
                                      case Register
                                      solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.2 )
                                        case Register
                                        by contradiction /* cyclic */
                                      qed
                                    qed
                                  next
                                    case V_verify
                                    solve( !Binding( ~idP.1, ~idV.1, ltkPV.1, pk(x) )[+] ▶₂ #i2.3 )
                                      case Register
                                      solve( !Pk( $V, $P, pk(~ltkPV.1) )[+] ▶₃ #i2.3 )
                                        case Register
                                        solve( (#i2.1 = #i2.2)  ∥ (#i2.1 = #i2.3) )
                                          case case_1
                                          by contradiction /* cyclic */
                                        next
                                          case case_2
                                          by contradiction /* cyclic */
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          qed
                        next
                          case Register
                          by contradiction /* cyclic */
                        qed
                      qed
                    next
                      case case_2
                      by contradiction /* from formulas */
                    qed
                  next
                    case case_2
                    solve( (#vr.1 = #i2.1)  ∥ (#i2.1 < #vr.1) )
                      case case_1
                      by contradiction /* cyclic */
                    next
                      case case_2
                      by contradiction /* from formulas */
                    qed
                  qed
                next
                  case case_2
                  solve( (#vr.1 = #i2.1)  ∥ (#i2.1 < #vr.1) )
