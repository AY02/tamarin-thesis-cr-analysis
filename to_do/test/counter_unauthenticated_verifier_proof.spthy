lemma clone_detection_soundness:
  all-traces
  "∀ p v #i2.
    (Detect( v, p ) @ #i2) ⇒
    (∃ #i1. (Reveal_ltk_PV( p, v ) @ #i1) ∧ (#i1 < #i2))"
/*
guarded formula characterizing all counter-examples:
"∃ p v #i2.
  (Detect( v, p ) @ #i2)
 ∧
  ∀ #i1. (Reveal_ltk_PV( p, v ) @ #i1) ⇒ ¬(#i1 < #i2)"
*/
simplify
solve( St_VP( ~idVP, %cVP, old_nPV, ch, 'verify_state' ) ▶₁ #i2 )
  case V_challenge_case_1
  solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, pk(x) ) ▶₂ #i2 )
    case Register
    solve( !KU( sign(<'response', $P, $V, %1, nPV, ~ch>, ~ltkPV)
           ) @ #vk.12 )
      case c_sign
      solve( !KU( ~ltkPV ) @ #vk.13 )
        case Reveal_ltk_PV
        by contradiction /* from formulas */
      qed
    qed
  qed
next
  case V_challenge_case_2
  solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, pk(x) ) ▶₂ #i2 )
    case Register
    solve( (%cPV ⊏ %cVP)  ∥ (%cVP = %cPV) )
      case case_1
      solve( !KU( sign(<'response', $P, $V, %cPV, nPV, ~ch>, ~ltkPV)
             ) @ #vk.16 )
        case P_response
        solve( !KU( sign(<'response', $P, $V, %cVP, old_nPV, ch.1>, ~ltkPV)
               ) @ #vk.25 )
          case P_response
          by contradiction /* cyclic */
        next
          case c_sign
          solve( !KU( ~ltkPV ) @ #vk.31 )
            case Reveal_ltk_PV
            by contradiction /* from formulas */
          qed
        qed
      next
        case c_sign
        solve( !KU( ~ltkPV ) @ #vk.23 )
          case Reveal_ltk_PV
          by contradiction /* from formulas */
        qed
      qed
    next
      case case_2
      solve( !KU( sign(<'response', $P, $V, %cPV, nPV, ~ch>, ~ltkPV)
             ) @ #vk.17 )
        case P_response
        solve( !KU( sign(<'response', $P, $V, (%cPV%+%1), old_nPV, ch.1>,
                         ~ltkPV)
               ) @ #vk.24 )
          case P_response
          by contradiction /* cyclic */
        next
          case c_sign
          solve( !KU( ~ltkPV ) @ #vk.30 )
            case Reveal_ltk_PV
            by contradiction /* from formulas */
          qed
        qed
      next
        case c_sign
        solve( !KU( ~ltkPV ) @ #vk.22 )
          case Reveal_ltk_PV
          by contradiction /* from formulas */
        qed
      qed
    qed
  qed
qed

lemma clone_detection_in_compromised_previous_session [use_induction]:
  all-traces
  "∀ p v %cPV1 nPV1 ch1 %cPV2 nPV2 ch2 #i2 #i3 #i4.
    (((((Verify( v, p, %cPV1, nPV1, ch1 ) @ #i2) ∧
        (Response( p, v, %cPV2, nPV2, ch2 ) @ #i3)) ∧
       (Verify( v, p, %cPV2, nPV2, ch2 ) @ #i4)) ∧
      (#i2 < #i3)) ∧
     (#i3 < #i4)) ⇒
    ((∃ #i1.
       (Response( p, v, %cPV1, nPV1, ch1 ) @ #i1) ∧ (#i1 < #i2)) ∨
     (∃ #i. Detect( v, p ) @ #i))"
/*
guarded formula characterizing all counter-examples:
"∃ p v %cPV1 nPV1 ch1 %cPV2 nPV2 ch2 #i2 #i3 #i4.
  (Verify( v, p, %cPV1, nPV1, ch1 ) @ #i2) ∧
  (Response( p, v, %cPV2, nPV2, ch2 ) @ #i3) ∧
  (Verify( v, p, %cPV2, nPV2, ch2 ) @ #i4)
 ∧
  (#i2 < #i3) ∧
  (#i3 < #i4) ∧
  (∀ #i1.
    (Response( p, v, %cPV1, nPV1, ch1 ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i. (Detect( v, p ) @ #i) ⇒ ⊥)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( Verify( $V, $P, %cPV1, nPV1, ch1 ) @ #i2 )
    case V_accept
    solve( Verify( $V, $P, (%cPV%+%1), ~next_nPV, ch2 ) @ #i4 )
      case V_accept
      solve( !Binding( ~idPV.1, ~idVP.1, $P, $V, ~ltkPV.1, pkPV
             ) ▶₂ #i3 )
        case Register
        solve( (last(#i4))  ∥
               (∃ #i1.
                 (Response( $P, $V, %cPV1, nPV1, ch1 ) @ #i1)
                ∧
                 (¬(last(#i1))) ∧ (#i1 < #i2))  ∥
               (∃ #i. (Detect( $V, $P ) @ #i) ∧ ¬(last(#i))) )
          case case_1
          solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, pk(x) ) ▶₂ #i2 )
            case Register
            solve( !Binding( ~idPV.1, ~idVP.1, $P, $V, ~ltkPV.1, pk(x)
                   ) ▶₂ #i4 )
              case Register
              solve( !KU( sign(<'response', $P, $V, (%cPV%+%1), ~next_nPV, ch2>,
                               ~ltkPV)
                     ) @ #vk.30 )
                case P_response
                solve( !KU( ~next_nPV ) @ #vk.30 )
                  case P_response
                  solve( !KU( sign(<'response', $P, $V, %cPV1, nPV1, ch1>, ~ltkPV)
                         ) @ #vk.29 )
                    case P_response
                    by contradiction /* from formulas */
                  next
                    case c_sign
                    solve( St_VP( ~idVP, %cVP, old_nPV, ch1, 'verify_state' ) ▶₁ #i2 )
                      case V_challenge_case_1
                      solve( St_VP( ~idVP, %cVP, old_nPV, ch2, 'verify_state' ) ▶₁ #i4 )
                        case V_challenge
                        solve( !KU( ~ltkPV ) @ #vk.34 )
                          case Reveal_ltk_PV
                          solve( (#vr.10 = #i2)  ∥ (#i2 < #vr.10) )
                            case case_1
                            solve( !KU( ~ch.1 ) @ #vk.24 )
                              case V_challenge
                              solve( !KU( ~ch ) @ #vk.30 )
                                case V_challenge
                                solve( St_PV( ~idPV, %cPV, nPV ) ▶₁ #i3 )
                                  case P_response
                                  solve( !KU( ~next_nPV ) @ #vk.29 )
                                    case P_response
                                    solve( St_PV( ~idPV, %cPV, nPV ) ▶₁ #vr.21 )
                                      case P_response
                                      by sorry
                                    next
                                      case Register
                                      SOLVED // trace found
                                    qed
                                  qed
                                next
                                  case Register
                                  by contradiction /* contradictory subterm store */
                                qed
                              qed
                            qed
                          next
                            case case_2
                            by sorry
                          qed
                        qed
                      qed
                    next
                      case V_challenge_case_2
                      by sorry
                    qed
                  qed
                qed
              next
                case c_sign
                by sorry
              qed
            qed
          qed
        next
          case case_2
          by contradiction /* from formulas */
        next
          case case_3
          by contradiction /* from formulas */
        qed
      qed
    next
      case V_detect
      by contradiction /* from formulas */
    qed
  next
    case V_detect
    by contradiction /* from formulas */
  qed
qed

