theory counter_authenticated_verifier
begin

builtins: signing, natural-numbers

heuristic: I

restriction Equality:
  "All x y #i. Eq(x, y) @i ==> x = y"

restriction LessThan:
  "All %x %y #i. LessThan(%x, %y) @i ==> %x << %y"

restriction GreaterEqualThan:
  "All %x %y #i. GreaterEqualThan(%x, %y) @i ==> %y << %x | %x = %y"

restriction RegisterOnce:
  "All p v #i #j. Register(p, v) @i & Register(p, v) @j ==> #i = #j"

rule Register:
    [ Fr(~ltkPV), Fr(~ltkVP),
      Fr(~idPV), Fr(~idVP),
      Fr(~inj_n) ]
  --[ Register($P, $V),
      InitCounterPV(~idPV), InitCounterVP(~idVP) ]->
    [ !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(~ltkPV), pk(~ltkVP)),
      St_PV(~idPV, %1, 'null'),
      St_VP(~idVP, %1, 'null', ~inj_n, 'challenge_state'),
      Out(<pk(~ltkPV), pk(~ltkVP)>) ]

rule V_challenge:
  let m = <'challenge', $V, $P, %cVP, old_nPV, ~ch>
      sig = sign(m, ~ltkVP)
  in
    [ St_VP(~idVP, %cVP, old_nPV, ~inj_n, 'challenge_state'),
      !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP),
      Fr(~ch) ]
  --[ Challenge($V, $P, %cVP, old_nPV, ~ch),
      Injectivity(~idVP, ~inj_n, ~ch) ]->
    [ St_VP(~idVP, %cVP, old_nPV, ~ch, 'verify_state'),
      Out(<m, sig>) ]

rule P_response:
  let v_m =  <'challenge', $V, $P, %cVP, sent_nPV, ch>
      %next_cPV = %cPV %+ %1
      p_m = <'response', $P, $V, %next_cPV, ~next_nPV, ch>
      p_sig = sign(p_m, ~ltkPV)
  in
    [ In(<v_m, v_sig>),
      St_PV(~idPV, %cPV, nPV),
      !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP),
      Fr(~next_nPV) ]
  --[ Eq(verify(v_sig, v_m, pkVP), true),
      Eq(nPV, sent_nPV), Eq(%cPV, %cVP),
      Response($P, $V, %next_cPV, ~next_nPV, ch) ]->
    [ St_PV(~idPV, %next_cPV, ~next_nPV),
      Out(<p_m, p_sig>) ]

rule V_accept:
  let m = <'response', $P, $V, %cPV, nPV, ch>
  in
    [ In(<m, sig>),
      St_VP(~idVP, %cVP, old_nPV, ch, 'verify_state'),
      !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP),
      Fr(~inj_n) ]
  --[ Verify($V, $P, %cPV, nPV, ch),
      Eq(verify(sig, m, pkPV), true),
      LessThan(%cVP, %cPV),
      Accept($V, $P),
      Injectivity(~idVP, ch, ~inj_n) ]->
    [ St_VP(~idVP, %cPV, nPV, ~inj_n, 'challenge_state') ]

rule V_detect:
  let m = <'response', $P, $V, %cPV, nPV, ch>
  in
    [ In(<m, sig>),
      St_VP(~idVP, %cVP, old_nPV, ch, 'verify_state'),
      !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP) ]
  --[ Verify($V, $P, %cPV, nPV, ch),
      Eq(verify(sig, m, pkPV), true),
      GreaterEqualThan(%cVP, %cPV),
      Detect($V, $P) ]->
    [ /* Perform mitigation */ ]

rule Reveal_ltk_PV:
    [ !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP) ]
  --[ Reveal_ltk_PV($P, $V) ]->
    [ Out(~ltkPV) ]

rule Reveal_ltk_VP:
    [ !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP) ]
  --[ Reveal_ltk_VP($V, $P) ]->
    [ Out(~ltkVP) ]

lemma verifier_injectivity[reuse]:
  "All idVP inj_n1 ch inj_n2 n1 n2 #i1 #i2 #i3.
    Injectivity(idVP, inj_n1, ch) @i1 &
    Injectivity(idVP, ch, inj_n2) @i3 &
    Injectivity(idVP, n1, n2) @i2 &
    #i2 < #i3 ==> not(#i1 < #i2)"

lemma executability_single_session_honest:
  exists-trace
  "Ex p v #i. Accept(v, p) @i &
    not(Ex #j. Reveal_ltk_PV(p, v) @j) &
    not(Ex #j. Reveal_ltk_VP(v, p) @j)"

lemma executability_consecutive_sessions_honest:
  exists-trace
   "Ex p v #i1 #i2. Accept(v, p) @i1 & Accept(v, p) @i2 & #i1 < #i2 &
    not(Ex #i. Reveal_ltk_PV(p, v) @i) &
    not(Ex #j. Reveal_ltk_VP(v, p) @j)"

lemma prover_injective_agreement:
  "All p v %cPV nPV ch #i2.
    Verify(v, p, %cPV, nPV, ch) @i2 & Accept(v, p) @i2 &
    not(Ex #i. Reveal_ltk_PV(p, v) @i) &
    not(Ex #i. Reveal_ltk_VP(v, p) @i)
    ==>
    (Ex #i1. Response(p, v, %cPV, nPV, ch) @i1 & #i1 < #i2) &
    not(Ex p_i v_i #i.
      Verify(v_i, p_i, %cPV, nPV, ch) @i & Accept(v_i, p_i) @i & not(#i = #i2))"

lemma clone_detection_soundness:
  "All p v #i2. Detect(v, p) @i2
    ==>
    (Ex #i1. Reveal_ltk_PV(p, v) @i1 & #i1 < #i2) |
    (Ex #i1. Reveal_ltk_VP(v, p) @i1 & #i1 < #i2)"

lemma clone_detection_in_compromised_previous_session[use_induction]:
  "All p v %cPV1 nPV1 ch1 %cPV2 nPV2 ch2 #i2 #i3 #i4.
    Verify(v, p, %cPV1, nPV1, ch1) @i2 &
    Response(p, v, %cPV2, nPV2, ch2) @i3 &
    Verify(v, p, %cPV2, nPV2, ch2) @i4 &
    #i2 < #i3 & #i3 < #i4
    ==>
    (Ex #i1. Response(p, v, %cPV1, nPV1, ch1) @i1 & #i1 < #i2) |
    (Ex #i. Detect(v, p) @i)"

end