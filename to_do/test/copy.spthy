theory Ideal_Protocol
begin


builtins: signing, hashing


heuristic: I


restriction Equality:
  "All x y #i. Eq(x, y) @i ==> x = y"

restriction Inequality:
  "All x #i. Neq(x, x) @i ==> F"

restriction RegisterOnce:
  "All p v #i #j. Register(p, v) @i & Register(p, v) @j ==> #i = #j"

restriction StartOnce:
  "All idP1 idV1 idP2 idV2 p v #i #j. Start(idP1, idV1, p, v) @i & Start(idP2, idV2, p, v) @j ==> #i = #j"


rule Register:
    [ Fr(~ltkPV), Fr(~ltkVP) ]
  --[ Register($P, $V) ]->
    [ !PV($P, $V, ~ltkPV, pk(~ltkPV), pk(~ltkVP)),
      !VP($V, $P, ~ltkVP, pk(~ltkVP), pk(~ltkPV)),
      Out(<pk(~ltkPV), pk(~ltkVP)>) ]

rule Start:
    [ !PV($P, $V, ~ltkPV, pkPV, pkVP),
      !VP($V, $P, ~ltkVP, pkVP, pkPV),
      Fr(~idP), Fr(~idV) ]
  --[ Start(~idP, ~idV, $P, $V),
      InitHashP(~idP), InitHashV(~idV) ]->
    [ !Binding(~idP, ~idV, $P, $V, ~ltkPV, ~ltkVP, pk(~ltkPV), pk(~ltkVP)),
      St_P(~idP, $P, $V, 'init'),
      St_V(~idV, $V, $P, 'init', 'challenge_state', 'null') ]

rule V_challenge:
  let sig = sign(<'challenge', $V, $P, ~ch, v_hash>, ~ltkVP)
  in
    [ St_V(~idV, $V, $P, v_hash, 'challenge_state', 'null'),
      !Binding(~idP, ~idV, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP),
      Fr(~ch) ]
  --[ Challenge($V, $P, ~ch, v_hash) ]->
    [ St_V(~idV, $V, $P, v_hash, 'verify_state', ~ch),
      Out(<'challenge', $V, $P, ~ch, v_hash, sig>) ]

rule P_response:
  let p_hash_next = h(<ch, p_hash>)
      p_sig = sign(<'response', $P, $V, ch, p_hash_next>, ~ltkPV)
  in
    [ In(<'challenge', $V, $P, ch, v_hash, v_sig>),
      St_P(~idP, $P, $V, p_hash),
      !Binding(~idP, ~idV, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP) ]
  --[ Eq(verify(v_sig, <'challenge', $V, $P, ch, v_hash>, pkVP), true),
      Eq(p_hash, v_hash),
      Response($P, $V, ch, p_hash_next),
      HashP(~idP, p_hash_next) ]->
    [ St_P(~idP, $P, $V, p_hash_next),
      Out(<'response', $P, $V, p_hash_next, p_sig>) ]

rule V_accept:
  let v_hash_next = h(<~ch, v_hash>)
  in
    [ In(<'response', $P, $V, p_hash, p_sig>),
      St_V(~idV, $V, $P, v_hash, 'verify_state', ~ch),
      !Binding(~idP, ~idV, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP) ]
  --[ Eq(verify(p_sig, <'response', $P, $V, ~ch, p_hash>, pkPV), true),
      Eq(v_hash_next, p_hash),
      Verify($V, $P, ~ch, v_hash_next),
      Accept($V, $P),
      HashV(~idV, v_hash_next) ]->
    [ St_V(~idV, $V, $P, v_hash_next, 'challenge_state', 'null') ]

rule V_detect:
  let v_hash_next = h(<~ch, v_hash>)
  in
    [ In(<'response', $P, $V, p_hash, p_sig>),
      St_V(~idV, $V, $P, v_hash, 'verify_state', ~ch),
      !Binding(~idP, ~idV, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP) ]
  --[ Eq(verify(p_sig, <'response', $P, $V, ~ch, p_hash>, pkPV), true),
      Neq(v_hash_next, p_hash),
      Verify($V, $P, ~ch, v_hash_next),
      Detect($V, $P) ]->
    [ /* Perform mitigation */ ]

rule Reveal_ltk_PV:
    [ !PV($P, $V, ~ltkPV, pkPV, pkVP) ]
  --[ Reveal_PV($P, $V) ]->
    [ Out(~ltkPV) ]

rule Reveal_ltk_VP:
    [ !VP($V, $P, ~ltkVP, pkVP, pkPV) ]
  --[ Reveal_VP($V, $P) ]->
    [ Out(~ltkVP) ]


// --------------------------------------LEMMAS--------------------------------------


lemma prover_injective_agreement:
  "All p v ch p_hash #i2.
    Verify(v, p, ch, p_hash) @i2 & Accept(v, p) @i2 &
    not(Ex #i. Reveal_PV(p, v) @i) &
    not(Ex #i. Reveal_VP(v, p) @i)
    ==>
    (Ex #i1. Response(p, v, ch, p_hash) @i1 & #i1 < #i2) &
    not(Ex p_i v_i #i.
      Verify(v_i, p_i, ch, p_hash) @i & Accept(v_i, p_i) @i & not(#i = #i2))"

lemma clone_detection_soundness:
  "All p v #i2. Detect(v, p) @i2
    ==>
    (Ex #i1. Reveal_PV(p, v) @i1 & #i1 < #i2) |
    (Ex #i1. Reveal_VP(v, p) @i1 & #i1 < #i2)"

lemma clone_detection_in_compromised_previous_session:
  "All p v ch1 ch2 p_hash1 p_hash2 #i2 #i3 #i4.
    Verify(v, p, ch1, p_hash1) @i2 &
    Response(p, v, ch2, p_hash2) @i3 &
    Verify(v, p, ch2, p_hash2) @i4 &
    #i2 < #i3 & #i3 < #i4
    ==>
    (Ex #i1. Response(p, v, ch1, p_hash1) @i1 & #i1 < #i2) |
    (Ex #i. Detect(v, p) @i) |
    (Ex #i. Reveal_PV(p, v) @i)"

lemma aposteriori_boundary_case:
  "All p v ch1 ch2 p_hash1 p_hash2 #i2 #i4.
    Verify(v, p, ch1, p_hash1) @i2 &
    not(Ex #i1. Response(p, v, ch1, p_hash1) @i1 & #i1 < #i2) &
    Verify(v, p, ch2, p_hash2) @i4 &
    #i2 < #i4 & p_hash2 = h(<ch2, p_hash1>)
    ==>
    not(Ex #i3. Response(p, v, ch2, p_hash2) @i3 & #i3 < #i4) |
    (Ex #i. Detect(v, p) @i)"

lemma clone_detection_in_compromised_previous_session_both_keys:
  "All p v ch1 ch2 p_hash1 p_hash2 #i2 #i3 #i4.
    Verify(v, p, ch1, p_hash1) @i2 &
    Response(p, v, ch2, p_hash2) @i3 &
    Verify(v, p, ch2, p_hash2) @i4 &
    #i2 < #i3 & #i3 < #i4
    ==>
    (Ex #i1. Response(p, v, ch1, p_hash1) @i1 & #i1 < #i2) |
    (Ex #i. Detect(v, p) @i)"


end