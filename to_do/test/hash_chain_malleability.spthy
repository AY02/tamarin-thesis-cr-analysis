theory hash_chain_malleability
begin

builtins: hashing

functions: verify/3, sign/3, pk/1, true/0
equations: verify(sign(m, r, sk), m, pk(sk)) = true

functions: mangle/2
equations: mangle(sign(m, r, sk), repnew) = sign(m, repnew, sk)

heuristic: I

restriction Equality:
  "All x y #i. Eq(x, y) @i ==> x = y"

restriction Inequality:
  "All x #i. Neq(x, x) @i ==> F"

restriction RegisterOnce:
  "All p v #i #j. Register(p, v) @i & Register(p, v) @j ==> #i = #j"

rule Register:
    [ Fr(~ltkPV), Fr(~ltkVP),
      Fr(~idPV), Fr(~idVP),
      Fr(~inj_n), Fr(~init) ]
  --[ Register($P, $V),
      InitHashPV(~idPV), InitHashVP(~idVP) ]->
    [ !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(~ltkPV), pk(~ltkVP)),
      St_PV(~idPV, ~init),
      St_VP(~idVP, ~init, ~inj_n, 'challenge_state'),
      Out(<pk(~ltkPV), pk(~ltkVP), ~init>) ]

rule V_challenge:
  let m = <'challenge', $V, $P, hVP, ~ch>
      sig = sign(m, ~r, ~ltkVP)
  in
    [ St_VP(~idVP, hVP, ~inj_n, 'challenge_state'),
      !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP),
      Fr(~ch), Fr(~r) ]
  --[ Challenge($V, $P, hVP, ~ch),
      Injectivity(~idVP, ~inj_n, ~ch) ]->
    [ St_VP(~idVP, hVP, ~ch, 'verify_state'),
      Out(<m, sig>) ]

rule P_response:
  let v_m =  <'challenge', $V, $P, hVP, ch>
      next_hPV = h(<hPV, ch>)
      p_m = <'response', $P, $V, ch, next_hPV, ~nPV>
      p_sig = sign(p_m, ~r, ~ltkPV)
      next_next_hPV = h(<next_hPV, ~nPV>)
  in
    [ In(<v_m, v_sig>),
      St_PV(~idPV, hPV),
      !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP),
      Fr(~nPV), Fr(~r) ]
  --[ Eq(verify(v_sig, v_m, pkVP), true),
      Eq(hPV, hVP),
      Response($P, $V, ch, next_hPV, ~nPV) ]->
    [ St_PV(~idPV, next_next_hPV),
      Out(<p_m, p_sig>) ]

rule V_accept:
  let m = <'response', $P, $V, ch, hPV, nPV>
      expected_hPV = h(<hVP, ch>)
      next_hVP = h(<expected_hPV, nPV>)
  in
    [ In(<m, sig>),
      St_VP(~idVP, hVP, ch, 'verify_state'),
      !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP),
      Fr(~inj_n) ]
  --[ Verify($V, $P, ch, hPV, nPV),
      Eq(verify(sig, m, pkPV), true),
      Eq(expected_hPV, hPV),
      Accept($V, $P),
      Injectivity(~idVP, ch, ~inj_n) ]->
    [ St_VP(~idVP, next_hVP, ~inj_n, 'challenge_state') ]

rule V_detect:
  let m = <'response', $P, $V, ch, hPV, nPV>
      expected_hPV = h(<hVP, ch>)
      next_hVP = h(<expected_hPV, nPV>)
  in
    [ In(<m, sig>),
      St_VP(~idVP, hVP, ch, 'verify_state'),
      !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP) ]
  --[ Verify($V, $P, ch, hPV, nPV),
      Eq(verify(sig, m, pkPV), true),
      Neq(expected_hPV, hPV),
      Detect($V, $P) ]->
    [ /* Perform mitigation */ ]

rule Reveal_ltk_PV:
    [ !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP) ]
  --[ Reveal_ltk_PV($P, $V) ]->
    [ Out(~ltkPV) ]

rule Reveal_ltk_VP:
    [ !Binding(~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP) ]
  --[ Reveal_ltk_VP($V, $P) ]->
    [ Out(~ltkVP) ]

lemma verifier_injectivity[reuse]:
  "All idVP inj_n1 ch inj_n2 n1 n2 #i1 #i2 #i3.
    Injectivity(idVP, inj_n1, ch) @i1 &
    Injectivity(idVP, ch, inj_n2) @i3 &
    Injectivity(idVP, n1, n2) @i2 &
    #i2 < #i3 ==> not(#i1 < #i2)"

lemma executability_single_session_honest:
  exists-trace
  "Ex p v #i. Accept(v, p) @i &
    not(Ex #j. Reveal_ltk_PV(p, v) @j) &
    not(Ex #j. Reveal_ltk_VP(v, p) @j)"

lemma executability_consecutive_sessions_honest:
  exists-trace
   "Ex p v #i1 #i2. Accept(v, p) @i1 & Accept(v, p) @i2 & #i1 < #i2 &
    not(Ex #i. Reveal_ltk_PV(p, v) @i) &
    not(Ex #j. Reveal_ltk_VP(v, p) @j)"

lemma prover_injective_agreement:
  "All p v ch hPV nPV #i2.
    Verify(v, p, ch, hPV, nPV) @i2 & Accept(v, p) @i2 &
    not(Ex #i. Reveal_ltk_PV(p, v) @i) &
    not(Ex #i. Reveal_ltk_VP(v, p) @i)
    ==>
    (Ex #i1. Response(p, v, ch, hPV, nPV) @i1 & #i1 < #i2) &
    not(Ex p_i v_i #i.
      Verify(v_i, p_i, ch, hPV, nPV) @i & Accept(v_i, p_i) @i & not(#i = #i2))"

lemma clone_detection_soundness:
  "All p v #i2. Detect(v, p) @i2
    ==>
    (Ex #i1. Reveal_ltk_PV(p, v) @i1 & #i1 < #i2) |
    (Ex #i1. Reveal_ltk_VP(v, p) @i1 & #i1 < #i2)"

lemma clone_detection_in_compromised_previous_session[use_induction]:
  "All p v ch1 hPV1 nPV1 ch2 hPV2 nPV2 #i2 #i3 #i4.
    Verify(v, p, ch1, hPV1, nPV1) @i2 &
    Response(p, v, ch2, hPV2, nPV2) @i3 &
    Verify(v, p, ch2, hPV2, nPV2) @i4 &
    #i2 < #i3 & #i3 < #i4
    ==>
    (Ex #i1. Response(p, v, ch1, hPV1, nPV1) @i1 & #i1 < #i2) |
    (Ex #i. Detect(v, p) @i)"

end