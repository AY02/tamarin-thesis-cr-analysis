lemma clone_detection_in_compromised_previous_session [use_induction]:
  all-traces
  "∀ p v ch1 hPV1 nPV1 ch2 hPV2 nPV2 #i2 #i3 #i4.
    (((((Verify( v, p, ch1, hPV1, nPV1 ) @ #i2) ∧
        (Response( p, v, ch2, hPV2, nPV2 ) @ #i3)) ∧
       (Verify( v, p, ch2, hPV2, nPV2 ) @ #i4)) ∧
      (#i2 < #i3)) ∧
     (#i3 < #i4)) ⇒
    ((∃ #i1. (Response( p, v, ch1, hPV1, nPV1 ) @ #i1) ∧ (#i1 < #i2)) ∨
     (∃ #i. Detect( v, p ) @ #i))"
/*
guarded formula characterizing all counter-examples:
"∃ p v ch1 hPV1 nPV1 ch2 hPV2 nPV2 #i2 #i3 #i4.
  (Verify( v, p, ch1, hPV1, nPV1 ) @ #i2) ∧
  (Response( p, v, ch2, hPV2, nPV2 ) @ #i3) ∧
  (Verify( v, p, ch2, hPV2, nPV2 ) @ #i4)
 ∧
  (#i2 < #i3) ∧
  (#i3 < #i4) ∧
  (∀ #i1. (Response( p, v, ch1, hPV1, nPV1 ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i. (Detect( v, p ) @ #i) ⇒ ⊥)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( Verify( $V, $P, ch1, hPV1, nPV1 ) @ #i2 )
    case V_accept
    solve( Verify( $V, $P, ch2, h(<hPV, ch2>), ~nPV ) @ #i4 )
      case V_accept
      solve( !Binding( ~idPV.1, ~idVP.1, $P, $V, ~ltkPV.1, ~ltkVP.1,
                       pkPV, pk(x.3)
             ) ▶₂ #i3 )
        case Register
        solve( (last(#i4))  ∥
               (∃ #i1.
                 (Response( $P, $V, ch1, h(<hVP, ch1>), nPV1 ) @ #i1)
                ∧
                 (¬(last(#i1))) ∧ (#i1 < #i2))  ∥
               (∃ #i. (Detect( $V, $P ) @ #i) ∧ ¬(last(#i))) )
          case case_1
          solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(x.1),
                           pkVP
                 ) ▶₂ #i2 )
            case Register
            solve( !Binding( ~idPV.1, ~idVP.1, $P, $V, ~ltkPV.1, ~ltkVP.1,
                             pk(x.3), pkVP
                   ) ▶₂ #i4 )
              case Register
              solve( St_PV( ~idPV, hVP.1 ) ▶₁ #i3 )
                case P_response
                solve( !KU( sign(<'challenge', $V, $P, h(<h(<hPV, ch>), ~nPV>), ch2
                                 >,
                                 x.1, ~ltkVP)
                       ) @ #vk.22 )
                  case V_challenge_case_1
                  solve( (#vr.1 < #i2)  ∥
                         (∃ #i1.
                           (Response( $P, $V, ch1, h(<hVP, ch1>), nPV1 ) @ #i1)
                          ∧
                           (¬(last(#i1))) ∧ (#i1 < #i2))  ∥
                         (∃ #i. (Detect( $V, $P ) @ #i) ∧ ¬(last(#i))) )
                    case case_1
                    solve( (#vr.4 = #i2)  ∥ (#i2 < #vr.4) )
                      case case_1
                      by contradiction /* from formulas */
                    next
                      case case_2
                      solve( St_VP( ~idVP, hVP, ch1, 'verify_state' ) ▶₁ #i2 )
                        case V_challenge_case_1
                        solve( !KU( sign(<'response', $P, $V, ~ch, h(<~init, ~ch>), nPV1>,
                                         x, ~ltkPV)
                               ) @ #vk.34 )
                          case P_response_case_1
                          by contradiction /* from formulas */
                        next
                          case P_response_case_2
                          by contradiction /* from formulas */
                        next
                          case P_response_case_3
                          by contradiction /* from formulas */
                        next
                          case c_sign
                          solve( !KU( ~ltkPV ) @ #vk.49 )
                            case Reveal_ltk_PV
                            solve( St_VP( ~idVP, h(<h(<hPV, ch.1>), ~nPV>), ~ch.2,
                                          'verify_state'
                                   ) ▶₁ #i4 )
                              case V_challenge
                              solve( !KU( sign(<'response', $P, $V, ~ch.2, 
                                                h(<h(<h(<hPV, ch.1>), ~nPV>), ~ch.2>), ~nPV.1>,
                                               x.1, ~ltkPV)
                                     ) @ #vk.39 )
                                case P_response_case_1
                                solve( !KU( sign(<'challenge', $V, $P, hPV, ch.1>, x.1, ~ltkVP)
                                       ) @ #vk.44 )
                                  case V_challenge_case_1
                                  by contradiction /* from formulas */
                                next
                                  case V_challenge_case_2
