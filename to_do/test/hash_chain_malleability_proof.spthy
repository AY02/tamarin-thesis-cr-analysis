                                    case Reveal_ltk_VP
                                    solve( St_PV( ~idPV, hPV ) ▶₁ #vr.1 )
                                      case P_response
                                      solve( !KU( sign(<'response', $P, $V, ch.2, 
                                                        h(<h(<h(<hPV, ch.1>), ~nPV>), ch.2>), ~nPV.1
                                                       >,
                                                       x.2, ~ltkPV)
                                             ) @ #vk.52 )
                                        case P_response_case_1
                                        solve( St_VP( ~idVP, h(<h(<hPV, ch.1>), ~nPV>), ch.2,
                                                      'verify_state'
                                               ) ▶₁ #vr.4 )
