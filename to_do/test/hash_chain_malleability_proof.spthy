theory hash_chain_malleability

begin

// Function signature and definition of the equational theory E

functions: fst/1, h/1, mangle/2, pair/2, pk/1, sign/3, snd/1,
           true/0, verify/3
equations:
    fst(<x.1, x.2>) = x.1,
    mangle(sign(m, r, sk), repnew) = sign(m, repnew, sk),
    snd(<x.1, x.2>) = x.2,
    verify(sign(m, r, sk), m, pk(sk)) = true

heuristic: I

/* looping facts with injective instances: St_PV/2, St_VP/4 */

restriction Equality:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

  /*
  expanded formula:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  */

restriction Inequality:
  "∀ x #i. (Neq( x, x ) @ #i) ⇒ (⊥)"
  // safety formula

  /*
  expanded formula:
  "∀ x #i. (Neq( x, x ) @ #i) ⇒ (⊥)"
  */

restriction RegisterOnce:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( p, v ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( p, v ) @ #j)) ⇒ (#i = #j)"
  */

rule (modulo E) Register:
   [
   Fr( ~ltkPV ), Fr( ~ltkVP ), Fr( ~idPV ), Fr( ~idVP ), Fr( ~inj_n ),
   Fr( ~init )
   ]
  --[ Register( $P, $V ), InitHashPV( ~idPV ), InitHashVP( ~idVP )
  ]->
   [
   !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(~ltkPV),
             pk(~ltkVP)
   ),
   St_PV( ~idPV, ~init ),
   St_VP( ~idVP, ~init, ~inj_n, 'challenge_state' ),
   Out( <pk(~ltkPV), pk(~ltkVP), ~init> )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) V_challenge:
   [
   St_VP( ~idVP, hVP, ~inj_n, 'challenge_state' ),
   !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP ),
   Fr( ~ch ), Fr( ~r )
   ]
  --[
  Challenge( $V, $P, hVP, ~ch ), Injectivity( ~idVP, ~inj_n, ~ch )
  ]->
   [
   St_VP( ~idVP, hVP, ~ch, 'verify_state' ),
   Out( <<'challenge', $V, $P, hVP, ~ch>, 
         sign(<'challenge', $V, $P, hVP, ~ch>, ~r, ~ltkVP)>
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) P_response:
   [
   In( <<'challenge', $V, $P, hVP, ch>, v_sig> ), St_PV( ~idPV, hPV ),
   !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP ),
   Fr( ~nPV ), Fr( ~r )
   ]
  --[
  Eq( verify(v_sig, <'challenge', $V, $P, hVP, ch>, pkVP), true ),
  Eq( hPV, hVP ), Response( $P, $V, ch, h(<hPV, ch>), ~nPV )
  ]->
   [
   St_PV( ~idPV, h(<h(<hPV, ch>), ~nPV>) ),
   Out( <<'response', $P, $V, ch, h(<hPV, ch>), ~nPV>, 
         sign(<'response', $P, $V, ch, h(<hPV, ch>), ~nPV>, ~r, ~ltkPV)>
   )
   ]

  // loop breaker: [1]
  /*
  rule (modulo AC) P_response:
     [
     In( <<'challenge', $V, $P, hVP, ch>, v_sig> ), St_PV( ~idPV, hPV ),
     !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP ),
     Fr( ~nPV ), Fr( ~r )
     ]
    --[
    Eq( z, true ), Eq( hPV, hVP ),
    Response( $P, $V, ch, h(<hPV, ch>), ~nPV )
    ]->
     [
     St_PV( ~idPV, h(<h(<hPV, ch>), ~nPV>) ),
     Out( <<'response', $P, $V, ch, h(<hPV, ch>), ~nPV>, 
           sign(<'response', $P, $V, ch, h(<hPV, ch>), ~nPV>, ~r, ~ltkPV)>
     )
     ]
    variants (modulo AC)
    1. $P    = $P.32
       $V    = $V.33
       ch    = ch.40
       hVP   = hVP.42
       pkVP  = pkVP.44
       v_sig = v_sig.45
       z     = verify(v_sig.45,
                      <'challenge', $V.33, $P.32, hVP.42, ch.40>, pkVP.44)
    
    2. $P    = $P.49
       $V    = $V.50
       ch    = ch.57
       hVP   = hVP.59
       pkVP  = pk(x.95)
       v_sig = sign(<'challenge', $V.50, $P.49, hVP.59, ch.57>, x.96,
                    x.95)
       z     = true
    // loop breaker: [1]
  */

rule (modulo E) V_accept:
   [
   In( <<'response', $P, $V, ch, hPV, nPV>, sig> ),
   St_VP( ~idVP, hVP, ch, 'verify_state' ),
   !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP ),
   Fr( ~inj_n )
   ]
  --[
  Verify( $V, $P, ch, hPV, nPV ),
  Eq( verify(sig, <'response', $P, $V, ch, hPV, nPV>, pkPV), true ),
  Eq( h(<hVP, ch>), hPV ), Accept( $V, $P ),
  Injectivity( ~idVP, ch, ~inj_n )
  ]->
   [ St_VP( ~idVP, h(<h(<hVP, ch>), nPV>), ~inj_n, 'challenge_state' )
   ]

  // loop breaker: [1]
  /*
  rule (modulo AC) V_accept:
     [
     In( <<'response', $P, $V, ch, hPV, nPV>, sig> ),
     St_VP( ~idVP, hVP, ch, 'verify_state' ),
     !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP ),
     Fr( ~inj_n )
     ]
    --[
    Verify( $V, $P, ch, hPV, nPV ), Eq( z, true ),
    Eq( h(<hVP, ch>), hPV ), Accept( $V, $P ),
    Injectivity( ~idVP, ch, ~inj_n )
    ]->
     [ St_VP( ~idVP, h(<h(<hVP, ch>), nPV>), ~inj_n, 'challenge_state' )
     ]
    variants (modulo AC)
    1. $P    = $P.33
       $V    = $V.34
       ch    = ch.40
       hPV   = hPV.41
       nPV   = nPV.43
       pkPV  = pkPV.44
       sig   = sig.46
       z     = verify(sig.46,
                      <'response', $P.33, $V.34, ch.40, hPV.41, nPV.43>, pkPV.44)
    
    2. $P    = $P.69
       $V    = $V.70
       ch    = ch.76
       hPV   = hPV.77
       nPV   = nPV.79
       pkPV  = pk(x.134)
       sig   = sign(<'response', $P.69, $V.70, ch.76, hPV.77, nPV.79>,
                    x.136, x.134)
       z     = true
    // loop breaker: [1]
  */

rule (modulo E) V_detect:
   [
   In( <<'response', $P, $V, ch, hPV, nPV>, sig> ),
   St_VP( ~idVP, hVP, ch, 'verify_state' ),
   !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP )
   ]
  --[
  Verify( $V, $P, ch, hPV, nPV ),
  Eq( verify(sig, <'response', $P, $V, ch, hPV, nPV>, pkPV), true ),
  Neq( h(<hVP, ch>), hPV ), Detect( $V, $P )
  ]->
   [ ]

  /*
  rule (modulo AC) V_detect:
     [
     In( <<'response', $P, $V, ch, hPV, nPV>, sig> ),
     St_VP( ~idVP, hVP, ch, 'verify_state' ),
     !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP )
     ]
    --[
    Verify( $V, $P, ch, hPV, nPV ), Eq( z, true ),
    Neq( h(<hVP, ch>), hPV ), Detect( $V, $P )
    ]->
     [ ]
    variants (modulo AC)
    1. $P    = $P.30
       $V    = $V.31
       ch    = ch.36
       hPV   = hPV.37
       nPV   = nPV.39
       pkPV  = pkPV.40
       sig   = sig.42
       z     = verify(sig.42,
                      <'response', $P.30, $V.31, ch.36, hPV.37, nPV.39>, pkPV.40)
    
    2. $P    = $P.46
       $V    = $V.47
       ch    = ch.52
       hPV   = hPV.53
       nPV   = nPV.55
       pkPV  = pk(x.88)
       sig   = sign(<'response', $P.46, $V.47, ch.52, hPV.53, nPV.55>,
                    x.90, x.88)
       z     = true
  */

rule (modulo E) Reveal_ltk_PV:
   [ !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP ) ]
  --[ Reveal_ltk_PV( $P, $V ) ]->
   [ Out( ~ltkPV ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_ltk_VP:
   [ !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP ) ]
  --[ Reveal_ltk_VP( $V, $P ) ]->
   [ Out( ~ltkVP ) ]

  /* has exactly the trivial AC variant */

lemma verifier_injectivity [reuse]:
  all-traces
  "∀ idVP inj_n1 ch inj_n2 n1 n2 #i1 #i2 #i3.
    ((((Injectivity( idVP, inj_n1, ch ) @ #i1) ∧
       (Injectivity( idVP, ch, inj_n2 ) @ #i3)) ∧
      (Injectivity( idVP, n1, n2 ) @ #i2)) ∧
     (#i2 < #i3)) ⇒
    (¬(#i1 < #i2))"
/*
guarded formula characterizing all counter-examples:
"∃ idVP inj_n1 ch inj_n2 n1 n2 #i1 #i2 #i3.
  (Injectivity( idVP, inj_n1, ch ) @ #i1) ∧
  (Injectivity( idVP, ch, inj_n2 ) @ #i3) ∧
  (Injectivity( idVP, n1, n2 ) @ #i2)
 ∧
  (#i2 < #i3) ∧ (#i1 < #i2)"
*/
simplify
solve( Injectivity( idVP, inj_n1, ch ) @ #i1 )
  case V_accept
  solve( Injectivity( ~idVP, ~inj_n, inj_n2 ) @ #i3 )
    case V_accept
    by solve( !KU( ~inj_n ) @ #vk.20 )
  next
    case V_challenge
    solve( Injectivity( ~idVP, n1, n2 ) @ #i2 )
      case V_accept
      solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(x.1),
                       pkVP
             ) ▶₂ #i1 )
        case Register
        solve( St_VP( ~idVP, hVP.2, ~inj_n, 'challenge_state' ) ▶₀ #i3 )
          case V_accept
          by contradiction /* cyclic */
        qed
      qed
    next
      case V_challenge
      solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(x.1),
                       pkVP
             ) ▶₂ #i1 )
        case Register
        solve( St_VP( ~idVP, hVP.2, ~inj_n, 'challenge_state' ) ▶₀ #i3 )
          case V_accept
          by contradiction /* cyclic */
        qed
      qed
    qed
  qed
next
  case V_challenge
  solve( Injectivity( ~idVP, ~ch, inj_n2 ) @ #i3 )
    case V_accept
    solve( Injectivity( ~idVP, n1, n2 ) @ #i2 )
      case V_accept
      solve( St_VP( ~idVP, hVP, ~inj_n, 'challenge_state' ) ▶₀ #i1 )
        case Register
        solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP
               ) ▶₁ #i1 )
          case Register
          solve( !Binding( ~idPV.2, ~idVP, $P.2, $V.2, ~ltkPV.2, ~ltkVP.2,
                           pk(x.3), pkVP.1
                 ) ▶₂ #i3 )
            case Register
            solve( !Binding( ~idPV.1, ~idVP, $P.1, $V.1, ~ltkPV.1, ~ltkVP.1,
                             pk(x.1), pkVP
                   ) ▶₂ #i2 )
              case Register
              solve( St_VP( ~idVP, hVP.1, ~ch, 'verify_state' ) ▶₁ #i3 )
                case V_challenge
                by contradiction /* cyclic */
              qed
            qed
          qed
        qed
      next
        case V_accept
        solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP
               ) ▶₁ #i1 )
          case Register
          solve( !Binding( ~idPV.2, ~idVP, $P.2, $V.2, ~ltkPV.2, ~ltkVP.2,
                           pk(x.3), pkVP.1
                 ) ▶₂ #i3 )
            case Register
            solve( !Binding( ~idPV.1, ~idVP, $P.1, $V.1, ~ltkPV.1, ~ltkVP.1,
                             pk(x.1), pkVP
                   ) ▶₂ #i2 )
              case Register
              solve( St_VP( ~idVP, hVP.2, ~ch.1, 'verify_state' ) ▶₁ #i3 )
                case V_challenge
                by contradiction /* cyclic */
              qed
            qed
          qed
        qed
      qed
    next
      case V_challenge
      solve( St_VP( ~idVP, hVP, ~inj_n, 'challenge_state' ) ▶₀ #i1 )
        case Register
        solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP
               ) ▶₁ #i1 )
          case Register
          solve( !Binding( ~idPV.2, ~idVP, $P.2, $V.2, ~ltkPV.2, ~ltkVP.2,
                           pk(x.1), pkVP.1
                 ) ▶₂ #i3 )
            case Register
            solve( St_VP( ~idVP, hVP, ~inj_n.1, 'challenge_state' ) ▶₀ #i2 )
              case Register
              by contradiction /* cyclic */
            next
              case V_accept
              solve( !Binding( ~idPV.1, ~idVP, $P.1, $V.1, ~ltkPV.1, ~ltkVP.1,
                               pkPV, pkVP
                     ) ▶₁ #i2 )
                case Register
                solve( St_VP( ~idVP, hVP.1, ~ch, 'verify_state' ) ▶₁ #i3 )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              qed
            qed
          qed
        qed
      next
        case V_accept
        solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP
               ) ▶₁ #i1 )
          case Register
          solve( !Binding( ~idPV.2, ~idVP, $P.2, $V.2, ~ltkPV.2, ~ltkVP.2,
                           pk(x.1), pkVP.1
                 ) ▶₂ #i3 )
            case Register
            solve( St_VP( ~idVP, hVP.1, ~inj_n.1, 'challenge_state' ) ▶₀ #i2 )
              case Register
              by contradiction /* cyclic */
            next
              case V_accept
              solve( !Binding( ~idPV.1, ~idVP, $P.1, $V.1, ~ltkPV.1, ~ltkVP.1,
                               pkPV, pkVP
                     ) ▶₁ #i2 )
                case Register
                solve( St_VP( ~idVP, hVP.2, ~ch.1, 'verify_state' ) ▶₁ #i3 )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  next
    case V_challenge
    solve( Injectivity( ~idVP, n1, n2 ) @ #i2 )
      case V_accept
      solve( St_VP( ~idVP, hVP, ~inj_n, 'challenge_state' ) ▶₀ #i1 )
        case Register
        solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP
               ) ▶₁ #i1 )
          case Register
          by solve( St_VP( ~idVP, hVP.1, ~ch, 'challenge_state' ) ▶₀ #i3 )
        qed
      next
        case V_accept
        solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP
               ) ▶₁ #i1 )
          case Register
          by solve( St_VP( ~idVP, hVP.2, ~ch.1, 'challenge_state' ) ▶₀ #i3 )
        qed
      qed
    next
      case V_challenge
      solve( St_VP( ~idVP, hVP, ~inj_n, 'challenge_state' ) ▶₀ #i1 )
        case Register
        solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP
               ) ▶₁ #i1 )
          case Register
          by solve( St_VP( ~idVP, hVP.1, ~ch, 'challenge_state' ) ▶₀ #i3 )
        qed
      next
        case V_accept
        solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pkPV, pkVP
               ) ▶₁ #i1 )
          case Register
          by solve( St_VP( ~idVP, hVP.2, ~ch.1, 'challenge_state' ) ▶₀ #i3 )
        qed
      qed
    qed
  qed
qed

lemma executability_single_session_honest:
  exists-trace
  "∃ p v #i.
    ((Accept( v, p ) @ #i) ∧ (¬(∃ #j. Reveal_ltk_PV( p, v ) @ #j))) ∧
    (¬(∃ #j. Reveal_ltk_VP( v, p ) @ #j))"
/*
guarded formula characterizing all satisfying traces:
"∃ p v #i.
  (Accept( v, p ) @ #i)
 ∧
  (∀ #j. (Reveal_ltk_PV( p, v ) @ #j) ⇒ ⊥) ∧
  (∀ #j. (Reveal_ltk_VP( v, p ) @ #j) ⇒ ⊥)"
*/
simplify
solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(x.1),
                 pkVP
       ) ▶₂ #i )
  case Register
  solve( St_VP( ~idVP, hVP, ch, 'verify_state' ) ▶₁ #i )
    case V_challenge_case_1
    solve( !KU( sign(<'response', $P, $V, ~ch, h(<~init, ~ch>), nPV>,
                     x, ~ltkPV)
           ) @ #vk.12 )
      case P_response_case_1
      solve( !KU( sign(<'challenge', $V, $P, ~init, ~ch>, x, ~ltkVP)
             ) @ #vk.20 )
        case V_challenge_case_1
        solve( St_PV( ~idPV, ~init ) ▶₁ #vr.2 )
          case Register
          solve( !KU( ~ch ) @ #vk.14 )
            case V_challenge
            solve( !KU( ~init ) @ #vk.20 )
              case Register
              solve( !KU( ~nPV ) @ #vk.19 )
                case P_response
                solve( !KU( h(<~init, ~ch>) ) @ #vk.19 )
                  case P_response
                  solve( !KU( sign(<'challenge', $V.1, $P.1, ~init, ~ch>, x,
                                   ~ltkVP.1)
                         ) @ #vk.27 )
                    case V_challenge
                    SOLVED // trace found
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma executability_consecutive_sessions_honest:
  exists-trace
  "∃ p v #i1 #i2.
    ((((Accept( v, p ) @ #i1) ∧ (Accept( v, p ) @ #i2)) ∧
      (#i1 < #i2)) ∧
     (¬(∃ #i. Reveal_ltk_PV( p, v ) @ #i))) ∧
    (¬(∃ #j. Reveal_ltk_VP( v, p ) @ #j))"
/*
guarded formula characterizing all satisfying traces:
"∃ p v #i1 #i2.
  (Accept( v, p ) @ #i1) ∧ (Accept( v, p ) @ #i2)
 ∧
  (#i1 < #i2) ∧
  (∀ #i. (Reveal_ltk_PV( p, v ) @ #i) ⇒ ⊥) ∧
  (∀ #j. (Reveal_ltk_VP( v, p ) @ #j) ⇒ ⊥)"
*/
simplify
solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(x.1),
                 pkVP
       ) ▶₂ #i1 )
  case Register
  solve( !Binding( ~idPV.1, ~idVP.1, $P, $V, ~ltkPV.1, ~ltkVP.1,
                   pk(x.2), pkVP
         ) ▶₂ #i2 )
    case Register
    solve( St_VP( ~idVP, hVP, ch, 'verify_state' ) ▶₁ #i1 )
      case V_challenge_case_1
      solve( St_VP( ~idVP, hVP, ch.1, 'verify_state' ) ▶₁ #i2 )
        case V_challenge_case_2
        solve( (#vr.3 = #i1)  ∥ (#i1 < #vr.3) )
          case case_1
          solve( !KU( sign(<'response', $P, $V, ~ch, h(<~init, ~ch>), nPV>,
                           x, ~ltkPV)
                 ) @ #vk.16 )
            case P_response_case_1
            solve( !KU( sign(<'response', $P, $V, ~ch.1, 
                              h(<h(<h(<~init, ~ch>), ~nPV>), ~ch.1>), nPV.1>,
                             x, ~ltkPV)
                   ) @ #vk.25 )
              case P_response_case_1
              solve( !KU( sign(<'challenge', $V, $P, ~init, ~ch>, x, ~ltkVP)
                     ) @ #vk.34 )
                case V_challenge_case_1
                solve( St_PV( ~idPV, ~init ) ▶₁ #vr.3 )
                  case Register
                  solve( !KU( sign(<'challenge', $V, $P, h(<h(<~init, ~ch>), ~nPV>), 
                                    ~ch.1>,
                                   x, ~ltkVP)
                         ) @ #vk.37 )
                    case V_challenge_case_1
                    solve( St_PV( ~idPV, h(<h(<~init, ~ch>), ~nPV>) ) ▶₁ #vr.5 )
                      case P_response
                      solve( !KU( ~ch ) @ #vk.24 )
                        case V_challenge
                        solve( !KU( ~ch.1 ) @ #vk.30 )
                          case V_challenge
                          solve( !KU( ~init ) @ #vk.36 )
                            case Register
                            solve( !KU( ~nPV ) @ #vk.32 )
                              case P_response
                              solve( !KU( ~nPV.1 ) @ #vk.35 )
                                case P_response
                                solve( !KU( h(<~init, ~ch>) ) @ #vk.33 )
                                  case P_response
                                  solve( !KU( sign(<'challenge', $V.1, $P.1, ~init, ~ch>, x,
                                                   ~ltkVP.1)
                                         ) @ #vk.44 )
                                    case V_challenge
                                    solve( !KU( h(<h(<h(<~init, ~ch>), ~nPV>), ~ch.1>) ) @ #vk.35 )
                                      case P_response
                                      solve( !KU( sign(<'challenge', $V.1, $P.1, 
                                                        h(<h(<~init, ~ch>), ~nPV>), ~ch.1>,
                                                       x, ~ltkVP.1)
                                             ) @ #vk.44 )
                                        case V_challenge
                                        solve( !KU( h(<h(<~init, ~ch>), ~nPV>) ) @ #vk.37 )
                                          case V_challenge
                                          solve( !KU( sign(<'response', $P.1, $V.1, ~ch, 
                                                            h(<~init, ~ch>), ~nPV>,
                                                           x, ~ltkPV.1)
                                                 ) @ #vk.44 )
                                            case P_response_case_1
                                            solve( (#vr.41 = #i1)  ∥ (#i1 < #vr.41) )
                                              case case_1
                                              SOLVED // trace found
                                            qed
                                          qed
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma prover_injective_agreement:
  all-traces
  "∀ p v ch hPV nPV #i2.
    ((((Verify( v, p, ch, hPV, nPV ) @ #i2) ∧ (Accept( v, p ) @ #i2)) ∧
      (¬(∃ #i. Reveal_ltk_PV( p, v ) @ #i))) ∧
     (¬(∃ #i. Reveal_ltk_VP( v, p ) @ #i))) ⇒
    ((∃ #i1. (Response( p, v, ch, hPV, nPV ) @ #i1) ∧ (#i1 < #i2)) ∧
     (¬(∃ p_i v_i #i.
         ((Verify( v_i, p_i, ch, hPV, nPV ) @ #i) ∧
          (Accept( v_i, p_i ) @ #i)) ∧
         (¬(#i = #i2)))))"
/*
guarded formula characterizing all counter-examples:
"∃ p v ch hPV nPV #i2.
  (Verify( v, p, ch, hPV, nPV ) @ #i2) ∧ (Accept( v, p ) @ #i2)
 ∧
  (∀ #i. (Reveal_ltk_PV( p, v ) @ #i) ⇒ ⊥) ∧
  (∀ #i. (Reveal_ltk_VP( v, p ) @ #i) ⇒ ⊥) ∧
  (((∀ #i1. (Response( p, v, ch, hPV, nPV ) @ #i1) ⇒ ¬(#i1 < #i2)) ∨
    (∃ p_i v_i #i.
      (Verify( v_i, p_i, ch, hPV, nPV ) @ #i) ∧ (Accept( v_i, p_i ) @ #i)
     ∧
      ¬(#i = #i2))))"
*/
simplify
solve( Verify( $V, $P, ch.2, hPV.2, nPV.2 ) @ #i2 )
  case V_accept
  solve( (∀ #i1.
           (Response( $P, $V, ch, h(<hVP, ch>), nPV ) @ #i1)
          ⇒
           ¬(#i1 < #i2))  ∥
         (∃ p_i v_i #i.
           (Verify( v_i, p_i, ch, h(<hVP, ch>), nPV ) @ #i) ∧
           (Accept( v_i, p_i ) @ #i)
          ∧
           ¬(#i = #i2)) )
    case case_1
    solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(x.1),
                     pkVP
           ) ▶₂ #i2 )
      case Register
      solve( St_VP( ~idVP, hVP, ch, 'verify_state' ) ▶₁ #i2 )
        case V_challenge_case_1
        solve( !KU( sign(<'response', $P, $V, ~ch, h(<~init, ~ch>), nPV>,
                         x, ~ltkPV)
               ) @ #vk.12 )
          case P_response_case_1
          by contradiction /* from formulas */
        next
          case P_response_case_2
          by contradiction /* from formulas */
        next
          case P_response_case_3
          by contradiction /* from formulas */
        next
          case c_sign
          solve( !KU( ~ltkPV ) @ #vk.14 )
            case Reveal_ltk_PV
            by contradiction /* from formulas */
          qed
        qed
      next
        case V_challenge_case_2
        solve( !KU( sign(<'response', $P, $V, ~ch, 
                          h(<h(<h(<hVP, ch.1>), nPV>), ~ch>), nPV.1>,
                         x, ~ltkPV)
               ) @ #vk.15 )
          case P_response_case_1
          by contradiction /* from formulas */
        next
          case P_response_case_2
          by contradiction /* from formulas */
        next
          case P_response_case_3
          by contradiction /* from formulas */
        next
          case c_sign
          solve( !KU( ~ltkPV ) @ #vk.24 )
            case Reveal_ltk_PV
            by contradiction /* from formulas */
          qed
        qed
      qed
    qed
  next
    case case_2
    solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(x.1),
                     pkVP
           ) ▶₂ #i2 )
      case Register
      solve( Verify( $V, $P, ch.1, h(<hVP.1, ch.1>), nPV.1 ) @ #i )
        case V_accept
        solve( (#i < #i2)  ∥ (#i2 < #i) )
          case case_1
          solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(x.1),
                           pkVP
                 ) ▶₂ #i )
            case Register
            solve( St_VP( ~idVP.1, hVP, ch, 'verify_state' ) ▶₁ #i2 )
              case V_challenge_case_1
              solve( !KU( sign(<'response', $P.1, $V.1, ~ch, h(<~init, ~ch>), nPV
                               >,
                               x.1, ~ltkPV.1)
                     ) @ #vk.16 )
                case P_response_case_1
                solve( St_VP( ~idVP, ~init, ~ch, 'verify_state' ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_case_2
                solve( St_VP( ~idVP, ~init, ~ch, 'verify_state' ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_case_3
                solve( St_VP( ~idVP, ~init, ~ch, 'verify_state' ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV.1 ) @ #vk.21 )
                  case Reveal_ltk_PV
                  by contradiction /* from formulas */
                qed
              qed
            next
              case V_challenge_case_2
              solve( !KU( sign(<'response', $P.1, $V.1, ~ch, 
                                h(<h(<h(<hVP, ch.1>), nPV>), ~ch>), nPV.1>,
                               x.1, ~ltkPV.1)
                     ) @ #vk.19 )
                case P_response_case_1
                solve( St_VP( ~idVP, h(<h(<hVP, ch.1>), nPV>), ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_case_2
                solve( St_VP( ~idVP, h(<h(<hVP, ch.1>), nPV>), ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_case_3
                solve( St_VP( ~idVP, h(<h(<hVP, ch.1>), nPV>), ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV.1 ) @ #vk.31 )
                  case Reveal_ltk_PV
                  by contradiction /* from formulas */
                qed
              qed
            qed
          qed
        next
          case case_2
          solve( !Binding( ~idPV, ~idVP, $P, $V, ~ltkPV, ~ltkVP, pk(x.1),
                           pkVP
                 ) ▶₂ #i )
            case Register
            solve( St_VP( ~idVP.1, hVP, ch, 'verify_state' ) ▶₁ #i2 )
              case V_challenge_case_1
              solve( !KU( sign(<'response', $P.1, $V.1, ~ch, h(<~init, ~ch>), nPV
                               >,
                               x.1, ~ltkPV.1)
                     ) @ #vk.16 )
                case P_response_case_1
                solve( St_VP( ~idVP, ~init, ~ch, 'verify_state' ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_case_2
                solve( St_VP( ~idVP, ~init, ~ch, 'verify_state' ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_case_3
                solve( St_VP( ~idVP, ~init, ~ch, 'verify_state' ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV.1 ) @ #vk.21 )
                  case Reveal_ltk_PV
                  by contradiction /* from formulas */
                qed
              qed
            next
              case V_challenge_case_2
              solve( !KU( sign(<'response', $P.1, $V.1, ~ch, 
                                h(<h(<h(<hVP, ch.1>), nPV>), ~ch>), nPV.1>,
                               x.1, ~ltkPV.1)
                     ) @ #vk.19 )
                case P_response_case_1
                solve( St_VP( ~idVP, h(<h(<hVP, ch.1>), nPV>), ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_case_2
                solve( St_VP( ~idVP, h(<h(<hVP, ch.1>), nPV>), ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_case_3
                solve( St_VP( ~idVP, h(<h(<hVP, ch.1>), nPV>), ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV.1 ) @ #vk.31 )
                  case Reveal_ltk_PV
                  by contradiction /* from formulas */
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

