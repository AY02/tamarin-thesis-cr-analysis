              case Reveal_ltk_VP
              by contradiction /* from formulas */
            qed
          qed
        qed
      next
        case P_response_case_3
        solve( St_VP( ~idVP, hVP, ch.1, 'verify_state' ) ▶₁ #vr.1 )
          case V_challenge_case_1
          solve( !KU( sign(<'challenge', $V, $P, hPV, ~ch>, x.2, ~ltkVP)
                 ) @ #vk.35 )
            case V_challenge_case_1
            by contradiction /* from formulas */
