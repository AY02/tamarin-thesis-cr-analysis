lemma verify_monotonicity [reuse, use_induction]:
  all-traces
  "∀ v p %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
    (((((Verify( v, p, %cP1, nP1, ch1 ) @ #i1) ∧
        (Accept( v, p ) @ #i1)) ∧
       (Verify( v, p, %cP2, nP2, ch2 ) @ #i2)) ∧
      (Accept( v, p ) @ #i2)) ∧
     (#i1 < #i2)) ⇒
    (%cP1 ⊏ %cP2)"
/*
guarded formula characterizing all counter-examples:
"∃ v p %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
  (Verify( v, p, %cP1, nP1, ch1 ) @ #i1) ∧
  (Accept( v, p ) @ #i1) ∧
  (Verify( v, p, %cP2, nP2, ch2 ) @ #i2) ∧
  (Accept( v, p ) @ #i2)
 ∧
  (#i1 < #i2) ∧ (¬(%cP1 ⊏ %cP2))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  simplify
  solve( Verify( $V, $P, %cP1, nP1, ch1 ) @ #i1 )
    case V_accept
    solve( Verify( $V, $P, %cP2, nP2, ch2 ) @ #i2 )
      case V_accept
      solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
             ) ▶₂ #i1 )
        case Register
        solve( !Binding_VP( $V, $P, ~idV.1, ~idP.1, pkVP, pk(x), ~ltkVP.1
               ) ▶₂ #i2 )
          case Register
          solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state'
                 ) ▶₁ #i1 )
            case V_challenge_case_1
            solve( St_VP( ~idV, $V, $P, %1, prev_nP, ch2, 'verify_state'
                   ) ▶₁ #i2 )
              case V_challenge_case_1
              by contradiction /* cyclic */
            next
              case V_challenge_case_2
              by contradiction /* cyclic */
            qed
          next
            case V_challenge_case_2
            solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP.1, ch2,
                          'verify_state'
                   ) ▶₁ #i2 )
              case V_challenge_case_1
              by contradiction /* cyclic */
            next
              case V_challenge_case_2
              by contradiction /* cyclic */
            next
              case V_challenge_case_3
              by contradiction /* cyclic */
            qed
          next
            case V_challenge_case_3
            solve( St_VP( ~idV, $V, $P, (%prev_cP%+%1), prev_nP.1, ch2,
                          'verify_state'
                   ) ▶₁ #i2 )
              case V_challenge_case_1
              by contradiction /* cyclic */
            next
              case V_challenge_case_2
              by contradiction /* cyclic */
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma verify_uniqueness [reuse]:
  all-traces
  "∀ v p %cP nP ch #i #j.
    ((Verify( v, p, %cP, nP, ch ) @ #i) ∧
     (Verify( v, p, %cP, nP, ch ) @ #j)) ⇒
    (#i = #j)"
/*
guarded formula characterizing all counter-examples:
"∃ v p %cP nP ch #i #j.
  (Verify( v, p, %cP, nP, ch ) @ #i) ∧
  (Verify( v, p, %cP, nP, ch ) @ #j)
 ∧
  ¬(#i = #j)"
*/
simplify
solve( Verify( v, p, %cP, nP, ch ) @ #i )
  case V_accept
  solve( Verify( $V, $P, (%prev_cP%+%1), nP, ch ) @ #j )
    case V_accept
    solve( (#i < #j)  ∥ (#j < #i) )
      case case_1
      by contradiction /* from formulas */
    next
      case case_2
      by contradiction /* from formulas */
    qed
  next
    case V_detect_cloning
    solve( (#i < #j)  ∥ (#j < #i) )
      case case_1
      solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
             ) ▶₂ #i )
        case Register
        solve( St_VP( ~idV.1, $V, $P, %prev_cP.1, prev_nP.1, ch,
                      'verify_state'
               ) ▶₁ #j )
          case V_challenge_case_1
          by contradiction /* cyclic */
        next
          case V_challenge_case_2
          by contradiction /* cyclic */
        next
          case V_challenge_case_3
          by contradiction /* cyclic */
        qed
      qed
    next
      case case_2
      solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
             ) ▶₂ #i )
        case Register
        solve( St_VP( ~idV.1, $V, $P, %prev_cP.1, prev_nP.1, ch,
                      'verify_state'
               ) ▶₁ #j )
          case V_challenge_case_1
          by contradiction /* contradictory subterm store */
        next
          case V_challenge_case_2
          solve( !Binding_VP( $V, $P, ~idV, ~idP.1, pkVP, pk(x), ~ltkVP.1
                 ) ▶₂ #j )
            case Register
            by solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~ch,
                             'verify_state'
                      ) ▶₁ #i )
          qed
        next
          case V_challenge_case_3
          by contradiction /* from formulas */
        qed
      qed
    qed
  next
    case V_detect_response_loss
    solve( (#i < #j)  ∥ (#j < #i) )
      case case_1
      solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
             ) ▶₂ #i )
        case Register
        solve( St_VP( ~idV.1, $V, $P, %prev_cP.1, prev_nP.1, ch,
                      'verify_state'
               ) ▶₁ #j )
          case V_challenge_case_1
          by contradiction /* cyclic */
        next
          case V_challenge_case_2
          by contradiction /* cyclic */
        next
          case V_challenge_case_3
          by contradiction /* cyclic */
        qed
      qed
    next
      case case_2
      solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
             ) ▶₂ #i )
        case Register
        solve( St_VP( ~idV.1, $V, $P, %prev_cP.1, prev_nP.1, ch,
                      'verify_state'
               ) ▶₁ #j )
          case V_challenge_case_1
          solve( !Binding_VP( $V, $P, ~idV, ~idP.1, pkVP, pk(x), ~ltkVP.1
                 ) ▶₂ #j )
            case Register
            by solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~ch,
                             'verify_state'
                      ) ▶₁ #i )
          qed
        next
          case V_challenge_case_2
          solve( !Binding_VP( $V, $P, ~idV, ~idP.1, pkVP, pk(x), ~ltkVP.1
                 ) ▶₂ #j )
            case Register
            by solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~ch,
                             'verify_state'
                      ) ▶₁ #i )
          qed
        next
          case V_challenge_case_3
          solve( !Binding_VP( $V, $P, ~idV, ~idP.1, pkVP, pk(x), ~ltkVP.1
                 ) ▶₂ #j )
            case Register
