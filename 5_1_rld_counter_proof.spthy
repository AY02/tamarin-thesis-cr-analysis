lemma clone_detection_in_compromised_previous_session_both_keys [use_induction]:
  all-traces
  "∀ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i2 #i3 #i4.
    ((((((((Verify( v, p, %cP1, nP1, ch1 ) @ #i2) ∧
           (Response( p, v, %cP2, nP2, ch2 ) @ #i3)) ∧
          (Verify( v, p, %cP2, nP2, ch2 ) @ #i4)) ∧
         (#i2 < #i3)) ∧
        (#i3 < #i4)) ∧
       (¬(∃ #i. DetectResponseLoss( v, p ) @ #i))) ∧
      (¬(∃ %cP nP ch #i. ChallengeTimeout( v, p, %cP, nP, ch ) @ #i))) ∧
     (¬(∃ #i. Desync( p, v ) @ #i))) ⇒
    ((∃ #i1. (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧ (#i1 < #i2)) ∨
     (∃ #i. DetectCloning( v, p ) @ #i))"
/*
guarded formula characterizing all counter-examples:
"∃ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i2 #i3 #i4.
  (Verify( v, p, %cP1, nP1, ch1 ) @ #i2) ∧
  (Response( p, v, %cP2, nP2, ch2 ) @ #i3) ∧
  (Verify( v, p, %cP2, nP2, ch2 ) @ #i4)
 ∧
  (#i2 < #i3) ∧
  (#i3 < #i4) ∧
  (∀ #i. (DetectResponseLoss( v, p ) @ #i) ⇒ ⊥) ∧
  (∀ %cP nP ch #i.
    (ChallengeTimeout( v, p, %cP, nP, ch ) @ #i) ⇒ ⊥) ∧
  (∀ #i. (Desync( p, v ) @ #i) ⇒ ⊥) ∧
  (∀ #i1. (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i. (DetectCloning( v, p ) @ #i) ⇒ ⊥)"
*/
induction
  case non_empty_trace
  solve( Verify( v, p, %cP1, nP1, ch1 ) @ #i2 )
    case V_accept
    solve( Response( $P, $V, %cP2, nP2, ch2 ) @ #i3 )
      case P_response_sync
      solve( Verify( $V, $P, (%prev_cP.1%+%1), ~nP, ch2 ) @ #i4 )
        case V_accept
        solve( (last(#i4))  ∥
               (∃ #i. (DetectResponseLoss( $V, $P ) @ #i) ∧ ¬(last(#i)))  ∥
               (∃ %cP nP ch #i.
                 (ChallengeTimeout( $V, $P, %cP, nP, ch ) @ #i) ∧ ¬(last(#i)))  ∥
               (∃ #i. (Desync( $P, $V ) @ #i) ∧ ¬(last(#i)))  ∥
               (∃ #i1.
                 (Response( $P, $V, (%prev_cP%+%1), nP1, ch1 ) @ #i1)
                ∧
                 (¬(last(#i1))) ∧ (#i1 < #i2))  ∥
               (∃ #i. (DetectCloning( $V, $P ) @ #i) ∧ ¬(last(#i))) )
          case case_1
          solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
                 ) ▶₂ #i2 )
            case Register
            solve( !Binding_PV( $P, $V, ~idP.1, ~idV.1, pkPV, pk(x), ~ltkPV.1
                   ) ▶₂ #i3 )
              case Register
              solve( !Binding_VP( $V, $P, ~idV.1, ~idP.1, pkVP, pk(x), ~ltkVP.1
                     ) ▶₂ #i4 )
                case Register
                solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch1, 'verify_state'
                       ) ▶₁ #i2 )
                  case V_challenge_case_1
                  solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP1, ~ch>, ~ltkPV)
                         ) @ #vk.20 )
                    case c_sign
                    solve( !KU( ~ltkPV ) @ #vk.33 )
                      case Reveal_ltk_PV
                      solve( St_PV( ~idP, $P, $V, %prev_cP, prev_nP ) ▶₁ #i3 )
                        case P_response_sync
                        solve( !KU( sign(<'challenge', $V, $P, (%prev_cP%+%1), ~nP, ch2>,
                                         ~ltkVP)
                               ) @ #vk.33 )
                          case V_challenge_case_2
                          solve( (¬(#i2 < #vr.6))  ∥ ((%1%+%1) ⊏ (%prev_cP%+%1))  ∥
                                 ((%1%+%1) = (%prev_cP%+%1)) )
                            case case_1
                            solve( (¬(#i2 < #vr.6))  ∥ ((%1%+%1) ⊏ (%prev_cP%+%1)) )
                              case case_1
                              solve( (#vr.6 = #i2)  ∥ (#i2 < #vr.6) )
                                case case_1
                                solve( St_VP( ~idV, $V, $P, (%1%+%1), prev_nP, ~ch.1,
                                              'verify_state'
                                       ) ▶₁ #i4 )
                                  case V_challenge
                                  solve( !KU( sign(<'challenge', $V, $P, %1, prev_nP, ch.2>, ~ltkVP)
                                         ) @ #vk.41 )
                                    case c_sign
                                    solve( !KU( ~ltkVP ) @ #vk.42 )
                                      case Reveal_ltk_VP
                                      solve( St_PV( ~idP, $P, $V, %1, prev_nP ) ▶₁ #vr.3 )
                                        case Register
                                        solve( !KU( ~nP.1 ) @ #vk.36 )
                                          case P_response_sync
                                          solve( !KU( ~ch ) @ #vk.31 )
                                            case V_challenge
                                            solve( !KU( ~nP ) @ #vk.32 )
                                              case P_response_sync
                                              solve( !KU( ~ch.1 ) @ #vk.35 )
                                                case V_challenge
                                                solve( !KU( sign(<'response', $P, $V, (%1%+%1%+%1), 
                                                                  ~nP.1, ~ch.1>,
                                                                 ~ltkPV)
                                                       ) @ #vk.37 )
                                                  case P_response_sync
                                                  SOLVED // trace found
                                                qed
                                              qed
                                            qed
                                          qed
                                        qed
                                      qed
                                    qed
                                  qed
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma clone_detection_in_compromised_previous_session_prover_key_unreliable [use_induction]:
  all-traces
  "∀ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i2 #i3 #i4.
    (((((((((Verify( v, p, %cP1, nP1, ch1 ) @ #i2) ∧
            (Accept( v, p ) @ #i2)) ∧
           (Response( p, v, %cP2, nP2, ch2 ) @ #i3)) ∧
          (Desync( p, v ) @ #i3)) ∧
         (Verify( v, p, %cP2, nP2, ch2 ) @ #i4)) ∧
        (DetectResponseLoss( v, p ) @ #i4)) ∧
       (#i2 < #i3)) ∧
      (#i3 < #i4)) ∧
     (¬(∃ %cP nP ch #j.
         ((ChallengeTimeout( v, p, %cP, nP, ch ) @ #j) ∧ (#i2 < #j)) ∧
         (#j < #i3)))) ⇒
    (((∃ #i1. (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧ (#i1 < #i2)) ∨
      (∃ #i. DetectCloning( v, p ) @ #i)) ∨
     (∃ #i. Reveal_ltk_VP( v, p ) @ #i))"
/*
guarded formula characterizing all counter-examples:
"∃ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i2 #i3 #i4.
  (Verify( v, p, %cP1, nP1, ch1 ) @ #i2) ∧
  (Accept( v, p ) @ #i2) ∧
  (Response( p, v, %cP2, nP2, ch2 ) @ #i3) ∧
  (Desync( p, v ) @ #i3) ∧
  (Verify( v, p, %cP2, nP2, ch2 ) @ #i4) ∧
  (DetectResponseLoss( v, p ) @ #i4)
 ∧
  (#i2 < #i3) ∧
  (#i3 < #i4) ∧
  (∀ %cP nP ch #j.
    (ChallengeTimeout( v, p, %cP, nP, ch ) @ #j)
   ⇒
    ((¬(#i2 < #j)) ∨ (¬(#j < #i3)))) ∧
  (∀ #i1. (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i. (DetectCloning( v, p ) @ #i) ⇒ ⊥) ∧
  (∀ #i. (Reveal_ltk_VP( v, p ) @ #i) ⇒ ⊥)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( Verify( $V, $P, %cP1, nP1, ch1 ) @ #i2 )
    case V_accept
    solve( Response( $P, $V, %cP2, nP2, ch2 ) @ #i3 )
      case P_response_desync
      solve( Verify( $V, $P, (%prev_cP.1%+%1), ~nP.1, ch2 ) @ #i4 )
        case V_detect_response_loss
        solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
               ) ▶₂ #i2 )
          case Register
          solve( !Binding_PV( $P, $V, ~idP.1, ~idV.1, pkPV, pk(x), ~ltkPV.1
                 ) ▶₂ #i3 )
            case Register
            solve( St_VP( ~idV.1, $V, $P, %prev_cP.2, prev_nP.2, ch2,
                          'verify_state'
                   ) ▶₁ #i4 )
              case V_challenge_case_1
              by contradiction /* cyclic */
            next
              case V_challenge_case_2
              by contradiction /* cyclic */
            next
              case V_challenge_case_3
              simplify
              solve( !Binding_VP( $V, $P, ~idV, ~idP.1, pkVP, pk(x), ~ltkVP.1
                     ) ▶₂ #i4 )
                case Register
                solve( (last(#i4))  ∥
                       (∃ %cP nP ch #j.
                         (ChallengeTimeout( $V, $P, %cP, nP, ch ) @ #j)
                        ∧
                         (¬(last(#j))) ∧ (#i2 < #j) ∧ (#j < #i3))  ∥
                       (∃ #i1.
                         (Response( $P, $V, (%prev_cP%+%1), nP, ch ) @ #i1)
                        ∧
                         (¬(last(#i1))) ∧ (#i1 < #i2))  ∥
                       (∃ #i. (DetectCloning( $V, $P ) @ #i) ∧ ¬(last(#i)))  ∥
                       (∃ #i. (Reveal_ltk_VP( $V, $P ) @ #i) ∧ ¬(last(#i))) )
                  case case_1
                  solve( !KU( ~nP.1 ) @ #vk.35 )
                    case P_response_desync
                    solve( !KU( ~ch.1 ) @ #vk.31 )
                      case V_challenge
                      solve( !KU( sign(<'response', $P, $V, (%prev_cP%+%1), nP, ch>,
                                       ~ltkPV)
                             ) @ #vk.28 )
                        case P_response_desync
                        by contradiction /* from formulas */
                      next
                        case P_response_sync
                        by contradiction /* from formulas */
                      next
                        case c_sign
                        solve( !KU( ~ltkPV ) @ #vk.43 )
                          case Reveal_ltk_PV
                          solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                                            sent_prev_nP, ~ch.1>,
                                           ~ltkVP)
                                 ) @ #vk.35 )
                            case V_challenge
                            solve( (#vr.2 = #i2)  ∥ (#i2 < #vr.2) )
                              case case_1
                              solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state'
                                     ) ▶₁ #i2 )
                                case V_challenge_case_1
                                solve( !KU( ~ch ) @ #vk.28 )
                                  case V_challenge
                                  solve( St_PV( ~idP, $P, $V, %prev_cP, prev_nP ) ▶₁ #i3 )
                                    case P_response_desync
                                    solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                                                      sent_prev_nP, ch.2>,
                                                     ~ltkVP)
                                           ) @ #vk.41 )
                                      case V_challenge_case_1
                                      solve( St_PV( ~idP, $P, $V, %prev_cP, prev_nP ) ▶₁ #vr.23 )
                                        case P_response_desync
                                        solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                                                          sent_prev_nP, ch.2>,
                                                         ~ltkVP)
                                               ) @ #vk.50 )
                                          case V_challenge_case_1
                                          by contradiction /* cyclic */
                                        next
                                          case V_challenge_case_2
                                          simplify
                                          solve( (#vr.28 = #i2)  ∥ (#i2 < #vr.28) )
                                            case case_2
                                            by contradiction /* cyclic */
                                          qed
                                        next
                                          case c_sign
                                          solve( !KU( ~ltkVP ) @ #vk.51 )
