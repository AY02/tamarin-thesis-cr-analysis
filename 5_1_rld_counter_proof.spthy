lemma executability_honest_single_session:
  exists-trace
  "∃ p v #i.
    (((Accept( v, p ) @ #i) ∧ (¬(∃ #j. Reveal_ltk_PV( p, v ) @ #j))) ∧
     (¬(∃ #j. Reveal_ltk_VP( v, p ) @ #j))) ∧
    (¬(∃ %cP nP ch #i.1.
        ChallengeTimeout( v, p, %cP, nP, ch ) @ #i.1))"
/*
guarded formula characterizing all satisfying traces:
"∃ p v #i.
  (Accept( v, p ) @ #i)
 ∧
  (∀ #j. (Reveal_ltk_PV( p, v ) @ #j) ⇒ ⊥) ∧
  (∀ #j. (Reveal_ltk_VP( v, p ) @ #j) ⇒ ⊥) ∧
  (∀ %cP nP ch #i.1.
    (ChallengeTimeout( v, p, %cP, nP, ch ) @ #i.1) ⇒ ⊥)"
*/
simplify
solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
       ) ▶₂ #i )
  case Register
  solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state'
         ) ▶₁ #i )
    case V_challenge_case_1
    solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP, ~ch>, ~ltkPV)
           ) @ #vk.12 )
      case P_response_sync
      solve( !KU( sign(<'challenge', $V, $P, %1, prev_nP, ~ch>, ~ltkVP)
             ) @ #vk.22 )
        case V_challenge
        solve( St_PV( ~idP, $P, $V, %1, 'null' ) ▶₁ #vr.2 )
          case Register
          solve( !KU( ~ch ) @ #vk.17 )
            case V_challenge
            solve( !KU( ~nP ) @ #vk.17 )
              case P_response_sync
              SOLVED // trace found
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma executability_honest_consecutive_sessions:
  exists-trace
  "∃ p v #i1 #i2.
    (((((Accept( v, p ) @ #i1) ∧ (Accept( v, p ) @ #i2)) ∧
       (#i1 < #i2)) ∧
      (¬(∃ #i. Reveal_ltk_PV( p, v ) @ #i))) ∧
     (¬(∃ #i. Reveal_ltk_VP( v, p ) @ #i))) ∧
    (¬(∃ %cP nP ch #i. ChallengeTimeout( v, p, %cP, nP, ch ) @ #i))"
/*
guarded formula characterizing all satisfying traces:
"∃ p v #i1 #i2.
  (Accept( v, p ) @ #i1) ∧ (Accept( v, p ) @ #i2)
 ∧
  (#i1 < #i2) ∧
  (∀ #i. (Reveal_ltk_PV( p, v ) @ #i) ⇒ ⊥) ∧
  (∀ #i. (Reveal_ltk_VP( v, p ) @ #i) ⇒ ⊥) ∧
  (∀ %cP nP ch #i. (ChallengeTimeout( v, p, %cP, nP, ch ) @ #i) ⇒ ⊥)"
*/
simplify
solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
       ) ▶₂ #i1 )
  case Register
  solve( !Binding_VP( $V, $P, ~idV.1, ~idP.1, pkVP, pk(x), ~ltkVP.1
         ) ▶₂ #i2 )
    case Register
    solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state'
           ) ▶₁ #i1 )
      case V_challenge_case_1
      solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch.1, 'verify_state'
             ) ▶₁ #i2 )
        case V_challenge_case_3
        solve( (¬(#i1 < #vr.3))  ∥ ((%1%+%1) ⊏ (%prev_cP%+%1))  ∥
               ((%1%+%1) = (%prev_cP%+%1)) )
          case case_1
          solve( (¬(#i1 < #vr.3))  ∥ ((%1%+%1) ⊏ (%prev_cP%+%1)) )
            case case_1
            solve( (#vr.3 = #i1)  ∥ (#i1 < #vr.3) )
              case case_1
              solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP, ~ch>, ~ltkPV)
                     ) @ #vk.16 )
                case P_response_sync
                solve( !KU( sign(<'response', $P, $V, (%1%+%1%+%1), nP.1, ~ch.1>,
                                 ~ltkPV)
                       ) @ #vk.25 )
                  case P_response_sync
                  solve( !KU( sign(<'challenge', $V, $P, %1, prev_nP, ~ch>, ~ltkVP)
                         ) @ #vk.37 )
                    case V_challenge
                    solve( St_PV( ~idP, $P, $V, %1, 'null' ) ▶₁ #vr.3 )
                      case Register
                      solve( !KU( sign(<'challenge', $V, $P, (%1%+%1), prev_nP, ~ch.1>,
                                       ~ltkVP)
                             ) @ #vk.40 )
                        case V_challenge
                        solve( St_PV( ~idP, $P, $V, (%1%+%1), ~nP ) ▶₁ #vr.5 )
                          case P_response_sync
                          solve( !KU( ~ch ) @ #vk.29 )
                            case V_challenge
                            solve( !KU( ~ch.1 ) @ #vk.36 )
                              case V_challenge
                              solve( !KU( ~nP ) @ #vk.31 )
                                case P_response_sync
                                solve( !KU( ~nP.1 ) @ #vk.36 )
                                  case P_response_sync
                                  SOLVED // trace found
                                qed
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma executability_cloning:
  exists-trace "∃ v p #i. DetectCloning( v, p ) @ #i"
/*
guarded formula characterizing all satisfying traces:
"∃ v p #i. (DetectCloning( v, p ) @ #i)"
*/
simplify
solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state'
       ) ▶₁ #i )
  case V_challenge_case_1
  solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
         ) ▶₂ #i )
    case Register
    solve( !KU( sign(<'response', $P, $V, %1, nP, ~ch>, ~ltkPV)
           ) @ #vk.12 )
      case c_sign
      solve( !KU( ~ltkPV ) @ #vk.13 )
        case Reveal_ltk_PV
        solve( !KU( ~ch ) @ #vk.13 )
          case V_challenge
          SOLVED // trace found
        qed
      qed
    qed
  qed
qed

lemma executability_honest_response_loss:
  exists-trace
  "∃ v p #i.
    ((DetectResponseLoss( v, p ) @ #i) ∧
     (¬(∃ #j. Reveal_ltk_PV( p, v ) @ #j))) ∧
    (¬(∃ #j. Reveal_ltk_VP( v, p ) @ #j))"
/*
guarded formula characterizing all satisfying traces:
"∃ v p #i.
  (DetectResponseLoss( v, p ) @ #i)
 ∧
  (∀ #j. (Reveal_ltk_PV( p, v ) @ #j) ⇒ ⊥) ∧
  (∀ #j. (Reveal_ltk_VP( v, p ) @ #j) ⇒ ⊥)"
*/
simplify
solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state'
       ) ▶₁ #i )
  case V_challenge_case_2
  solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
         ) ▶₂ #i )
    case Register
    solve( !KU( sign(<'response', $P, $V, %cP, nP, ~ch>, ~ltkPV)
           ) @ #vk.12 )
      case P_response_desync
      solve( St_VP( ~idV, $V, $P, %prev_cP.1, prev_nP, ~ch.1,
                    'verify_state'
             ) ▶₀ #vr.1 )
        case V_challenge_case_1
        solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                          sent_prev_nP, ~ch>,
                         ~ltkVP)
               ) @ #vk.22 )
          case V_challenge
          solve( St_PV( ~idP, $P, $V, %prev_cP, prev_nP ) ▶₁ #vr.3 )
            case P_response_sync
            solve( !KU( sign(<'challenge', $V, $P, %prev_cP, prev_nP, ch.2>,
                             ~ltkVP)
                   ) @ #vk.32 )
              case V_challenge_case_1
              solve( St_PV( ~idP, $P, $V, %1, 'null' ) ▶₁ #vr.7 )
                case Register
                solve( !KU( ~ch ) @ #vk.22 )
                  case V_challenge
                  solve( !KU( ~nP ) @ #vk.22 )
                    case P_response_desync
                    solve( !KU( ~ch.1 ) @ #vk.30 )
                      case V_challenge
                      SOLVED // trace found
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma prover_injective_agreement:
  all-traces
  "∀ p v %cP nP ch #i2.
    ((((Verify( v, p, %cP, nP, ch ) @ #i2) ∧ (Accept( v, p ) @ #i2)) ∧
      (¬(∃ #i. Reveal_ltk_PV( p, v ) @ #i))) ∧
     (¬(∃ #i. Reveal_ltk_VP( v, p ) @ #i))) ⇒
    ((∃ #i1. (Response( p, v, %cP, nP, ch ) @ #i1) ∧ (#i1 < #i2)) ∧
     (¬(∃ p_i v_i #i.
         ((Verify( v_i, p_i, %cP, nP, ch ) @ #i) ∧
          (Accept( v_i, p_i ) @ #i)) ∧
         (¬(#i = #i2)))))"
/*
guarded formula characterizing all counter-examples:
"∃ p v %cP nP ch #i2.
  (Verify( v, p, %cP, nP, ch ) @ #i2) ∧ (Accept( v, p ) @ #i2)
 ∧
  (∀ #i. (Reveal_ltk_PV( p, v ) @ #i) ⇒ ⊥) ∧
  (∀ #i. (Reveal_ltk_VP( v, p ) @ #i) ⇒ ⊥) ∧
  (((∀ #i1. (Response( p, v, %cP, nP, ch ) @ #i1) ⇒ ¬(#i1 < #i2)) ∨
    (∃ p_i v_i #i.
      (Verify( v_i, p_i, %cP, nP, ch ) @ #i) ∧ (Accept( v_i, p_i ) @ #i)
     ∧
      ¬(#i = #i2))))"
*/
simplify
solve( Verify( $V, $P, %cP.2, nP.2, ch.2 ) @ #i2 )
  case V_accept
  solve( (∀ #i1.
           (Response( $P, $V, (%prev_cP%+%1), nP, ch ) @ #i1)
          ⇒
           ¬(#i1 < #i2))  ∥
         (∃ p_i v_i #i.
           (Verify( v_i, p_i, (%prev_cP%+%1), nP, ch ) @ #i) ∧
           (Accept( v_i, p_i ) @ #i)
          ∧
           ¬(#i = #i2)) )
    case case_1
    solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
           ) ▶₂ #i2 )
      case Register
      solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state'
             ) ▶₁ #i2 )
        case V_challenge_case_1
        solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP, ~ch>, ~ltkPV)
               ) @ #vk.12 )
          case P_response_desync
          by contradiction /* contradictory subterm store */
        next
          case P_response_sync
          by contradiction /* from formulas */
        next
          case c_sign
          solve( !KU( ~ltkPV ) @ #vk.13 )
            case Reveal_ltk_PV
            by contradiction /* from formulas */
          qed
        qed
      next
        case V_challenge_case_2
        solve( !KU( sign(<'response', $P, $V, (%prev_cP%+%1), nP, ~ch>,
                         ~ltkPV)
               ) @ #vk.12 )
          case P_response_desync
          by contradiction /* from formulas */
        next
          case P_response_sync
          by contradiction /* from formulas */
        next
          case c_sign
          solve( !KU( ~ltkPV ) @ #vk.13 )
            case Reveal_ltk_PV
            by contradiction /* from formulas */
          qed
        qed
      next
        case V_challenge_case_3
        solve( !KU( sign(<'response', $P, $V, (%prev_cP%+%1%+%1), nP, ~ch>,
                         ~ltkPV)
               ) @ #vk.15 )
          case P_response_desync
          by contradiction /* from formulas */
        next
          case P_response_sync
          by contradiction /* from formulas */
        next
          case c_sign
          solve( !KU( ~ltkPV ) @ #vk.23 )
            case Reveal_ltk_PV
            by contradiction /* from formulas */
          qed
        qed
      qed
    qed
  next
    case case_2
    solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
           ) ▶₂ #i2 )
      case Register
      solve( Verify( $V, $P, (%prev_cP.1%+%1), nP.1, ch.1 ) @ #i )
        case V_accept
        solve( (#i < #i2)  ∥ (#i2 < #i) )
          case case_1
          solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
                 ) ▶₂ #i )
            case Register
            solve( St_VP( ~idV.1, $V.1, $P.1, %prev_cP, prev_nP.1, ch,
                          'verify_state'
                   ) ▶₁ #i2 )
              case V_challenge_case_1
              solve( !KU( sign(<'response', $P.1, $V.1, (%1%+%1), nP, ~ch>,
                               ~ltkPV.1)
                     ) @ #vk.16 )
                case P_response_desync
                by contradiction /* contradictory subterm store */
              next
                case P_response_sync
                solve( St_VP( ~idV, $V, $P, %1, prev_nP, ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV.1 ) @ #vk.20 )
                  case Reveal_ltk_PV
                  by contradiction /* from formulas */
                qed
              qed
            next
              case V_challenge_case_2
              solve( !KU( sign(<'response', $P.1, $V.1, (%prev_cP%+%1), nP, ~ch>,
                               ~ltkPV.1)
                     ) @ #vk.16 )
                case P_response_desync
                solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_sync
                solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV.1 ) @ #vk.20 )
                  case Reveal_ltk_PV
                  by contradiction /* from formulas */
                qed
              qed
            next
              case V_challenge_case_3
              solve( !KU( sign(<'response', $P.1, $V.1, (%prev_cP%+%1%+%1), nP, 
                                ~ch>,
                               ~ltkPV.1)
                     ) @ #vk.19 )
                case P_response_desync
                solve( St_VP( ~idV, $V, $P, (%prev_cP%+%1), prev_nP, ~ch,
                              'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_sync
                solve( St_VP( ~idV, $V, $P, (%prev_cP%+%1), prev_nP, ~ch,
                              'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV.1 ) @ #vk.30 )
                  case Reveal_ltk_PV
                  by contradiction /* from formulas */
                qed
              qed
            qed
          qed
        next
          case case_2
          solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
                 ) ▶₂ #i )
            case Register
            solve( St_VP( ~idV.1, $V.1, $P.1, %prev_cP, prev_nP.1, ch,
                          'verify_state'
                   ) ▶₁ #i2 )
              case V_challenge_case_1
              solve( !KU( sign(<'response', $P.1, $V.1, (%1%+%1), nP, ~ch>,
                               ~ltkPV.1)
                     ) @ #vk.16 )
                case P_response_desync
                by contradiction /* contradictory subterm store */
              next
                case P_response_sync
                solve( St_VP( ~idV, $V, $P, %1, prev_nP, ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV.1 ) @ #vk.20 )
                  case Reveal_ltk_PV
                  by contradiction /* from formulas */
                qed
              qed
            next
              case V_challenge_case_2
              solve( !KU( sign(<'response', $P.1, $V.1, (%prev_cP%+%1), nP, ~ch>,
                               ~ltkPV.1)
                     ) @ #vk.16 )
                case P_response_desync
                solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_sync
                solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~ch, 'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV.1 ) @ #vk.20 )
                  case Reveal_ltk_PV
                  by contradiction /* from formulas */
                qed
              qed
            next
              case V_challenge_case_3
              solve( !KU( sign(<'response', $P.1, $V.1, (%prev_cP%+%1%+%1), nP, 
                                ~ch>,
                               ~ltkPV.1)
                     ) @ #vk.19 )
                case P_response_desync
                solve( St_VP( ~idV, $V, $P, (%prev_cP%+%1), prev_nP, ~ch,
                              'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_sync
                solve( St_VP( ~idV, $V, $P, (%prev_cP%+%1), prev_nP, ~ch,
                              'verify_state'
                       ) ▶₁ #i )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV.1 ) @ #vk.30 )
                  case Reveal_ltk_PV
                  by contradiction /* from formulas */
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma clone_detection_soundness:
  all-traces
  "∀ p v #i2.
    (DetectCloning( v, p ) @ #i2) ⇒
    ((∃ #i1. (Reveal_ltk_PV( p, v ) @ #i1) ∧ (#i1 < #i2)) ∨
     (∃ #i1. (Reveal_ltk_VP( v, p ) @ #i1) ∧ (#i1 < #i2)))"
/*
guarded formula characterizing all counter-examples:
"∃ p v #i2.
  (DetectCloning( v, p ) @ #i2)
 ∧
  (∀ #i1. (Reveal_ltk_PV( p, v ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i1. (Reveal_ltk_VP( v, p ) @ #i1) ⇒ ¬(#i1 < #i2))"
*/
simplify
solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state'
       ) ▶₁ #i2 )
  case V_challenge_case_1
  solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
         ) ▶₂ #i2 )
    case Register
    solve( !KU( sign(<'response', $P, $V, %1, nP, ~ch>, ~ltkPV)
           ) @ #vk.12 )
      case c_sign
      solve( !KU( ~ltkPV ) @ #vk.13 )
        case Reveal_ltk_PV
        by contradiction /* from formulas */
      qed
    qed
  qed
next
  case V_challenge_case_2
  solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
         ) ▶₂ #i2 )
    case Register
    solve( !KU( sign(<'response', $P, $V, %cP, nP, ~ch>, ~ltkPV)
           ) @ #vk.12 )
      case P_response_desync
      solve( St_VP( ~idV, $V, $P, %prev_cP.1, prev_nP, ~ch.1,
                    'verify_state'
             ) ▶₀ #vr.1 )
        case V_challenge_case_1
        by contradiction /* contradictory subterm store */
      next
        case V_challenge_case_2
        solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                          sent_prev_nP, ~ch>,
                         ~ltkVP)
               ) @ #vk.22 )
          case V_challenge
          by contradiction /* contradictory subterm store */
        next
          case c_sign
          solve( !KU( ~ltkVP ) @ #vk.23 )
            case Reveal_ltk_VP
            by contradiction /* from formulas */
          qed
        qed
      next
        case V_challenge_case_3
        solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                          sent_prev_nP, ~ch>,
                         ~ltkVP)
               ) @ #vk.25 )
          case V_challenge
          by contradiction /* contradictory subterm store */
        next
          case c_sign
          solve( !KU( ~ltkVP ) @ #vk.33 )
            case Reveal_ltk_VP
            by contradiction /* from formulas */
          qed
        qed
      qed
    next
      case P_response_sync
      solve( St_VP( ~idV, $V, $P, %prev_cP.1, prev_nP, ~ch.1,
                    'verify_state'
             ) ▶₀ #vr.1 )
        case V_challenge_case_1
        by contradiction /* contradictory subterm store */
      next
        case V_challenge_case_2
        solve( !KU( sign(<'challenge', $V, $P, %prev_cP, prev_nP.1, ~ch>,
                         ~ltkVP)
               ) @ #vk.22 )
          case V_challenge
          by contradiction /* contradictory subterm store */
        next
          case c_sign
          solve( !KU( ~ltkVP ) @ #vk.23 )
            case Reveal_ltk_VP
            by contradiction /* from formulas */
          qed
        qed
      next
        case V_challenge_case_3
        solve( !KU( sign(<'challenge', $V, $P, %prev_cP, prev_nP.1, ~ch>,
                         ~ltkVP)
               ) @ #vk.25 )
          case V_challenge
          by contradiction /* contradictory subterm store */
        next
          case c_sign
          solve( !KU( ~ltkVP ) @ #vk.33 )
            case Reveal_ltk_VP
            by contradiction /* from formulas */
          qed
        qed
      qed
    next
      case c_sign
      solve( !KU( ~ltkPV ) @ #vk.13 )
        case Reveal_ltk_PV
        by contradiction /* from formulas */
      qed
    qed
  qed
next
  case V_challenge_case_3
  solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
         ) ▶₂ #i2 )
    case Register
    solve( !KU( sign(<'response', $P, $V, %cP, nP, ~ch>, ~ltkPV)
           ) @ #vk.16 )
      case P_response_desync
      solve( !KU( sign(<'response', $P, $V, (%prev_cP.1%+%1), prev_nP, 
                        ch.1>,
                       ~ltkPV)
             ) @ #vk.25 )
        case P_response_desync
        by contradiction /* cyclic */
      next
        case P_response_sync
        by contradiction /* cyclic */
      next
        case c_sign
        solve( !KU( ~ltkPV ) @ #vk.33 )
          case Reveal_ltk_PV
          by contradiction /* from formulas */
        qed
      qed
    next
      case P_response_sync
      solve( !KU( sign(<'response', $P, $V, (%prev_cP.1%+%1), prev_nP, 
                        ch.1>,
                       ~ltkPV)
             ) @ #vk.25 )
        case P_response_desync
        by contradiction /* cyclic */
      next
        case P_response_sync
        by contradiction /* cyclic */
      next
        case c_sign
        solve( !KU( ~ltkPV ) @ #vk.33 )
          case Reveal_ltk_PV
          by contradiction /* from formulas */
        qed
      qed
    next
      case c_sign
      solve( !KU( ~ltkPV ) @ #vk.23 )
        case Reveal_ltk_PV
        by contradiction /* from formulas */
      qed
    qed
  qed
qed

lemma response_loss_detection_soundness:
  all-traces
  "∀ p v #i3.
    (((DetectResponseLoss( v, p ) @ #i3) ∧
      (¬(∃ #i. (Reveal_ltk_PV( p, v ) @ #i) ∧ (#i < #i3)))) ∧
     (¬(∃ #i. (Reveal_ltk_VP( v, p ) @ #i) ∧ (#i < #i3)))) ⇒
    (∃ %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
      (((Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧
        (Response( p, v, %cP2, nP2, ch2 ) @ #i2)) ∧
       (#i1 < #i2)) ∧
      (#i2 < #i3))"
/*
guarded formula characterizing all counter-examples:
"∃ p v #i3.
  (DetectResponseLoss( v, p ) @ #i3)
 ∧
  (∀ #i. (Reveal_ltk_PV( p, v ) @ #i) ⇒ ¬(#i < #i3)) ∧
  (∀ #i. (Reveal_ltk_VP( v, p ) @ #i) ⇒ ¬(#i < #i3)) ∧
  (∀ %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
    (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧
    (Response( p, v, %cP2, nP2, ch2 ) @ #i2)
   ⇒
    ((¬(#i1 < #i2)) ∨ (¬(#i2 < #i3))))"
*/
simplify
solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state'
       ) ▶₁ #i3 )
  case V_challenge_case_1
  solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
         ) ▶₂ #i3 )
    case Register
    solve( !KU( sign(<'response', $P, $V, %cP, nP, ~ch>, ~ltkPV)
           ) @ #vk.12 )
      case P_response_desync
      solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                        sent_prev_nP, ~ch>,
                       ~ltkVP)
             ) @ #vk.22 )
        case V_challenge
