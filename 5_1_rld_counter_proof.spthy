                  qed
                qed
              qed
            qed
          next
            case case_2
            by contradiction /* from formulas */
          qed
        qed
      next
        case V_challenge_timeout
        solve( !Binding_VP( $V, $P, ~idV, ~idP.1, pkVP, pkPV, ~ltkVP.1
               ) ▶₁ #i2 )
          case Register
          solve( (last(#i2))  ∥ (%cP1 = %cP2) )
            case case_1
            solve( St_VP( ~idV, $V, $P, %cP1, nP1, ~ch.2, 'verify_state'
                   ) ▶₀ #vr )
              case V_challenge_case_1
              by contradiction /* from formulas */
            next
              case V_challenge_case_2
              solve( St_VP( ~idV, $V, $P, %cP2, nP2, ~ch.3, 'verify_state'
                     ) ▶₀ #vr.2 )
                case V_challenge_case_1
                by contradiction /* cyclic */
              next
                case V_challenge_case_2
                by contradiction /* from formulas */
              next
                case V_challenge_case_3
                by contradiction /* from formulas */
              qed
            next
              case V_challenge_case_3
              simplify
              solve( St_VP( ~idV, $V, $P, %cP2, nP2, ~ch.3, 'verify_state'
                     ) ▶₀ #vr.2 )
                case V_challenge_case_1
                by contradiction /* cyclic */
              next
                case V_challenge_case_2
                by contradiction /* from formulas */
              next
                case V_challenge_case_3
                by contradiction /* from formulas */
              qed
            qed
          next
            case case_2
            by contradiction /* from formulas */
          qed
        qed
      qed
    qed
  qed
qed

lemma response_monotonicity [reuse, use_induction]:
  all-traces
  "∀ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
    (((Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧
      (Response( p, v, %cP2, nP2, ch2 ) @ #i2)) ∧
     (#i1 < #i2)) ⇒
    (%cP1 ⊏ %cP2)"
/*
guarded formula characterizing all counter-examples:
"∃ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
  (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧
  (Response( p, v, %cP2, nP2, ch2 ) @ #i2)
 ∧
  (#i1 < #i2) ∧ (¬(%cP1 ⊏ %cP2))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  simplify
  solve( Response( p, v, %cP1, nP1, ch1 ) @ #i1 )
    case P_response_desync
    simplify
    solve( Response( $P, $V, %cP2, nP2, ch2 ) @ #i2 )
      case P_response_desync
      simplify
      solve( !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pk(x), ~ltkPV
             ) ▶₂ #i1 )
        case Register
        solve( !Binding_PV( $P, $V, ~idP.1, ~idV.1, pkPV, pk(x), ~ltkPV.1
               ) ▶₂ #i2 )
          case Register
          by contradiction /* cyclic */
        qed
      qed
    next
      case P_response_sync
      simplify
      solve( !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pk(x), ~ltkPV
             ) ▶₂ #i1 )
        case Register
        solve( !Binding_PV( $P, $V, ~idP.1, ~idV.1, pkPV, pk(x), ~ltkPV.1
               ) ▶₂ #i2 )
          case Register
          by contradiction /* cyclic */
        qed
      qed
    qed
  next
    case P_response_sync
    simplify
    solve( Response( $P, $V, %cP2, nP2, ch2 ) @ #i2 )
      case P_response_desync
      simplify
      solve( !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pk(x), ~ltkPV
             ) ▶₂ #i1 )
        case Register
        solve( !Binding_PV( $P, $V, ~idP.1, ~idV.1, pkPV, pk(x), ~ltkPV.1
               ) ▶₂ #i2 )
          case Register
          by contradiction /* cyclic */
        qed
      qed
    next
      case P_response_sync
      simplify
      solve( !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pk(x), ~ltkPV
             ) ▶₂ #i1 )
        case Register
        solve( !Binding_PV( $P, $V, ~idP.1, ~idV.1, pkPV, pk(x), ~ltkPV.1
               ) ▶₂ #i2 )
          case Register
          by contradiction /* cyclic */
        qed
      qed
    qed
  qed
qed

lemma state_vp_monotonicity [reuse, use_induction]:
  all-traces
  "∀ v p %cP1 nP ch %cP2 #i1 #i2.
    (((Verify( v, p, %cP1, nP, ch ) @ #i1) ∧
      (CounterVP( v, p, %cP2 ) @ #i2)) ∧
     (#i1 < #i2)) ⇒
    ((%cP1 ⊏ %cP2) ∨ (%cP1 = %cP2))"
/*
guarded formula characterizing all counter-examples:
"∃ v p %cP1 nP ch %cP2 #i1 #i2.
  (Verify( v, p, %cP1, nP, ch ) @ #i1) ∧
  (CounterVP( v, p, %cP2 ) @ #i2)
 ∧
  (#i1 < #i2) ∧ (¬(%cP1 ⊏ %cP2)) ∧ (¬(%cP1 = %cP2))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  simplify
  solve( Verify( v, p, %cP1, nP, ch ) @ #i1 )
    case V_accept
    simplify
    solve( CounterVP( $V, $P, %cP2 ) @ #i2 )
      case V_accept
      simplify
      solve( (last(#i2))  ∥ ((%prev_cP%+%1) = (%prev_cP.1%+%1)) )
        case case_1
        solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
               ) ▶₂ #i1 )
          case Register
          solve( !Binding_VP( $V, $P, ~idV.1, ~idP.1, pkVP, pk(x), ~ltkVP.1
                 ) ▶₂ #i2 )
            case Register
            solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state'
                   ) ▶₁ #i1 )
              case V_challenge_case_1
              by contradiction /* from formulas */
            next
              case V_challenge_case_2
              solve( !KU( sign(<'response', $P, $V, (%prev_cP%+%1), nP, ~ch>,
                               ~ltkPV)
                     ) @ #vk.16 )
                case P_response_desync
                solve( St_VP( ~idV, $V, $P, %prev_cP.1, prev_nP.1, ch.1,
                              'verify_state'
                       ) ▶₁ #i2 )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_sync
                solve( St_VP( ~idV, $V, $P, %prev_cP.1, prev_nP.1, ch.1,
                              'verify_state'
                       ) ▶₁ #i2 )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV ) @ #vk.23 )
                  case Reveal_ltk_PV
                  solve( St_VP( ~idV, $V, $P, %prev_cP.1, prev_nP.1, ch.1,
                                'verify_state'
                         ) ▶₁ #i2 )
                    case V_challenge
                    by contradiction /* cyclic */
                  qed
                qed
              qed
            next
              case V_challenge_case_3
              simplify
              solve( !KU( sign(<'response', $P, $V, (%prev_cP%+%1%+%1), nP, ~ch>,
                               ~ltkPV)
                     ) @ #vk.20 )
                case P_response_desync
                solve( St_VP( ~idV, $V, $P, %prev_cP.1, prev_nP.1, ch.1,
                              'verify_state'
                       ) ▶₁ #i2 )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case P_response_sync
                solve( St_VP( ~idV, $V, $P, %prev_cP.1, prev_nP.1, ch.1,
                              'verify_state'
                       ) ▶₁ #i2 )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV ) @ #vk.33 )
                  case Reveal_ltk_PV
                  solve( St_VP( ~idV, $V, $P, %prev_cP.1, prev_nP.1, ch.1,
                                'verify_state'
                         ) ▶₁ #i2 )
                    case V_challenge
                    by contradiction /* cyclic */
                  qed
                qed
              qed
            qed
          qed
        qed
      next
        case case_2
        by contradiction /* from formulas */
      qed
    next
      case V_challenge
      solve( (last(#i2))  ∥ ((%prev_cP%+%1) = %cP2) )
        case case_1
        solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
               ) ▶₂ #i1 )
          case Register
          solve( St_VP( ~idV.1, $V, $P, %cP2, prev_nP.1, ~inj_n.1,
                        'challenge_state'
                 ) ▶₀ #i2 )
            case Register
            by contradiction /* cyclic */
          next
            case V_accept
            simplify
            solve( !Binding_VP( $V, $P, ~idV, ~idP.1, pkVP, pkPV, ~ltkVP.1
                   ) ▶₁ #i2 )
              case Register
              solve( (#vr.1 = #i1)  ∥ (#i1 < #vr.1)  ∥
                     ((%prev_cP.1%+%1) ⊏ (%prev_cP%+%1))  ∥
                     ((%prev_cP.1%+%1) = (%prev_cP%+%1)) )
                case case_1
                by contradiction /* from formulas */
              next
                case case_2
                by contradiction /* from formulas */
              next
                case case_3
                solve( (#i1 = #vr.1)  ∥ (#vr.1 < #i1)  ∥
                       ((%prev_cP%+%1) = (%prev_cP.1%+%1)) )
                  case case_1
                  by contradiction /* contradictory subterm store */
                next
                  case case_2
                  by contradiction /* cyclic */
                next
                  case case_3
                  by contradiction /* contradictory subterm store */
                qed
              next
                case case_4
                by contradiction /* from formulas */
              qed
            qed
          next
            case V_challenge_timeout
            by contradiction /* from formulas */
          qed
        qed
      next
        case case_2
        by contradiction /* from formulas */
      qed
    next
      case V_challenge_timeout
