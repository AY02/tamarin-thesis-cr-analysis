                     ) @ #vk.12 )
                case P_response_desync
                solve( St_VP( ~idV, $V, $P, %cP2, prev_nP.1, ~ch.1, 'verify_state'
                       ) ▶₀ #i2 )
                  case V_challenge_case_1
