theory 5_1_rld_counter

begin

// Function signature and definition of the equational theory E

builtins: natural-numbers
functions: fst/1, pair/2, pk/1, sign/2, snd/1, true/0, verify/3
equations:
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    verify(sign(x.1, x.2), x.1, pk(x.2)) = true

heuristic: I

/* looping facts with injective instances: St_PV/5, St_VP/7 */

restriction Equality:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

  /*
  expanded formula:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  */

restriction LessThan:
  "∀ %x %y #i. (LessThan( %x, %y ) @ #i) ⇒ (%x ⊏ %y)"
  // safety formula

  /*
  expanded formula:
  "∀ %x %y #i. (LessThan( %x, %y ) @ #i) ⇒ (%x ⊏ %y)"
  */

restriction GreaterThan:
  "∀ %x %y #i. (GreaterThan( %x, %y ) @ #i) ⇒ (%y ⊏ %x)"
  // safety formula

  /*
  expanded formula:
  "∀ %x %y #i. (GreaterThan( %x, %y ) @ #i) ⇒ (%y ⊏ %x)"
  */

restriction RegisterOnce:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( p, v ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( p, v ) @ #j)) ⇒ (#i = #j)"
  */

restriction NoReplayChallenge:
  "∀ p v %cP1 nP1 %cP2 nP2 ch #i #j.
    ((Response( p, v, %cP1, nP1, ch ) @ #i) ∧
     (Response( p, v, %cP2, nP2, ch ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ p v %cP1 nP1 %cP2 nP2 ch #i #j.
    ((Response( p, v, %cP1, nP1, ch ) @ #i) ∧
     (Response( p, v, %cP2, nP2, ch ) @ #j)) ⇒
    (#i = #j)"
  */

rule (modulo E) Register:
   [ Fr( ~ltkPV ), Fr( ~ltkVP ), Fr( ~idP ), Fr( ~idV ), Fr( ~inj_n )
   ]
  --[ Register( $P, $V ), Init_prev_nP( ~idV, 'null' ) ]->
   [
   !Binding_PV( $P, $V, ~idP, ~idV, pk(~ltkPV), pk(~ltkVP), ~ltkPV ),
   !Binding_VP( $V, $P, ~idV, ~idP, pk(~ltkVP), pk(~ltkPV), ~ltkVP ),
   St_PV( ~idP, $P, $V, %1, 'null' ),
   St_VP( ~idV, $V, $P, %1, 'null', ~inj_n, 'challenge_state' ),
   Out( <pk(~ltkPV), pk(~ltkVP), ~idP, ~idV, ~inj_n> )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) V_challenge:
   [
   St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~inj_n, 'challenge_state'
   ),
   !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP ), Fr( ~ch )
   ]
  --[
  Challenge( $V, $P, %prev_cP, prev_nP, ~ch ),
  Injectivity( ~idV, ~inj_n, ~ch ), CounterVP( $V, $P, %prev_cP )
  ]->
   [
   St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~ch, 'verify_state' ),
   Out( <<'challenge', $V, $P, %prev_cP, prev_nP, ~ch>, 
         sign(<'challenge', $V, $P, %prev_cP, prev_nP, ~ch>, ~ltkVP)>
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) V_challenge_timeout:
   [
   St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~ch, 'verify_state' ),
   !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP ), Fr( ~inj_n )
   ]
  --[
  ChallengeTimeout( $V, $P, %prev_cP, prev_nP, ~ch ),
  Injectivity( ~idV, ~ch, ~inj_n ), CounterVP( $V, $P, %prev_cP ),
  Timeout_prev_nP( ~idV, prev_nP )
  ]->
   [
   St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~inj_n, 'challenge_state' )
   ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) P_response_sync:
   [
   In( <<'challenge', $V, $P, %prev_cP, prev_nP, ch>, v_sig> ),
   St_PV( ~idP, $P, $V, %prev_cP, prev_nP ),
   !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pkVP, ~ltkPV ), Fr( ~nP )
   ]
  --[
  Eq( verify(v_sig, <'challenge', $V, $P, %prev_cP, prev_nP, ch>,
             pkVP),
      true
  ),
  Response( $P, $V, (%prev_cP%+%1), ~nP, ch ), Sync( $P, $V )
  ]->
   [
   St_PV( ~idP, $P, $V, (%prev_cP%+%1), ~nP ),
   Out( <<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, 
         sign(<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, ~ltkPV)>
   )
   ]

  // loop breaker: [1]
  /*
  rule (modulo AC) P_response_sync:
     [
     In( <<'challenge', $V, $P, %prev_cP, prev_nP, ch>, v_sig> ),
     St_PV( ~idP, $P, $V, %prev_cP, prev_nP ),
     !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pkVP, ~ltkPV ), Fr( ~nP )
     ]
    --[
    Eq( z, true ), Response( $P, $V, (%prev_cP%+%1), ~nP, ch ),
    Sync( $P, $V )
    ]->
     [
     St_PV( ~idP, $P, $V, (%prev_cP%+%1), ~nP ),
     Out( <<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, 
           sign(<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, ~ltkPV)>
     )
     ]
    variants (modulo AC)
    1. $P    = $P.28
       $V    = $V.29
       ch    = ch.34
       pkVP  = pkVP.36
       prev_nP
             = prev_nP.37
       v_sig = v_sig.38
       z     = verify(v_sig.38,
                      <'challenge', $V.29, $P.28, %prev_cP.39, prev_nP.37, ch.34>,
                      pkVP.36)
       %prev_cP
             = %prev_cP.39
    
    2. $P    = $P.40
       $V    = $V.41
       ch    = ch.46
       pkVP  = pk(x.78)
       prev_nP
             = prev_nP.49
       v_sig = sign(<'challenge', $V.41, $P.40, %prev_cP.51, prev_nP.49, 
                     ch.46>,
                    x.78)
       z     = true
       %prev_cP
             = %prev_cP.51
    // loop breaker: [1]
  */

rule (modulo E) P_response_desync:
   [
   In( <<'challenge', $V, $P, %sent_prev_cP, sent_prev_nP, ch>, v_sig>
   ),
   St_PV( ~idP, $P, $V, %prev_cP, prev_nP ),
   !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pkVP, ~ltkPV ), Fr( ~nP )
   ]
  --[
  Eq( verify(v_sig,
             <'challenge', $V, $P, %sent_prev_cP, sent_prev_nP, ch>, pkVP),
      true
  ),
  LessThan( %sent_prev_cP, %prev_cP ),
  Response( $P, $V, (%prev_cP%+%1), ~nP, ch ), Desync( $P, $V )
  ]->
   [
   St_PV( ~idP, $P, $V, (%prev_cP%+%1), ~nP ),
   Out( <<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, 
         sign(<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, ~ltkPV)>
   )
   ]

  // loop breaker: [1]
  /*
  rule (modulo AC) P_response_desync:
     [
     In( <<'challenge', $V, $P, %sent_prev_cP, sent_prev_nP, ch>, v_sig>
     ),
     St_PV( ~idP, $P, $V, %prev_cP, prev_nP ),
     !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pkVP, ~ltkPV ), Fr( ~nP )
     ]
    --[
    Eq( z, true ), LessThan( %sent_prev_cP, %prev_cP ),
    Response( $P, $V, (%prev_cP%+%1), ~nP, ch ), Desync( $P, $V )
    ]->
     [
     St_PV( ~idP, $P, $V, (%prev_cP%+%1), ~nP ),
     Out( <<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, 
           sign(<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, ~ltkPV)>
     )
     ]
    variants (modulo AC)
    1. $P    = $P.32
       $V    = $V.33
       ch    = ch.38
       pkVP  = pkVP.40
       sent_prev_nP
             = sent_prev_nP.42
       v_sig = v_sig.43
       z     = verify(v_sig.43,
                      <'challenge', $V.33, $P.32, %sent_prev_cP.45, sent_prev_nP.42, 
                       ch.38>,
                      pkVP.40)
       %sent_prev_cP
             = %sent_prev_cP.45
    
    2. $P    = $P.44
       $V    = $V.45
       ch    = ch.50
       pkVP  = pk(x.86)
       sent_prev_nP
             = sent_prev_nP.54
       v_sig = sign(<'challenge', $V.45, $P.44, %sent_prev_cP.57, 
                     sent_prev_nP.54, ch.50>,
                    x.86)
       z     = true
       %sent_prev_cP
             = %sent_prev_cP.57
    // loop breaker: [1]
  */

rule (modulo E) V_accept:
   [
   In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
   St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state' ),
   !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP ), Fr( ~inj_n )
   ]
  --[
  Verify( $V, $P, %cP, nP, ch ),
  Eq( verify(sig, <'response', $P, $V, %cP, nP, ch>, pkPV), true ),
  Eq( (%prev_cP%+%1), %cP ), Accept( $V, $P ),
  Injectivity( ~idV, ch, ~inj_n ), CounterVP( $V, $P, %cP ),
  Update_prev_nP( ~idV, nP )
  ]->
   [ St_VP( ~idV, $V, $P, %cP, nP, ~inj_n, 'challenge_state' ) ]

  // loop breaker: [1]
  /*
  rule (modulo AC) V_accept:
     [
     In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
     St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state' ),
     !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP ), Fr( ~inj_n )
     ]
    --[
    Verify( $V, $P, %cP, nP, ch ), Eq( z, true ),
    Eq( (%prev_cP%+%1), %cP ), Accept( $V, $P ),
    Injectivity( ~idV, ch, ~inj_n ), CounterVP( $V, $P, %cP ),
    Update_prev_nP( ~idV, nP )
    ]->
     [ St_VP( ~idV, $V, $P, %cP, nP, ~inj_n, 'challenge_state' ) ]
    variants (modulo AC)
    1. $P    = $P.32
       $V    = $V.33
       ch    = ch.38
       nP    = nP.39
       pkPV  = pkPV.40
       sig   = sig.43
       z     = verify(sig.43,
                      <'response', $P.32, $V.33, %cP.44, nP.39, ch.38>, pkPV.40)
       %cP   = %cP.44
    
    2. $P    = $P.64
       $V    = $V.65
       ch    = ch.70
       nP    = nP.71
       pkPV  = pk(x.126)
       sig   = sign(<'response', $P.64, $V.65, %cP.76, nP.71, ch.70>,
                    x.126)
       z     = true
       %cP   = %cP.76
    // loop breaker: [1]
  */

rule (modulo E) V_detect_cloning:
   [
   In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
   St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state' ),
   !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP )
   ]
  --[
  Verify( $V, $P, %cP, nP, ch ),
  Eq( verify(sig, <'response', $P, $V, %cP, nP, ch>, pkPV), true ),
  GreaterThan( (%prev_cP%+%1), %cP ), DetectCloning( $V, $P )
  ]->
   [ ]

  /*
  rule (modulo AC) V_detect_cloning:
     [
     In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
     St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state' ),
     !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP )
     ]
    --[
    Verify( $V, $P, %cP, nP, ch ), Eq( z, true ),
    GreaterThan( (%prev_cP%+%1), %cP ), DetectCloning( $V, $P )
    ]->
     [ ]
    variants (modulo AC)
    1. $P    = $P.29
       $V    = $V.30
       ch    = ch.34
       nP    = nP.35
       pkPV  = pkPV.36
       sig   = sig.39
       z     = verify(sig.39,
                      <'response', $P.29, $V.30, %cP.40, nP.35, ch.34>, pkPV.36)
       %cP   = %cP.40
    
    2. $P    = $P.41
       $V    = $V.42
       ch    = ch.46
       nP    = nP.47
       pkPV  = pk(x.80)
       sig   = sign(<'response', $P.41, $V.42, %cP.52, nP.47, ch.46>,
                    x.80)
       z     = true
       %cP   = %cP.52
  */

rule (modulo E) V_detect_response_loss:
   [
   In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
   St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state' ),
   !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP )
   ]
  --[
  Verify( $V, $P, %cP, nP, ch ),
  Eq( verify(sig, <'response', $P, $V, %cP, nP, ch>, pkPV), true ),
  LessThan( (%prev_cP%+%1), %cP ), DetectResponseLoss( $V, $P )
  ]->
   [ ]

  /*
  rule (modulo AC) V_detect_response_loss:
     [
     In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
     St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch, 'verify_state' ),
     !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP )
     ]
    --[
    Verify( $V, $P, %cP, nP, ch ), Eq( z, true ),
    LessThan( (%prev_cP%+%1), %cP ), DetectResponseLoss( $V, $P )
    ]->
     [ ]
    variants (modulo AC)
    1. $P    = $P.29
       $V    = $V.30
       ch    = ch.34
       nP    = nP.35
       pkPV  = pkPV.36
       sig   = sig.39
       z     = verify(sig.39,
                      <'response', $P.29, $V.30, %cP.40, nP.35, ch.34>, pkPV.36)
       %cP   = %cP.40
    
    2. $P    = $P.41
       $V    = $V.42
       ch    = ch.46
       nP    = nP.47
       pkPV  = pk(x.80)
       sig   = sign(<'response', $P.41, $V.42, %cP.52, nP.47, ch.46>,
                    x.80)
       z     = true
       %cP   = %cP.52
  */

rule (modulo E) Reveal_ltk_PV:
   [ !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pkVP, ~ltkPV ) ]
  --[ Reveal_ltk_PV( $P, $V ) ]->
   [ Out( ~ltkPV ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_ltk_VP:
   [ !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP ) ]
  --[ Reveal_ltk_VP( $V, $P ) ]->
   [ Out( ~ltkVP ) ]

  /* has exactly the trivial AC variant */

lemma sources_timeout_prev_nP [sources]:
  all-traces
  "∀ idV prev_nP #i2.
    (Timeout_prev_nP( idV, prev_nP ) @ #i2) ⇒
    ((∃ #i1. (Init_prev_nP( idV, prev_nP ) @ #i1) ∧ (#i1 < #i2)) ∨
     (∃ #i1. (Update_prev_nP( idV, prev_nP ) @ #i1) ∧ (#i1 < #i2)))"
/*
guarded formula characterizing all counter-examples:
"∃ idV prev_nP #i2.
  (Timeout_prev_nP( idV, prev_nP ) @ #i2)
 ∧
  (∀ #i1. (Init_prev_nP( idV, prev_nP ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i1. (Update_prev_nP( idV, prev_nP ) @ #i1) ⇒ ¬(#i1 < #i2))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i2))  ∥
         (∃ #i1.
           (Init_prev_nP( ~idV, prev_nP ) @ #i1)
          ∧
           (¬(last(#i1))) ∧ (#i1 < #i2))  ∥
         (∃ #i1.
           (Update_prev_nP( ~idV, prev_nP ) @ #i1)
          ∧
           (¬(last(#i1))) ∧ (#i1 < #i2)) )
    case case_1
    solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP
           ) ▶₁ #i2 )
      case Register
      solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ~ch, 'verify_state'
             ) ▶₀ #i2 )
        case V_challenge_case_1
        by contradiction /* from formulas */
      next
        case V_challenge_case_2
        solve( (∃ #i1.
                 (Init_prev_nP( ~idV, prev_nP ) @ #i1)
                ∧
                 (¬(last(#i1))) ∧ (#i1 < #vr.2))  ∥
               (∃ #i1.
                 (Update_prev_nP( ~idV, prev_nP ) @ #i1)
                ∧
                 (¬(last(#i1))) ∧ (#i1 < #vr.2)) )
          case case_1
          by contradiction /* from formulas */
        next
          case case_2
          by contradiction /* from formulas */
        qed
      next
        case V_challenge_case_3
        by contradiction /* from formulas */
      qed
    qed
  next
    case case_2
    by contradiction /* from formulas */
  next
    case case_3
    by contradiction /* from formulas */
  qed
qed

lemma verifier_injectivity [reuse]:
  all-traces
  "∀ idV inj_n1 ch inj_n2 n1 n2 #i #i1 #i3.
    ((((Injectivity( idV, inj_n1, ch ) @ #i1) ∧
       (Injectivity( idV, ch, inj_n2 ) @ #i3)) ∧
      (Injectivity( idV, n1, n2 ) @ #i)) ∧
     (#i < #i3)) ⇒
    (¬(#i1 < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ idV inj_n1 ch inj_n2 n1 n2 #i #i1 #i3.
  (Injectivity( idV, inj_n1, ch ) @ #i1) ∧
  (Injectivity( idV, ch, inj_n2 ) @ #i3) ∧
  (Injectivity( idV, n1, n2 ) @ #i)
 ∧
  (#i < #i3) ∧ (#i1 < #i)"
*/
simplify
solve( Injectivity( idV, inj_n1, ch ) @ #i1 )
  case V_accept
  solve( Injectivity( ~idV, ~inj_n, inj_n2 ) @ #i3 )
    case V_accept
    by solve( !KU( ~inj_n ) @ #vk.21 )
  next
    case V_challenge
    solve( Injectivity( ~idV, n1, n2 ) @ #i )
      case V_accept
      solve( !Binding_VP( $V, $P, ~idV, ~idP.1, pkVP.1, pk(x.1), ~ltkVP.1
             ) ▶₂ #i1 )
        case Register
        solve( St_VP( ~idV, $V, $P, %prev_cP.2, prev_nP.2, ~inj_n.1,
                      'challenge_state'
               ) ▶₀ #i3 )
          case V_accept
          by contradiction /* cyclic */
        qed
      qed
    next
      case V_challenge
      solve( !Binding_VP( $V, $P, ~idV, ~idP.1, pkVP.1, pk(x), ~ltkVP.1
             ) ▶₂ #i1 )
        case Register
        solve( St_VP( ~idV, $V, $P, %prev_cP.2, prev_nP.2, ~inj_n.1,
                      'challenge_state'
               ) ▶₀ #i3 )
          case V_accept
          by contradiction /* cyclic */
        qed
      qed
    next
      case V_challenge_timeout
      solve( !Binding_VP( $V, $P, ~idV, ~idP.1, pkVP.1, pk(x), ~ltkVP.1
             ) ▶₂ #i1 )
        case Register
        solve( St_VP( ~idV, $V, $P, %prev_cP.2, prev_nP.2, ~inj_n.1,
                      'challenge_state'
               ) ▶₀ #i3 )
          case V_accept
          by contradiction /* cyclic */
        qed
      qed
    qed
  next
    case V_challenge_timeout
    solve( Injectivity( ~idV, n1, n2 ) @ #i )
      case V_accept
      solve( !Binding_VP( $V, $P, ~idV, ~idP.1, pkVP.1, pk(x.1), ~ltkVP.1
             ) ▶₂ #i1 )
        case Register
        solve( !Binding_VP( $V, $P, ~idV, ~idP.2, pkVP.1, pkPV, ~ltkVP.2
               ) ▶₁ #i3 )
          case Register
          solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
                 ) ▶₂ #i )
            case Register
            solve( St_VP( ~idV, $V, $P, %prev_cP.1, prev_nP.1, inj_n1,
                          'verify_state'
                   ) ▶₁ #i1 )
              case V_challenge_case_1
              solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP.1, ~ch>, ~ltkPV)
                     ) @ #vk.16 )
                case P_response_desync
                by contradiction /* contradictory subterm store */
              next
                case P_response_sync
