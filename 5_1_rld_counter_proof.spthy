lemma clone_detection_in_compromised_previous_session_verifier_key [use_induction]:
  all-traces
  "∀ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i2 #i3 #i4.
    ((((((((Verify( v, p, %cP1, nP1, ch1 ) @ #i2) ∧
           (Response( p, v, %cP2, nP2, ch2 ) @ #i3)) ∧
          (Verify( v, p, %cP2, nP2, ch2 ) @ #i4)) ∧
         (#i2 < #i3)) ∧
        (#i3 < #i4)) ∧
       (¬(∃ #i. DetectResponseLoss( v, p ) @ #i))) ∧
      (¬(∃ %cP nP ch #i. ChallengeTimeout( v, p, %cP, nP, ch ) @ #i))) ∧
     (¬(∃ #i. Desync( p, v ) @ #i))) ⇒
    (((∃ #i1. (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧ (#i1 < #i2)) ∨
      (∃ #i. DetectCloning( v, p ) @ #i)) ∨
     (∃ #i. Reveal_ltk_PV( p, v ) @ #i))"
/*
guarded formula characterizing all counter-examples:
"∃ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i2 #i3 #i4.
  (Verify( v, p, %cP1, nP1, ch1 ) @ #i2) ∧
  (Response( p, v, %cP2, nP2, ch2 ) @ #i3) ∧
  (Verify( v, p, %cP2, nP2, ch2 ) @ #i4)
 ∧
  (#i2 < #i3) ∧
  (#i3 < #i4) ∧
  (∀ #i. (DetectResponseLoss( v, p ) @ #i) ⇒ ⊥) ∧
  (∀ %cP nP ch #i.
    (ChallengeTimeout( v, p, %cP, nP, ch ) @ #i) ⇒ ⊥) ∧
  (∀ #i. (Desync( p, v ) @ #i) ⇒ ⊥) ∧
  (∀ #i1. (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i. (DetectCloning( v, p ) @ #i) ⇒ ⊥) ∧
  (∀ #i. (Reveal_ltk_PV( p, v ) @ #i) ⇒ ⊥)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( Verify( v, p, %cP1, nP1, ch1 ) @ #i2 )
    case V_accept
    solve( Response( $P, $V, %cP2, nP2, ch2 ) @ #i3 )
      case P_response_desync
      by contradiction /* from formulas */
    next
      case P_response_sync
      solve( Verify( $V, $P, (%prev_cP.1%+%1), ~nP, ch2 ) @ #i4 )
        case V_accept
        solve( (last(#i4))  ∥
               (∃ #i. (DetectResponseLoss( $V, $P ) @ #i) ∧ ¬(last(#i)))  ∥
               (∃ %cP nP ch #i.
                 (ChallengeTimeout( $V, $P, %cP, nP, ch ) @ #i) ∧ ¬(last(#i)))  ∥
               (∃ #i. (Desync( $P, $V ) @ #i) ∧ ¬(last(#i)))  ∥
               (∃ #i1.
                 (Response( $P, $V, (%prev_cP%+%1), nP1, ch1 ) @ #i1)
                ∧
                 (¬(last(#i1))) ∧ (#i1 < #i2))  ∥
               (∃ #i. (DetectCloning( $V, $P ) @ #i) ∧ ¬(last(#i)))  ∥
               (∃ #i. (Reveal_ltk_PV( $P, $V ) @ #i) ∧ ¬(last(#i))) )
          case case_1
          solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
                 ) ▶₂ #i2 )
            case Register
            solve( !Binding_PV( $P, $V, ~idP.1, ~idV.1, pkPV, pk(x), ~ltkPV.1
                   ) ▶₂ #i3 )
              case Register
              solve( !Binding_VP( $V, $P, ~idV.1, ~idP.1, pkVP, pk(x), ~ltkVP.1
                     ) ▶₂ #i4 )
                case Register
                solve( St_VP( ~idV, $V, $P, %prev_cP, prev_nP, ch1, 'verify_state'
                       ) ▶₁ #i2 )
                  case V_challenge_case_1
                  solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP1, ~ch>, ~ltkPV)
                         ) @ #vk.20 )
                    case P_response_desync
                    by contradiction /* cyclic */
                  next
                    case P_response_sync
                    by contradiction /* from formulas */
                  next
                    case c_sign
                    solve( !KU( ~ltkPV ) @ #vk.33 )
                      case Reveal_ltk_PV
                      by contradiction /* from formulas */
                    qed
                  qed
                next
                  case V_challenge_case_2
                  by contradiction /* from formulas */
                next
                  case V_challenge_case_3
                  solve( !KU( sign(<'response', $P, $V, (%prev_cP%+%1%+%1), nP1, ~ch
                                   >,
                                   ~ltkPV)
                         ) @ #vk.23 )
                    case P_response_desync
                    by contradiction /* from formulas */
                  next
                    case P_response_sync
                    by contradiction /* from formulas */
                  next
                    case c_sign
                    solve( !KU( ~ltkPV ) @ #vk.43 )
                      case Reveal_ltk_PV
                      by contradiction /* from formulas */
                    qed
                  qed
                qed
              qed
            qed
          qed
        next
          case case_2
          by contradiction /* from formulas */
        next
          case case_3
          by contradiction /* from formulas */
        next
          case case_4
          by contradiction /* from formulas */
        next
          case case_5
          by contradiction /* from formulas */
        next
          case case_6
          by contradiction /* from formulas */
        next
          case case_7
          by contradiction /* from formulas */
        qed
      next
        case V_detect_cloning
        by contradiction /* from formulas */
      next
        case V_detect_response_loss
        by contradiction /* from formulas */
      qed
    qed
  next
    case V_detect_cloning
    by contradiction /* from formulas */
  next
    case V_detect_response_loss
    by contradiction /* from formulas */
  qed
qed

