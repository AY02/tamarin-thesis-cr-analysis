lemma clone_detection_in_compromised_previous_session_prover_key [use_induction]:
  all-traces
  "∀ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i2 #i3 #i4.
    (((((((Verify( v, p, %cP1, nP1, ch1 ) @ #i2) ∧
          (Response( p, v, %cP2, nP2, ch2 ) @ #i3)) ∧
         (Verify( v, p, %cP2, nP2, ch2 ) @ #i4)) ∧
        (#i2 < #i3)) ∧
       (#i3 < #i4)) ∧
      (¬(∃ #i. DetectResponseLoss( v, p ) @ #i))) ∧
     (¬(∃ %cP nP ch #i. ChallengeTimeout( v, p, %cP, nP, ch ) @ #i))) ⇒
    (((∃ #i1. (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧ (#i1 < #i2)) ∨
      (∃ #i. DetectCloning( v, p ) @ #i)) ∨
     (∃ #i. Reveal_ltk_VP( v, p ) @ #i))"
/*
guarded formula characterizing all counter-examples:
"∃ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i2 #i3 #i4.
  (Verify( v, p, %cP1, nP1, ch1 ) @ #i2) ∧
  (Response( p, v, %cP2, nP2, ch2 ) @ #i3) ∧
  (Verify( v, p, %cP2, nP2, ch2 ) @ #i4)
 ∧
  (#i2 < #i3) ∧
  (#i3 < #i4) ∧
  (∀ #i. (DetectResponseLoss( v, p ) @ #i) ⇒ ⊥) ∧
  (∀ %cP nP ch #i.
    (ChallengeTimeout( v, p, %cP, nP, ch ) @ #i) ⇒ ⊥) ∧
  (∀ #i1. (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i. (DetectCloning( v, p ) @ #i) ⇒ ⊥) ∧
  (∀ #i. (Reveal_ltk_VP( v, p ) @ #i) ⇒ ⊥)"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( Verify( $V, $P, %cP1, nP1, ch1 ) @ #i2 )
    case V_accept
    solve( Verify( $V, $P, (%prev_cP.1%+%1), ~nP, ch2 ) @ #i4 )
      case V_accept
      solve( !Binding_PV( $P, $V, ~idP.1, ~idV.1, pkPV, pk(x.1), ~ltkPV
             ) ▶₂ #i3 )
        case Register
        solve( (last(#i4))  ∥
               (∃ #i. (DetectResponseLoss( $V, $P ) @ #i) ∧ ¬(last(#i)))  ∥
               (∃ %cP nP ch #i.
                 (ChallengeTimeout( $V, $P, %cP, nP, ch ) @ #i) ∧ ¬(last(#i)))  ∥
               (∃ #i1.
                 (Response( $P, $V, (%prev_cP%+%1), nP1, ch1 ) @ #i1)
                ∧
                 (¬(last(#i1))) ∧ (#i1 < #i2))  ∥
               (∃ #i. (DetectCloning( $V, $P ) @ #i) ∧ ¬(last(#i)))  ∥
               (∃ #i. (Reveal_ltk_VP( $V, $P ) @ #i) ∧ ¬(last(#i))) )
          case case_1
          solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
                 ) ▶₂ #i2 )
            case Register
            solve( !Binding_VP( $V, $P, ~idV.1, ~idP.1, pkVP, pk(x), ~ltkVP.1
                   ) ▶₂ #i4 )
              case Register
              solve( St_VP( ~idV, %prev_cP.1, prev_nP.2, ch2, 'verify_state'
                     ) ▶₁ #i4 )
                case V_challenge_case_1
                by contradiction /* cyclic */
              next
                case V_challenge_case_2
                by contradiction /* from formulas */
              next
                case V_challenge_case_3
                solve( (¬(#i2 < #vr.2))  ∥ ((%prev_cP%+%1) ⊏ (%prev_cP.1%+%1)) )
                  case case_1
                  solve( (#vr.2 = #i2)  ∥ (#i2 < #vr.2) )
                    case case_1
                    solve( St_PV( ~idP, (%prev_cP%+%1), prev_nP.1 ) ▶₁ #i3 )
                      case P_response
                      solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                                        sent_prev_nP, ~ch>,
                                       ~ltkVP)
                             ) @ #vk.25 )
                        case V_challenge_case_1
                        solve( St_VP( ~idV.1, %prev_cP.1, prev_nP.2, ~ch.3, 'verify_state'
                               ) ▶₀ #vr.10 )
                          case V_challenge_case_1
                          by contradiction /* forbidden KD-fact */
                        next
                          case V_challenge_case_2
                          by contradiction /* cyclic */
                        next
