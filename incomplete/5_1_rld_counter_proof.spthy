lemma clone_detection_soundness:
  all-traces
  "∀ p v #i2.
    (DetectCloning( v, p ) @ #i2) ⇒
    ((∃ #i1. (Reveal_ltk_PV( p, v ) @ #i1) ∧ (#i1 < #i2)) ∨
     (∃ #i1. (Reveal_ltk_VP( v, p ) @ #i1) ∧ (#i1 < #i2)))"
/*
guarded formula characterizing all counter-examples:
"∃ p v #i2.
  (DetectCloning( v, p ) @ #i2)
 ∧
  (∀ #i1. (Reveal_ltk_PV( p, v ) @ #i1) ⇒ ¬(#i1 < #i2)) ∧
  (∀ #i1. (Reveal_ltk_VP( v, p ) @ #i1) ⇒ ¬(#i1 < #i2))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i2))  ∥
         (∃ #i1.
           (Reveal_ltk_PV( $P, $V ) @ #i1) ∧ (¬(last(#i1))) ∧ (#i1 < #i2))  ∥
         (∃ #i1.
           (Reveal_ltk_VP( $V, $P ) @ #i1) ∧ (¬(last(#i1))) ∧ (#i1 < #i2)) )
    case case_1
    solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
           ) ▶₂ #i2 )
      case Register
      solve( !KU( sign(<'response', $P, $V, %cP, nP, ch>, ~ltkPV)
             ) @ #vk.12 )
        case P_response
        solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                          sent_prev_nP, ch>,
                         ~ltkVP)
               ) @ #vk.22 )
          case V_challenge_case_1
          solve( St_VP( ~idV.1, %prev_cP.2, prev_nP.2, ~ch.2, 'verify_state'
                 ) ▶₀ #vr.10 )
            case V_challenge_case_1
            by contradiction /* forbidden KD-fact */
          next
            case V_challenge_case_2
            by contradiction /* cyclic */
          next
            case V_challenge_case_3
            by contradiction /* cyclic */
          qed
        next
          case V_challenge_case_2
          solve( St_VP( ~idV, %prev_cP.1, prev_nP, ~ch, 'verify_state'
                 ) ▶₁ #i2 )
            case V_challenge
            by contradiction /* contradictory subterm store */
          qed
        next
          case V_challenge_case_3
          solve( St_VP( ~idV, %prev_cP.1, prev_nP, ~ch, 'verify_state'
                 ) ▶₁ #i2 )
            case V_challenge
            solve( St_VP( ~idV, %sent_prev_cP, prev_nP, ~ch.1, 'verify_state'
                   ) ▶₀ #vr.5 )
              case V_challenge_case_1
              by contradiction /* contradictory subterm store */
            next
              case V_challenge_case_2
              solve( !KU( ~nP ) @ #vk.19 )
                case P_response
                solve( !KU( ~ch ) @ #vk.21 )
                  case V_challenge_case_1
                  solve( St_PV( ~idP, %prev_cP, prev_nP.1 ) ▶₁ #vr.1 )
                    case P_response
                    solve( !KU( sign(<'response', $P, $V, (%prev_cP.1%+%1), prev_nP, 
                                      ch.3>,
                                     ~ltkPV)
                           ) @ #vk.33 )
                      case P_response
                      by contradiction /* cyclic */
                    next
                      case V_challenge
                      solve( St_VP( ~idV, %prev_cP.1, prev_nP.2, ch.3, 'verify_state'
                             ) ▶₁ #vr.7 )
                        case V_challenge_case_1
                        by contradiction /* contradictory subterm store */
                      next
                        case V_challenge_case_2
                        solve( St_VP( ~idV.1, %prev_cP.2, prev_nP.1, ~ch.6, 'verify_state'
