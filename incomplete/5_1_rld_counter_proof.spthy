        qed
      qed
    next
      case V_challenge
      solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV.1,
                          ~ltkVP.1
             ) ▶₁ #i1 )
        case Register
        solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pkPV.1,
                            ~ltkVP.2
               ) ▶₁ #i3 )
          case Register
