lemma verifier_injectivity [reuse]:
  all-traces
  "∀ idV inj_n1 ch inj_n2 n1 n2 #i #i1 #i3.
    ((((Injectivity( idV, inj_n1, ch ) @ #i1) ∧
       (Injectivity( idV, ch, inj_n2 ) @ #i3)) ∧
      (Injectivity( idV, n1, n2 ) @ #i)) ∧
     (#i < #i3)) ⇒
    (¬(#i1 < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ idV inj_n1 ch inj_n2 n1 n2 #i #i1 #i3.
  (Injectivity( idV, inj_n1, ch ) @ #i1) ∧
  (Injectivity( idV, ch, inj_n2 ) @ #i3) ∧
  (Injectivity( idV, n1, n2 ) @ #i)
 ∧
  (#i < #i3) ∧ (#i1 < #i)"
*/
simplify
solve( Injectivity( idV, inj_n1, ch ) @ #i1 )
  case V_accept
  solve( Injectivity( ~idV, ~inj_n, inj_n2 ) @ #i3 )
    case V_accept
    solve( !KU( ~inj_n ) @ #vk.23 )
      case V_challenge
      solve( Injectivity( ~idV, n1, n2 ) @ #i )
        case V_accept
        solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pk(x.1),
                            ~ltkVP.1
               ) ▶₂ #i1 )
          case Register
          solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pk(x.1),
                              ~ltkVP.2
                 ) ▶₂ #i3 )
            case Register
            solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
                   ) ▶₂ #i )
              case Register
              solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, inj_n1, 'verify_state'
                     ) ▶₁ #i1 )
                case V_challenge_case_1
                solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP.1, ~ch>, ~ltkPV)
                       ) @ #vk.23 )
                  case P_response
                  by solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ~inj_n.1,
                                   'verify_state'
                            ) ▶₁ #i3 )
                next
                  case V_challenge
                  by solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ~inj_n.1,
                                   'verify_state'
                            ) ▶₁ #i3 )
                next
                  case c_sign
                  solve( !KU( ~ltkPV ) @ #vk.33 )
                    case Reveal_ltk_PV
                    by solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ~inj_n.1,
                                     'verify_state'
                              ) ▶₁ #i3 )
                  next
                    case V_challenge
                    by solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ~inj_n.1,
                                     'verify_state'
                              ) ▶₁ #i3 )
                  qed
                qed
              next
                case V_challenge_case_2
                solve( !KU( sign(<'response', $P, $V, (%prev_cP.1%+%1), nP.1, ~ch>,
                                 ~ltkPV)
                       ) @ #vk.23 )
                  case P_response
                  by solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                                   'verify_state'
                            ) ▶₁ #i3 )
                next
                  case V_challenge
                  by solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                                   'verify_state'
                            ) ▶₁ #i3 )
                next
                  case c_sign
                  solve( !KU( ~ltkPV ) @ #vk.33 )
                    case Reveal_ltk_PV
                    by solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                                     'verify_state'
                              ) ▶₁ #i3 )
                  next
                    case V_challenge
                    by solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                                     'verify_state'
                              ) ▶₁ #i3 )
                  qed
                qed
              next
                case V_challenge_case_3
                solve( !KU( sign(<'response', $P, $V, (%prev_cP.1%+%1%+%1), nP.1, 
                                  ~ch>,
                                 ~ltkPV)
                       ) @ #vk.26 )
                  case P_response
                  by solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                                   'verify_state'
                            ) ▶₁ #i3 )
                next
                  case V_challenge
                  by solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                                   'verify_state'
                            ) ▶₁ #i3 )
                next
                  case c_sign
                  solve( !KU( ~ltkPV ) @ #vk.43 )
                    case Reveal_ltk_PV
                    by solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                                     'verify_state'
                              ) ▶₁ #i3 )
                  next
                    case V_challenge
                    by solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                                     'verify_state'
                              ) ▶₁ #i3 )
                  qed
                qed
              qed
            qed
          qed
        qed
      next
        case V_challenge
        solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pk(x),
                            ~ltkVP.1
               ) ▶₂ #i1 )
          case Register
          solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pk(x),
                              ~ltkVP.2
                 ) ▶₂ #i3 )
            case Register
            solve( St_VP( ~idV, %prev_cP, prev_nP, ~inj_n, 'challenge_state'
                   ) ▶₀ #i )
              case Register
              by contradiction /* cyclic */
            next
              case V_accept
              solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP
                     ) ▶₁ #i )
                case Register
                solve( (¬(#i1 < #vr.10))  ∥ ((%prev_cP.1%+%1) ⊏ (%prev_cP%+%1)) )
                  case case_1
                  solve( (¬(#vr.10 < #i1))  ∥ ((%prev_cP%+%1) ⊏ (%prev_cP.1%+%1)) )
                    case case_1
                    solve( (#i1 = #vr.10)  ∥ (#vr.10 < #i1) )
                      case case_1
                      solve( St_VP( ~idV, %prev_cP, prev_nP, inj_n1, 'verify_state'
                             ) ▶₁ #i1 )
                        case V_challenge_case_1
                        solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP, ~ch.1>, ~ltkPV)
                               ) @ #vk.19 )
                          case P_response
