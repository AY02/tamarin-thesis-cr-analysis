lemma executability_honest_single_session:
  exists-trace
  "∃ p v #i.
    ((Accept( v, p ) @ #i) ∧ (¬(∃ #j. Reveal_ltk_PV( p, v ) @ #j))) ∧
    (¬(∃ #j. Reveal_ltk_VP( v, p ) @ #j))"
/*
guarded formula characterizing all satisfying traces:
"∃ p v #i.
  (Accept( v, p ) @ #i)
 ∧
  (∀ #j. (Reveal_ltk_PV( p, v ) @ #j) ⇒ ⊥) ∧
  (∀ #j. (Reveal_ltk_VP( v, p ) @ #j) ⇒ ⊥)"
*/
simplify
solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
       ) ▶₂ #i )
  case Register
  solve( St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state' ) ▶₁ #i )
    case V_challenge_case_1
    solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP, ~ch>, ~ltkPV)
           ) @ #vk.12 )
      case P_response
      solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                        sent_prev_nP, ~ch>,
                       ~ltkVP)
             ) @ #vk.22 )
        case V_challenge_case_2
        solve( St_PV( ~idP, %1, prev_nP ) ▶₁ #vr.2 )
          case Register
          solve( !KU( ~ch ) @ #vk.17 )
            case V_challenge_case_2
            solve( !KU( ~nP ) @ #vk.17 )
              case P_response
              SOLVED // trace found
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma executability_honest_consecutive_sessions:
  exists-trace
  "∃ p v #i1 #i2.
    ((((Accept( v, p ) @ #i1) ∧ (Accept( v, p ) @ #i2)) ∧
      (#i1 < #i2)) ∧
     (¬(∃ #i. Reveal_ltk_PV( p, v ) @ #i))) ∧
    (¬(∃ #i. Reveal_ltk_VP( v, p ) @ #i))"
/*
guarded formula characterizing all satisfying traces:
"∃ p v #i1 #i2.
  (Accept( v, p ) @ #i1) ∧ (Accept( v, p ) @ #i2)
 ∧
  (#i1 < #i2) ∧
  (∀ #i. (Reveal_ltk_PV( p, v ) @ #i) ⇒ ⊥) ∧
  (∀ #i. (Reveal_ltk_VP( v, p ) @ #i) ⇒ ⊥)"
*/
simplify
solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
       ) ▶₂ #i1 )
  case Register
  solve( !Binding_VP( $V, $P, ~idV.1, ~idP.1, pkVP, pk(x), ~ltkVP.1
         ) ▶₂ #i2 )
    case Register
    solve( St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state'
           ) ▶₁ #i1 )
      case V_challenge_case_1
      solve( St_VP( ~idV, %prev_cP, prev_nP, ch.1, 'verify_state'
             ) ▶₁ #i2 )
        case V_challenge_case_1
        by contradiction /* cyclic */
      next
        case V_challenge_case_2
        by sorry
      next
        case V_challenge_case_3
        solve( (¬(#i1 < #vr.3))  ∥ ((%1%+%1) ⊏ (%prev_cP%+%1)) )
          case case_1
          solve( (#vr.3 = #i1)  ∥ (#i1 < #vr.3) )
            case case_1
            solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP, ~ch>, ~ltkPV)
                   ) @ #vk.16 )
              case P_response
              solve( !KU( sign(<'response', $P, $V, (%1%+%1%+%1), nP.1, ~ch.1>,
                               ~ltkPV)
                     ) @ #vk.25 )
                case P_response
                solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                                  sent_prev_nP, ~ch>,
                                 ~ltkVP)
                       ) @ #vk.36 )
                  case V_challenge_case_1
                  by sorry
                next
                  case V_challenge_case_2
                  solve( St_PV( ~idP, %1, prev_nP ) ▶₁ #vr.3 )
                    case Register
                    solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                                      sent_prev_nP, ~ch.1>,
                                     ~ltkVP)
                           ) @ #vk.41 )
                      case V_challenge_case_1
                      by sorry
                    next
                      case V_challenge_case_2
                      solve( St_PV( ~idP, (%1%+%1), prev_nP ) ▶₁ #vr.5 )
                        case P_response
                        solve( !KU( ~ch ) @ #vk.29 )
                          case V_challenge_case_1
                          by sorry
                        next
                          case V_challenge_case_2
                          solve( !KU( ~ch.1 ) @ #vk.36 )
                            case V_challenge_case_1
                            by sorry
                          next
                            case V_challenge_case_2
                            solve( !KU( ~nP ) @ #vk.31 )
                              case P_response
                              solve( !KU( ~nP.1 ) @ #vk.36 )
                                case P_response
                                SOLVED // trace found
                              next
                                case V_challenge
                                by sorry
                              qed
                            next
                              case V_challenge
                              by sorry
                            qed
                          qed
                        qed
                      qed
                    next
                      case c_sign
                      by sorry
                    qed
                  qed
                next
                  case c_sign
                  by sorry
                qed
              next
                case V_challenge
                by sorry
              next
                case c_sign
                by sorry
              qed
            next
              case V_challenge
              by sorry
            next
              case c_sign
              by sorry
            qed
          next
            case case_2
            by contradiction /* from formulas */
          qed
        next
          case case_2
          by sorry
        qed
      qed
    next
      case V_challenge_case_2
      by sorry
    next
      case V_challenge_case_3
      by sorry
    qed
  qed
qed

lemma executability_cloning:
  exists-trace "∃ v p #i. DetectCloning( v, p ) @ #i"
/*
guarded formula characterizing all satisfying traces:
"∃ v p #i. (DetectCloning( v, p ) @ #i)"
*/
simplify
solve( St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state' ) ▶₁ #i )
  case V_challenge_case_1
  solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
         ) ▶₂ #i )
    case Register
    solve( !KU( sign(<'response', $P, $V, %1, nP, ~ch>, ~ltkPV)
           ) @ #vk.12 )
      case c_sign
      solve( !KU( ~ltkPV ) @ #vk.13 )
        case Reveal_ltk_PV
        solve( !KU( ~ch ) @ #vk.13 )
          case V_challenge_case_2
          SOLVED // trace found
        qed
      qed
    qed
  qed
qed

lemma executability_honest_response_loss:
  exists-trace
  "∃ v p #i.
    ((DetectResponseLoss( v, p ) @ #i) ∧
     (¬(∃ #j. Reveal_ltk_PV( p, v ) @ #j))) ∧
    (¬(∃ #j. Reveal_ltk_VP( v, p ) @ #j))"
/*
guarded formula characterizing all satisfying traces:
"∃ v p #i.
  (DetectResponseLoss( v, p ) @ #i)
 ∧
  (∀ #j. (Reveal_ltk_PV( p, v ) @ #j) ⇒ ⊥) ∧
  (∀ #j. (Reveal_ltk_VP( v, p ) @ #j) ⇒ ⊥)"
*/
simplify
solve( St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state' ) ▶₁ #i )
  case V_challenge_case_2
  solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
         ) ▶₂ #i )
    case Register
    solve( !KU( sign(<'response', $P, $V, %cP, nP, ~ch>, ~ltkPV)
           ) @ #vk.12 )
      case P_response
      solve( St_VP( ~idV, %prev_cP.1, prev_nP, ~ch.1, 'verify_state'
             ) ▶₀ #vr.1 )
        case V_challenge_case_1
        solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                          sent_prev_nP, ~ch>,
                         ~ltkVP)
               ) @ #vk.22 )
          case V_challenge_case_2
          solve( St_PV( ~idP, %prev_cP, prev_nP ) ▶₁ #vr.3 )
            case P_response
            solve( !KU( sign(<'challenge', $V, $P, %sent_prev_cP, 
                              sent_prev_nP, ch.2>,
                             ~ltkVP)
                   ) @ #vk.32 )
              case V_challenge_case_2
              solve( St_PV( ~idP, %prev_cP, prev_nP ) ▶₁ #vr.7 )
                case Register
                solve( !KU( ~ch ) @ #vk.22 )
                  case V_challenge_case_2
                  solve( !KU( ~nP ) @ #vk.22 )
                    case P_response
                    solve( !KU( ~ch.1 ) @ #vk.30 )
                      case V_challenge_case_2
                      SOLVED // trace found
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma prover_injective_agreement:
  all-traces
  "∀ p v %cP nP ch #i2.
    ((((Verify( v, p, %cP, nP, ch ) @ #i2) ∧ (Accept( v, p ) @ #i2)) ∧
      (¬(∃ #i. Reveal_ltk_PV( p, v ) @ #i))) ∧
     (¬(∃ #i. Reveal_ltk_VP( v, p ) @ #i))) ⇒
    ((∃ #i1. (Response( p, v, %cP, nP, ch ) @ #i1) ∧ (#i1 < #i2)) ∧
     (¬(∃ p_i v_i #i.
         ((Verify( v_i, p_i, %cP, nP, ch ) @ #i) ∧
          (Accept( v_i, p_i ) @ #i)) ∧
         (¬(#i = #i2)))))"
/*
guarded formula characterizing all counter-examples:
"∃ p v %cP nP ch #i2.
  (Verify( v, p, %cP, nP, ch ) @ #i2) ∧ (Accept( v, p ) @ #i2)
 ∧
  (∀ #i. (Reveal_ltk_PV( p, v ) @ #i) ⇒ ⊥) ∧
  (∀ #i. (Reveal_ltk_VP( v, p ) @ #i) ⇒ ⊥) ∧
  (((∀ #i1. (Response( p, v, %cP, nP, ch ) @ #i1) ⇒ ¬(#i1 < #i2)) ∨
    (∃ p_i v_i #i.
      (Verify( v_i, p_i, %cP, nP, ch ) @ #i) ∧ (Accept( v_i, p_i ) @ #i)
     ∧
      ¬(#i = #i2))))"
*/
simplify
solve( Verify( $V, $P, %cP.2, nP.2, ch.2 ) @ #i2 )
  case V_accept
  solve( (∀ #i1.
           (Response( $P, $V, (%prev_cP%+%1), nP, ch ) @ #i1)
          ⇒
           ¬(#i1 < #i2))  ∥
         (∃ p_i v_i #i.
           (Verify( v_i, p_i, (%prev_cP%+%1), nP, ch ) @ #i) ∧
           (Accept( v_i, p_i ) @ #i)
          ∧
           ¬(#i = #i2)) )
    case case_1
    solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
           ) ▶₂ #i2 )
      case Register
      solve( St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state'
             ) ▶₁ #i2 )
        case V_challenge_case_1
        solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP, ~ch>, ~ltkPV)
               ) @ #vk.12 )
          case P_response
          by contradiction /* from formulas */
        next
          case V_challenge
          solve( St_VP( ~idV.1, %prev_cP, prev_nP, ~ch.2, 'verify_state'
                 ) ▶₀ #vr.9 )
            case V_challenge_case_1
            by contradiction /* forbidden KD-fact */
          next
            case V_challenge_case_2
            by contradiction /* cyclic */
          next
            case V_challenge_case_3
