lemma response_monotonicity [reuse, use_induction]:
  all-traces
  "∀ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
    (((Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧
      (Response( p, v, %cP2, nP2, ch2 ) @ #i2)) ∧
     (#i1 < #i2)) ⇒
    (%cP1 ⊏ %cP2)"
/*
guarded formula characterizing all counter-examples:
"∃ p v %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
  (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧
  (Response( p, v, %cP2, nP2, ch2 ) @ #i2)
 ∧
  (#i1 < #i2) ∧ (¬(%cP1 ⊏ %cP2))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  simplify
  solve( !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pk(x), ~ltkPV
         ) ▶₂ #i1 )
    case Register
    solve( !Binding_PV( $P, $V, ~idP.1, ~idV.1, pkPV, pk(x), ~ltkPV.1
           ) ▶₂ #i2 )
      case Register
      by contradiction /* cyclic */
    qed
  qed
qed

lemma verify_monotonicity [reuse, use_induction]:
  all-traces
  "∀ v p %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
    (((((Verify( v, p, %cP1, nP1, ch1 ) @ #i1) ∧
        (Accept( v, p ) @ #i1)) ∧
       (Verify( v, p, %cP2, nP2, ch2 ) @ #i2)) ∧
      (Accept( v, p ) @ #i2)) ∧
     (#i1 < #i2)) ⇒
    (%cP1 ⊏ %cP2)"
/*
guarded formula characterizing all counter-examples:
"∃ v p %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
  (Verify( v, p, %cP1, nP1, ch1 ) @ #i1) ∧
  (Accept( v, p ) @ #i1) ∧
  (Verify( v, p, %cP2, nP2, ch2 ) @ #i2) ∧
  (Accept( v, p ) @ #i2)
 ∧
  (#i1 < #i2) ∧ (¬(%cP1 ⊏ %cP2))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  simplify
  solve( Verify( $V, $P, %cP1, nP1, ch1 ) @ #i1 )
    case V_accept
    solve( Verify( $V, $P, %cP2, nP2, ch2 ) @ #i2 )
      case V_accept
      solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
             ) ▶₂ #i1 )
        case Register
        solve( !Binding_VP( $V, $P, ~idV.1, ~idP.1, pkVP, pk(x), ~ltkVP.1
               ) ▶₂ #i2 )
          case Register
          solve( St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state'
                 ) ▶₁ #i1 )
            case V_challenge_case_1
            solve( St_VP( ~idV, %1, prev_nP, ch2, 'verify_state' ) ▶₁ #i2 )
              case V_challenge_case_1
              by contradiction /* cyclic */
            next
              case V_challenge_case_2
              simplify
              solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP, ~ch>, ~ltkPV)
                     ) @ #vk.17 )
                case P_response
                solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP2, ~ch.1>,
                                 ~ltkPV)
                       ) @ #vk.24 )
                  case V_challenge
                  by solve( St_VP( ~idV, %1, prev_nP, ~ch.2, 'verify_state'
                            ) ▶₀ #vr.3 )
                next
                  case c_sign
                  solve( !KU( ~ltkPV ) @ #vk.32 )
                    case Reveal_ltk_PV
                    by solve( St_VP( ~idV, %1, prev_nP, ~ch.2, 'verify_state'
                              ) ▶₀ #vr.3 )
                  next
                    case V_challenge
                    by solve( St_VP( ~idV, %1, prev_nP, ~ch.2, 'verify_state'
                              ) ▶₀ #vr.3 )
                  qed
                qed
              next
                case V_challenge
                solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP2, ~ch.1>,
                                 ~ltkPV)
                       ) @ #vk.21 )
                  case P_response
                  by solve( St_VP( ~idV, %1, prev_nP, ~ch.3, 'verify_state'
                            ) ▶₀ #vr.3 )
                next
                  case V_challenge
                  by solve( St_VP( ~idV, %1, prev_nP, ~ch.3, 'verify_state'
                            ) ▶₀ #vr.3 )
                next
                  case c_sign
                  solve( !KU( ~ltkPV ) @ #vk.22 )
                    case Reveal_ltk_PV
                    by solve( St_VP( ~idV, %1, prev_nP, ~ch.3, 'verify_state'
                              ) ▶₀ #vr.3 )
                  next
                    case V_challenge
                    by solve( St_VP( ~idV, %1, prev_nP, ~ch.3, 'verify_state'
                              ) ▶₀ #vr.3 )
                  qed
                qed
              next
                case c_sign
                solve( !KU( ~ltkPV ) @ #vk.22 )
                  case Reveal_ltk_PV
                  solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP2, ~ch.1>,
                                   ~ltkPV)
                         ) @ #vk.22 )
                    case P_response
                    by solve( St_VP( ~idV, %1, prev_nP, ~ch.2, 'verify_state'
                              ) ▶₀ #vr.3 )
                  next
                    case V_challenge
                    by solve( St_VP( ~idV, %1, prev_nP, ~ch.2, 'verify_state'
                              ) ▶₀ #vr.3 )
                  next
                    case c_sign
                    by solve( St_VP( ~idV, %1, prev_nP, ~ch.2, 'verify_state'
                              ) ▶₀ #vr.3 )
                  qed
                next
                  case V_challenge
                  solve( !KU( sign(<'response', $P, $V, (%1%+%1), nP2, ~ch.1>,
                                   ~ltkPV)
                         ) @ #vk.22 )
                    case P_response
                    by solve( St_VP( ~idV, %1, prev_nP, ~ch.3, 'verify_state'
