theory 5_1_rld_counter

begin

// Function signature and definition of the equational theory E

builtins: natural-numbers
functions: fst/1, pair/2, pk/1, sign/2, snd/1, true/0, verify/3
equations:
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    verify(sign(x.1, x.2), x.1, pk(x.2)) = true

heuristic: I

/* looping facts with injective instances: St_PV/3, St_VP/5 */

restriction Equality:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

  /*
  expanded formula:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  */

restriction LessThan:
  "∀ %x %y #i. (LessThan( %x, %y ) @ #i) ⇒ (%x ⊏ %y)"
  // safety formula

  /*
  expanded formula:
  "∀ %x %y #i. (LessThan( %x, %y ) @ #i) ⇒ (%x ⊏ %y)"
  */

restriction GreaterThan:
  "∀ %x %y #i. (GreaterThan( %x, %y ) @ #i) ⇒ (%y ⊏ %x)"
  // safety formula

  /*
  expanded formula:
  "∀ %x %y #i. (GreaterThan( %x, %y ) @ #i) ⇒ (%y ⊏ %x)"
  */

restriction RegisterOnce:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( p, v ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ p v #i #j.
    ((Register( p, v ) @ #i) ∧ (Register( p, v ) @ #j)) ⇒ (#i = #j)"
  */

restriction NoReplayChallenge:
  "∀ p v %cP1 nP1 %cP2 nP2 ch #i #j.
    ((Response( p, v, %cP1, nP1, ch ) @ #i) ∧
     (Response( p, v, %cP2, nP2, ch ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ p v %cP1 nP1 %cP2 nP2 ch #i #j.
    ((Response( p, v, %cP1, nP1, ch ) @ #i) ∧
     (Response( p, v, %cP2, nP2, ch ) @ #j)) ⇒
    (#i = #j)"
  */

restriction TimeoutPerPairOnce:
  "∀ v p %cP1 nP1 ch1 %cP2 nP2 ch2 #i #j.
    ((ChallengeTimeout( v, p, %cP1, nP1, ch1 ) @ #i) ∧
     (ChallengeTimeout( v, p, %cP2, nP2, ch2 ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ v p %cP1 nP1 ch1 %cP2 nP2 ch2 #i #j.
    ((ChallengeTimeout( v, p, %cP1, nP1, ch1 ) @ #i) ∧
     (ChallengeTimeout( v, p, %cP2, nP2, ch2 ) @ #j)) ⇒
    (#i = #j)"
  */

rule (modulo E) Register:
   [ Fr( ~ltkPV ), Fr( ~ltkVP ), Fr( ~idP ), Fr( ~idV ), Fr( ~inj_n )
   ]
  --[ Register( $P, $V ) ]->
   [
   !Binding_PV( $P, $V, ~idP, ~idV, pk(~ltkPV), pk(~ltkVP), ~ltkPV ),
   !Binding_VP( $V, $P, ~idV, ~idP, pk(~ltkVP), pk(~ltkPV), ~ltkVP ),
   St_PV( ~idP, %1, 'null' ),
   St_VP( ~idV, %1, 'null', ~inj_n, 'challenge_state' ),
   Out( <pk(~ltkPV), pk(~ltkVP), ~idP, ~idV, ~inj_n> )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) V_challenge:
   [
   St_VP( ~idV, %prev_cP, prev_nP, ~inj_n, 'challenge_state' ),
   !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP ), Fr( ~ch )
   ]
  --[
  Challenge( $V, $P, %prev_cP, prev_nP, ~ch ),
  Injectivity( ~idV, ~inj_n, ~ch )
  ]->
   [
   St_VP( ~idV, %prev_cP, prev_nP, ~ch, 'verify_state' ),
   Out( <<'challenge', $V, $P, %prev_cP, prev_nP, ~ch>, 
         sign(<'challenge', $V, $P, %prev_cP, prev_nP, ~ch>, ~ltkVP)>
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) V_challenge_timeout:
   [
   St_VP( ~idV, %prev_cP, prev_nP, ~ch, 'verify_state' ),
   !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP ), Fr( ~inj_n )
   ]
  --[
  ChallengeTimeout( $V, $P, %prev_cP, prev_nP, ~ch ),
  Injectivity( ~idV, ~ch, ~inj_n )
  ]->
   [ St_VP( ~idV, %prev_cP, prev_nP, ~inj_n, 'challenge_state' ) ]

  // loop breaker: [0]
  /* has exactly the trivial AC variant */

rule (modulo E) P_response:
   [
   In( <<'challenge', $V, $P, %sent_prev_cP, sent_prev_nP, ch>, v_sig>
   ),
   St_PV( ~idP, %prev_cP, prev_nP ),
   !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pkVP, ~ltkPV ), Fr( ~nP )
   ]
  --[
  Eq( verify(v_sig,
             <'challenge', $V, $P, %sent_prev_cP, sent_prev_nP, ch>, pkVP),
      true
  ),
  Response( $P, $V, (%prev_cP%+%1), ~nP, ch )
  ]->
   [
   St_PV( ~idP, (%prev_cP%+%1), ~nP ),
   Out( <<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, 
         sign(<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, ~ltkPV)>
   )
   ]

  // loop breaker: [1]
  /*
  rule (modulo AC) P_response:
     [
     In( <<'challenge', $V, $P, %sent_prev_cP, sent_prev_nP, ch>, v_sig>
     ),
     St_PV( ~idP, %prev_cP, prev_nP ),
     !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pkVP, ~ltkPV ), Fr( ~nP )
     ]
    --[ Eq( z, true ), Response( $P, $V, (%prev_cP%+%1), ~nP, ch ) ]->
     [
     St_PV( ~idP, (%prev_cP%+%1), ~nP ),
     Out( <<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, 
           sign(<'response', $P, $V, (%prev_cP%+%1), ~nP, ch>, ~ltkPV)>
     )
     ]
    variants (modulo AC)
    1. $P    = $P.32
       $V    = $V.33
       ch    = ch.38
       pkVP  = pkVP.40
       sent_prev_nP
             = sent_prev_nP.42
       v_sig = v_sig.43
       z     = verify(v_sig.43,
                      <'challenge', $V.33, $P.32, %sent_prev_cP.45, sent_prev_nP.42, 
                       ch.38>,
                      pkVP.40)
       %sent_prev_cP
             = %sent_prev_cP.45
    
    2. $P    = $P.44
       $V    = $V.45
       ch    = ch.50
       pkVP  = pk(x.86)
       sent_prev_nP
             = sent_prev_nP.54
       v_sig = sign(<'challenge', $V.45, $P.44, %sent_prev_cP.57, 
                     sent_prev_nP.54, ch.50>,
                    x.86)
       z     = true
       %sent_prev_cP
             = %sent_prev_cP.57
    // loop breaker: [1]
  */

rule (modulo E) V_accept:
   [
   In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
   St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state' ),
   !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP ), Fr( ~inj_n )
   ]
  --[
  Verify( $V, $P, %cP, nP, ch ),
  Eq( verify(sig, <'response', $P, $V, %cP, nP, ch>, pkPV), true ),
  Eq( (%prev_cP%+%1), %cP ), Accept( $V, $P ),
  Injectivity( ~idV, ch, ~inj_n )
  ]->
   [ St_VP( ~idV, %cP, nP, ~inj_n, 'challenge_state' ) ]

  // loop breaker: [1]
  /*
  rule (modulo AC) V_accept:
     [
     In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
     St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state' ),
     !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP ), Fr( ~inj_n )
     ]
    --[
    Verify( $V, $P, %cP, nP, ch ), Eq( z, true ),
    Eq( (%prev_cP%+%1), %cP ), Accept( $V, $P ),
    Injectivity( ~idV, ch, ~inj_n )
    ]->
     [ St_VP( ~idV, %cP, nP, ~inj_n, 'challenge_state' ) ]
    variants (modulo AC)
    1. $P    = $P.32
       $V    = $V.33
       ch    = ch.38
       nP    = nP.39
       pkPV  = pkPV.40
       sig   = sig.43
       z     = verify(sig.43,
                      <'response', $P.32, $V.33, %cP.44, nP.39, ch.38>, pkPV.40)
       %cP   = %cP.44
    
    2. $P    = $P.64
       $V    = $V.65
       ch    = ch.70
       nP    = nP.71
       pkPV  = pk(x.126)
       sig   = sign(<'response', $P.64, $V.65, %cP.76, nP.71, ch.70>,
                    x.126)
       z     = true
       %cP   = %cP.76
    // loop breaker: [1]
  */

rule (modulo E) V_detect_cloning:
   [
   In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
   St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state' ),
   !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP )
   ]
  --[
  Verify( $V, $P, %cP, nP, ch ),
  Eq( verify(sig, <'response', $P, $V, %cP, nP, ch>, pkPV), true ),
  GreaterThan( (%prev_cP%+%1), %cP ), DetectCloning( $V, $P )
  ]->
   [ ]

  /*
  rule (modulo AC) V_detect_cloning:
     [
     In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
     St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state' ),
     !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP )
     ]
    --[
    Verify( $V, $P, %cP, nP, ch ), Eq( z, true ),
    GreaterThan( (%prev_cP%+%1), %cP ), DetectCloning( $V, $P )
    ]->
     [ ]
    variants (modulo AC)
    1. $P    = $P.29
       $V    = $V.30
       ch    = ch.34
       nP    = nP.35
       pkPV  = pkPV.36
       sig   = sig.39
       z     = verify(sig.39,
                      <'response', $P.29, $V.30, %cP.40, nP.35, ch.34>, pkPV.36)
       %cP   = %cP.40
    
    2. $P    = $P.41
       $V    = $V.42
       ch    = ch.46
       nP    = nP.47
       pkPV  = pk(x.80)
       sig   = sign(<'response', $P.41, $V.42, %cP.52, nP.47, ch.46>,
                    x.80)
       z     = true
       %cP   = %cP.52
  */

rule (modulo E) V_detect_response_loss:
   [
   In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
   St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state' ),
   !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP )
   ]
  --[
  Verify( $V, $P, %cP, nP, ch ),
  Eq( verify(sig, <'response', $P, $V, %cP, nP, ch>, pkPV), true ),
  LessThan( (%prev_cP%+%1), %cP ), DetectResponseLoss( $V, $P )
  ]->
   [ ]

  /*
  rule (modulo AC) V_detect_response_loss:
     [
     In( <<'response', $P, $V, %cP, nP, ch>, sig> ),
     St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state' ),
     !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP )
     ]
    --[
    Verify( $V, $P, %cP, nP, ch ), Eq( z, true ),
    LessThan( (%prev_cP%+%1), %cP ), DetectResponseLoss( $V, $P )
    ]->
     [ ]
    variants (modulo AC)
    1. $P    = $P.29
       $V    = $V.30
       ch    = ch.34
       nP    = nP.35
       pkPV  = pkPV.36
       sig   = sig.39
       z     = verify(sig.39,
                      <'response', $P.29, $V.30, %cP.40, nP.35, ch.34>, pkPV.36)
       %cP   = %cP.40
    
    2. $P    = $P.41
       $V    = $V.42
       ch    = ch.46
       nP    = nP.47
       pkPV  = pk(x.80)
       sig   = sign(<'response', $P.41, $V.42, %cP.52, nP.47, ch.46>,
                    x.80)
       z     = true
       %cP   = %cP.52
  */

rule (modulo E) Reveal_ltk_PV:
   [ !Binding_PV( $P, $V, ~idP, ~idV, pkPV, pkVP, ~ltkPV ) ]
  --[ Reveal_ltk_PV( $P, $V ) ]->
   [ Out( ~ltkPV ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_ltk_VP:
   [ !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP ) ]
  --[ Reveal_ltk_VP( $V, $P ) ]->
   [ Out( ~ltkVP ) ]

  /* has exactly the trivial AC variant */

lemma challenge_monotonicity [reuse, use_induction]:
  all-traces
  "∀ v p %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
    (((Challenge( v, p, %cP1, nP1, ch1 ) @ #i1) ∧
      (Challenge( v, p, %cP2, nP2, ch2 ) @ #i2)) ∧
     (#i1 < #i2)) ⇒
    ((%cP1 ⊏ %cP2) ∨ (%cP1 = %cP2))"
/*
guarded formula characterizing all counter-examples:
"∃ v p %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
  (Challenge( v, p, %cP1, nP1, ch1 ) @ #i1) ∧
  (Challenge( v, p, %cP2, nP2, ch2 ) @ #i2)
 ∧
  (#i1 < #i2) ∧ (¬(%cP1 ⊏ %cP2)) ∧ (¬(%cP1 = %cP2))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  simplify
  solve( St_VP( ~idV, %cP1, nP1, ~inj_n, 'challenge_state' ) ▶₀ #i1 )
    case Register
    by contradiction /* from formulas */
  next
    case V_accept
    simplify
    solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP
           ) ▶₁ #i1 )
      case Register
      solve( St_VP( ~idV.1, %cP2, nP2, ~inj_n.1, 'challenge_state'
             ) ▶₀ #i2 )
        case Register
        solve( !Binding_VP( $V, $P, ~idV.1, ~idP.1, pkVP, pkPV, ~ltkVP.1
               ) ▶₁ #i2 )
          case Register
          by contradiction /* cyclic */
        qed
      next
        case V_accept
        simplify
        solve( !Binding_VP( $V, $P, ~idV.1, ~idP.1, pkVP, pkPV, ~ltkVP.1
               ) ▶₁ #i2 )
          case Register
          solve( (last(#i2))  ∥ ((%prev_cP%+%1) = (%prev_cP.1%+%1)) )
            case case_1
            solve( !KU( sign(<'response', $P, $V, (%prev_cP%+%1), nP1, ch.2>,
                             ~ltkPV)
                   ) @ #vk.16 )
              case P_response
              solve( St_VP( ~idV, %prev_cP, prev_nP, ch.2, 'verify_state'
                     ) ▶₁ #vr )
                case V_challenge_case_1
                by contradiction /* from formulas */
              next
                case V_challenge_case_2
                solve( !KU( sign(<'response', $P, $V, (%prev_cP.1%+%1), nP2, ch.3>,
                                 ~ltkPV)
                       ) @ #vk.27 )
                  case P_response
                  solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ch.3, 'verify_state'
                         ) ▶₁ #vr.2 )
                    case V_challenge_case_1
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_2
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_3
                    by simplify
                  qed
                next
                  case V_challenge
                  solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ch.3, 'verify_state'
                         ) ▶₁ #vr.2 )
                    case V_challenge_case_1
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_2
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_3
                    simplify
                    by contradiction /* cyclic */
                  qed
                next
                  case c_sign
                  solve( !KU( ~ltkPV ) @ #vk.33 )
                    case Reveal_ltk_PV
                    solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ch.3, 'verify_state'
                           ) ▶₁ #vr.2 )
                      case V_challenge_case_1
                      by contradiction /* cyclic */
                    next
                      case V_challenge_case_2
                      simplify
                      by contradiction /* cyclic */
                    qed
                  next
                    case V_challenge
                    solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ch.3, 'verify_state'
                           ) ▶₁ #vr.2 )
                      case V_challenge_case_1
                      by contradiction /* cyclic */
                    next
                      case V_challenge_case_2
                      simplify
                      by contradiction /* cyclic */
                    qed
                  qed
                qed
              next
                case V_challenge_case_3
                simplify
                solve( !KU( sign(<'response', $P, $V, (%prev_cP.1%+%1), nP2, ch.3>,
                                 ~ltkPV)
                       ) @ #vk.32 )
                  case P_response
                  solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ch.3, 'verify_state'
                         ) ▶₁ #vr.2 )
                    case V_challenge_case_1
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_2
                    by simplify
                  next
                    case V_challenge_case_3
                    simplify
                    by contradiction /* cyclic */
                  qed
                next
                  case V_challenge
                  solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ch.3, 'verify_state'
                         ) ▶₁ #vr.2 )
                    case V_challenge_case_1
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_2
                    simplify
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_3
                    simplify
                    by contradiction /* cyclic */
                  qed
                next
                  case c_sign
                  solve( !KU( ~ltkPV ) @ #vk.43 )
                    case Reveal_ltk_PV
                    solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ch.3, 'verify_state'
                           ) ▶₁ #vr.2 )
                      case V_challenge_case_1
                      by contradiction /* cyclic */
                    next
                      case V_challenge_case_2
                      simplify
                      by contradiction /* cyclic */
                    next
                      case V_challenge_case_3
                      simplify
                      by contradiction /* cyclic */
                    qed
                  next
                    case V_challenge
                    solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ch.3, 'verify_state'
                           ) ▶₁ #vr.2 )
                      case V_challenge_case_1
                      by contradiction /* cyclic */
                    next
                      case V_challenge_case_2
                      simplify
                      by contradiction /* cyclic */
                    next
                      case V_challenge_case_3
                      simplify
                      by contradiction /* cyclic */
                    qed
                  qed
                qed
              qed
            next
              case V_challenge
              solve( St_VP( ~idV, %prev_cP, prev_nP, ch.2, 'verify_state'
                     ) ▶₁ #vr )
                case V_challenge_case_1
                by contradiction /* from formulas */
              next
                case V_challenge_case_2
                solve( !KU( sign(<'response', $P, $V, (%prev_cP.1%+%1), nP2, ch.4>,
                                 ~ltkPV)
                       ) @ #vk.22 )
                  case P_response
                  solve( St_VP( ~idV, %prev_cP.1, prev_nP.2, ch.4, 'verify_state'
                         ) ▶₁ #vr.2 )
                    case V_challenge_case_1
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_2
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_3
                    simplify
                    by contradiction /* cyclic */
                  qed
                next
                  case V_challenge
                  solve( St_VP( ~idV, %prev_cP.1, prev_nP.2, ch.4, 'verify_state'
                         ) ▶₁ #vr.2 )
                    case V_challenge_case_1
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_2
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_3
                    simplify
                    by contradiction /* cyclic */
                  qed
                next
                  case c_sign
                  solve( !KU( ~ltkPV ) @ #vk.23 )
                    case Reveal_ltk_PV
                    solve( St_VP( ~idV, %prev_cP.1, prev_nP.2, ch.4, 'verify_state'
                           ) ▶₁ #vr.2 )
                      case V_challenge_case_1
                      by contradiction /* cyclic */
                    next
                      case V_challenge_case_2
                      simplify
                      by contradiction /* cyclic */
                    qed
                  next
                    case V_challenge
                    solve( St_VP( ~idV, %prev_cP.1, prev_nP.2, ch.4, 'verify_state'
                           ) ▶₁ #vr.2 )
                      case V_challenge_case_1
                      by contradiction /* cyclic */
                    next
                      case V_challenge_case_2
                      simplify
                      by contradiction /* cyclic */
                    qed
                  qed
                qed
              next
                case V_challenge_case_3
                simplify
                solve( !KU( sign(<'response', $P, $V, (%prev_cP.1%+%1), nP2, ch.4>,
                                 ~ltkPV)
                       ) @ #vk.26 )
                  case P_response
                  solve( St_VP( ~idV, %prev_cP.1, prev_nP.2, ch.4, 'verify_state'
                         ) ▶₁ #vr.2 )
                    case V_challenge_case_1
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_2
                    simplify
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_3
                    simplify
                    by contradiction /* cyclic */
                  qed
                next
                  case V_challenge
                  solve( St_VP( ~idV, %prev_cP.1, prev_nP.2, ch.4, 'verify_state'
                         ) ▶₁ #vr.2 )
                    case V_challenge_case_1
                    by contradiction /* cyclic */
                  next
                    case V_challenge_case_2
                    simplify
