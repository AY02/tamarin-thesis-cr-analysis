                            ~ltkVP.1
               ) ▶₁ #i1 )
          case Register
          solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pkPV.1,
                              ~ltkVP.2
                 ) ▶₁ #i3 )
            case Register
            solve( St_VP( ~idV, %prev_cP, prev_nP, ~inj_n, 'challenge_state'
                   ) ▶₀ #i )
              case Register
              by contradiction /* cyclic */
            next
              case V_accept
              simplify
              solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP
                     ) ▶₁ #i )
                case Register
                solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~ch.1, 'verify_state'
                       ) ▶₀ #i3 )
                  case V_challenge
                  by contradiction /* cyclic */
                qed
              qed
            next
              case V_challenge_timeout
              by contradiction /* cyclic */
            qed
          qed
        qed
      next
        case V_challenge_timeout
        solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV.1,
                            ~ltkVP.1
               ) ▶₁ #i1 )
          case Register
          solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pkPV.1,
                              ~ltkVP.2
                 ) ▶₁ #i3 )
            case Register
            by contradiction /* cyclic */
          qed
        qed
      qed
    next
      case V_challenge_timeout
      solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ~inj_n.1,
                    'challenge_state'
             ) ▶₀ #i1 )
        case Register
        solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV.1,
                            ~ltkVP.1
               ) ▶₁ #i1 )
          case Register
          solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pkPV.1,
                              ~ltkVP.2
                 ) ▶₁ #i3 )
            case Register
            solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP
                   ) ▶₁ #i )
              case Register
              by contradiction /* cyclic */
            qed
          qed
        qed
      next
        case V_accept
        solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV.1,
                            ~ltkVP.1
               ) ▶₁ #i1 )
          case Register
          solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pkPV.1,
                              ~ltkVP.2
                 ) ▶₁ #i3 )
            case Register
            solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP
                   ) ▶₁ #i )
              case Register
              by contradiction /* cyclic */
            qed
          qed
        qed
      next
        case V_challenge_timeout
        solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV.1,
                            ~ltkVP.1
               ) ▶₁ #i1 )
          case Register
          solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pkPV.1,
                              ~ltkVP.2
                 ) ▶₁ #i3 )
            case Register
            by contradiction /* cyclic */
          qed
        qed
      qed
    qed
  qed
next
  case V_challenge_timeout
  solve( Injectivity( ~idV, ~inj_n, inj_n2 ) @ #i3 )
    case V_accept
    solve( !KU( ~inj_n ) @ #vk.11 )
      case V_challenge
      solve( Injectivity( ~idV, n1, n2 ) @ #i )
        case V_accept
        solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV,
                            ~ltkVP.1
               ) ▶₁ #i1 )
          case Register
          solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pk(x.1),
                              ~ltkVP.2
                 ) ▶₂ #i3 )
            case Register
            solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
                   ) ▶₂ #i )
              case Register
              solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ~ch, 'verify_state'
                     ) ▶₀ #i1 )
                case V_challenge_case_1
                by solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ~inj_n.1,
                                 'verify_state'
                          ) ▶₁ #i3 )
              next
                case V_challenge_case_2
                by contradiction /* cyclic */
              next
                case V_challenge_case_3
                by solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                                 'verify_state'
                          ) ▶₁ #i3 )
              qed
            qed
          qed
        qed
      next
        case V_challenge
        solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV.1,
                            ~ltkVP.1
               ) ▶₁ #i1 )
          case Register
          solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pk(x),
                              ~ltkVP.2
                 ) ▶₂ #i3 )
            case Register
            solve( St_VP( ~idV, %prev_cP, prev_nP, ~inj_n, 'challenge_state'
                   ) ▶₀ #i )
              case Register
              by contradiction /* cyclic */
            next
              case V_accept
              solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP
                     ) ▶₁ #i )
                case Register
                solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ~ch.1, 'verify_state'
                       ) ▶₀ #i1 )
                  case V_challenge_case_1
                  by solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ~inj_n.1,
                                   'verify_state'
                            ) ▶₁ #i3 )
                next
                  case V_challenge_case_2
                  by contradiction /* cyclic */
                next
                  case V_challenge_case_3
                  by solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                                   'verify_state'
                            ) ▶₁ #i3 )
                qed
              qed
            next
              case V_challenge_timeout
              solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP
                     ) ▶₁ #i )
                case Register
                solve( St_VP( ~idV, %prev_cP, prev_nP, ~ch.1, 'verify_state'
                       ) ▶₀ #i1 )
                  case V_challenge_case_1
                  by solve( St_VP( ~idV, %prev_cP, prev_nP, ~inj_n, 'verify_state'
                            ) ▶₁ #i3 )
                next
                  case V_challenge_case_2
                  by contradiction /* cyclic */
                next
                  case V_challenge_case_3
                  by solve( St_VP( ~idV, %prev_cP.1, prev_nP.1, ~inj_n,
                                   'verify_state'
                            ) ▶₁ #i3 )
                qed
              qed
            qed
          qed
        qed
      next
        case V_challenge_timeout
        solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV.1,
                            ~ltkVP.1
               ) ▶₁ #i1 )
          case Register
          solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pk(x),
                              ~ltkVP.2
                 ) ▶₂ #i3 )
            case Register
            solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pkPV, ~ltkVP
                   ) ▶₁ #i )
              case Register
              by contradiction /* cyclic */
            qed
          qed
        qed
      qed
    qed
  next
    case V_challenge
    solve( Injectivity( ~idV, n1, n2 ) @ #i )
      case V_accept
      solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV,
                          ~ltkVP.1
             ) ▶₁ #i1 )
        case Register
        solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                      'challenge_state'
               ) ▶₀ #i3 )
          case V_challenge_timeout
          by contradiction /* cyclic */
        qed
      qed
    next
      case V_challenge
      solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV.1,
                          ~ltkVP.1
             ) ▶₁ #i1 )
        case Register
        solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                      'challenge_state'
               ) ▶₀ #i3 )
          case V_challenge_timeout
          by contradiction /* cyclic */
        qed
      qed
    next
      case V_challenge_timeout
      solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV.1,
                          ~ltkVP.1
             ) ▶₁ #i1 )
        case Register
        solve( St_VP( ~idV, %prev_cP.2, prev_nP.2, ~inj_n.1,
                      'challenge_state'
               ) ▶₀ #i3 )
          case V_challenge_timeout
          by contradiction /* cyclic */
        qed
      qed
    qed
  next
    case V_challenge_timeout
    solve( Injectivity( ~idV, n1, n2 ) @ #i )
      case V_accept
      solve( !Binding_VP( $V.1, $P.1, ~idV, ~idP.1, pkVP.1, pkPV,
                          ~ltkVP.1
             ) ▶₁ #i1 )
        case Register
        solve( !Binding_VP( $V.2, $P.2, ~idV, ~idP.2, pkVP.1, pkPV,
                            ~ltkVP.2
               ) ▶₁ #i3 )
          case Register
