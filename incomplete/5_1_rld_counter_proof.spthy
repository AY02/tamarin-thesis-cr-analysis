lemma response_loss_detection_soundness:
  all-traces
  "∀ p v #i3.
    (((DetectResponseLoss( v, p ) @ #i3) ∧
      (¬(∃ #i. (Reveal_ltk_PV( p, v ) @ #i) ∧ (#i < #i3)))) ∧
     (¬(∃ #i. (Reveal_ltk_VP( v, p ) @ #i) ∧ (#i < #i3)))) ⇒
    (∃ %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
      (((Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧
        (Response( p, v, %cP2, nP2, ch2 ) @ #i2)) ∧
       (#i1 < #i2)) ∧
      (#i2 < #i3))"
/*
guarded formula characterizing all counter-examples:
"∃ p v #i3.
  (DetectResponseLoss( v, p ) @ #i3)
 ∧
  (∀ #i. (Reveal_ltk_PV( p, v ) @ #i) ⇒ ¬(#i < #i3)) ∧
  (∀ #i. (Reveal_ltk_VP( v, p ) @ #i) ⇒ ¬(#i < #i3)) ∧
  (∀ %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
    (Response( p, v, %cP1, nP1, ch1 ) @ #i1) ∧
    (Response( p, v, %cP2, nP2, ch2 ) @ #i2)
   ⇒
    ((¬(#i1 < #i2)) ∨ (¬(#i2 < #i3))))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i3))  ∥
         (∃ #i.
           (Reveal_ltk_PV( $P, $V ) @ #i) ∧ (¬(last(#i))) ∧ (#i < #i3))  ∥
         (∃ #i.
           (Reveal_ltk_VP( $V, $P ) @ #i) ∧ (¬(last(#i))) ∧ (#i < #i3))  ∥
         (∃ %cP1 nP1 ch1 %cP2 nP2 ch2 #i1 #i2.
           (Response( $P, $V, %cP1, nP1, ch1 ) @ #i1) ∧
           (Response( $P, $V, %cP2, nP2, ch2 ) @ #i2)
          ∧
           (¬(last(#i2))) ∧ (¬(last(#i1))) ∧ (#i1 < #i2) ∧ (#i2 < #i3)) )
    case case_1
    solve( !Binding_VP( $V, $P, ~idV, ~idP, pkVP, pk(x), ~ltkVP
           ) ▶₂ #i3 )
      case Register
      solve( St_VP( ~idV, %prev_cP, prev_nP, ch, 'verify_state'
             ) ▶₁ #i3 )
        case V_challenge_case_1
        solve( !KU( sign(<'response', $P, $V, %cP, nP, ~ch>, ~ltkPV)
               ) @ #vk.12 )
          case P_response
          solve( St_PV( ~idP, %prev_cP, prev_nP ) ▶₁ #vr.2 )
            case P_response
            by contradiction /* from formulas */
          next
            case Register
            by contradiction /* contradictory subterm store */
          qed
        next
          case V_challenge
          solve( St_VP( ~idV.1, %prev_cP, prev_nP, ~ch.2, 'verify_state'
                 ) ▶₀ #vr.9 )
            case V_challenge_case_1
            by contradiction /* forbidden KD-fact */
          next
            case V_challenge_case_2
            by contradiction /* cyclic */
          next
            case V_challenge_case_3
            by contradiction /* cyclic */
          qed
        next
          case c_sign
          solve( !KU( ~ltkPV ) @ #vk.13 )
            case Reveal_ltk_PV
            by contradiction /* from formulas */
          next
            case V_challenge
            solve( St_VP( ~idV.1, %prev_cP, prev_nP, ~ch.2, 'verify_state'
                   ) ▶₀ #vr.9 )
              case V_challenge_case_1
              by contradiction /* forbidden KD-fact */
            next
              case V_challenge_case_2
              by contradiction /* cyclic */
            next
              case V_challenge_case_3
              by contradiction /* cyclic */
            qed
          qed
        qed
      next
        case V_challenge_case_2
        solve( !KU( sign(<'response', $P, $V, %cP, nP, ~ch>, ~ltkPV)
               ) @ #vk.12 )
          case P_response
          solve( St_PV( ~idP, %prev_cP, prev_nP.1 ) ▶₁ #vr.3 )
            case P_response
            by contradiction /* from formulas */
          next
            case Register
            by contradiction /* contradictory subterm store */
          qed
        next
          case V_challenge
          solve( St_VP( ~idV.1, %prev_cP.1, prev_nP.1, ~ch.3, 'verify_state'
                 ) ▶₀ #vr.10 )
            case V_challenge_case_1
            by contradiction /* forbidden KD-fact */
          next
            case V_challenge_case_2
            by contradiction /* cyclic */
          next
            case V_challenge_case_3
            by contradiction /* cyclic */
          qed
        next
